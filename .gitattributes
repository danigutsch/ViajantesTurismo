# Repository line-ending policy. Git stores and checks out text as LF for
# deterministic cross-platform diffs, independent of user autocrlf.
* text=auto

# Text source, build, docs, and data files use LF.
*.cs text eol=lf diff=csharp
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.slnx text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

*.json text eol=lf
*.jsonc text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.feature text eol=lf
*.xml text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
.shellcheckrc text eol=lf

# Generated workflow locks and NuGet lock files should not use line endings as
# a merge signal. Keep their EOL normalized, but require explicit conflict
# resolution when content changes concurrently.
.github/workflows/*.lock.yml linguist-generated=true merge=binary
**/packages.lock.json text eol=lf merge=binary

# Binary assets must never be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
