root = true

[*]
end_of_line = lf
insert_final_newline = true

[*.{cs,vb}]
#### Naming styles ####

# Naming rules

dotnet_naming_rule.interface_should_be_begins_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_rule.types_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

dotnet_naming_rule.non_field_members_should_be_pascal_case.severity = warning
dotnet_naming_rule.non_field_members_should_be_pascal_case.symbols = non_field_members
dotnet_naming_rule.non_field_members_should_be_pascal_case.style = pascal_case

# Symbol specifications

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.interface.required_modifiers =

dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum
dotnet_naming_symbols.types.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.types.required_modifiers =

dotnet_naming_symbols.non_field_members.applicable_kinds = property, event, method
dotnet_naming_symbols.non_field_members.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.non_field_members.required_modifiers =

# Naming styles

dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.required_suffix =
dotnet_naming_style.begins_with_i.word_separator =
dotnet_naming_style.begins_with_i.capitalization = pascal_case

dotnet_naming_style.pascal_case.required_prefix =
dotnet_naming_style.pascal_case.required_suffix =
dotnet_naming_style.pascal_case.word_separator =
dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_style_operator_placement_when_wrapping = beginning_of_line
tab_width = 4
indent_size = 4
end_of_line = lf
dotnet_style_coalesce_expression = true:warning
dotnet_style_null_propagation = true:warning
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_object_initializer = true:warning
dotnet_style_collection_initializer = true:suggestion
dotnet_diagnostic.IDE0001.severity = warning
dotnet_diagnostic.IDE0002.severity = warning
dotnet_diagnostic.IDE0005.severity = warning
dotnet_diagnostic.IDE0028.severity = suggestion
dotnet_style_prefer_simplified_boolean_expressions = true:warning
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:suggestion
dotnet_style_explicit_tuple_names = true:warning
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion
dotnet_style_prefer_compound_assignment = true:warning
dotnet_style_prefer_simplified_interpolation = true:warning
dotnet_diagnostic.CA2007.severity = warning
dotnet_code_quality.CA2000.dispose_ownership_transfer_at_method_call = true
dotnet_style_predefined_type_for_locals_parameters_members = true:silent

[*.cs]
end_of_line = lf
insert_final_newline = true
csharp_using_directive_placement = outside_namespace:warning
csharp_prefer_simple_using_statement = true:warning
csharp_prefer_braces = true:warning

csharp_max_line_length = 200
csharp_wrap_parameters_style = wrap_if_long

csharp_indent_block_contents = true
csharp_indent_braces = false

csharp_style_namespace_declarations = file_scoped:warning
csharp_style_prefer_method_group_conversion = true:suggestion
csharp_style_prefer_top_level_statements = true:suggestion
csharp_style_prefer_primary_constructors = true:warning
csharp_prefer_system_threading_lock = true:warning
csharp_style_prefer_simple_property_accessors = true:suggestion
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_operators = false:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_accessors = true:silent
csharp_style_expression_bodied_lambdas = true:silent
csharp_style_expression_bodied_local_functions = false:silent
csharp_style_prefer_local_over_anonymous_function = true:warning
csharp_prefer_static_local_function = true:warning
csharp_style_conditional_delegate_call = true:warning
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_prefer_pattern_matching = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_prefer_switch_expression = true:warning
csharp_style_prefer_not_pattern = true:warning
csharp_style_prefer_extended_property_pattern = true:warning
dotnet_diagnostic.CA1812.severity = silent
dotnet_diagnostic.CA1716.severity = warning
# Public null-guard policy: production public APIs validate caller-provided arguments.
# Keep exceptions scoped to generated EF artifacts and framework-owned test bindings only.
dotnet_diagnostic.CA1062.severity = error
dotnet_diagnostic.CA1000.severity = warning
dotnet_diagnostic.CA1002.severity = warning
dotnet_diagnostic.CA1034.severity = warning
dotnet_diagnostic.CA1040.severity = warning
dotnet_diagnostic.CA1303.severity = warning
dotnet_diagnostic.CA1508.severity = warning
dotnet_diagnostic.CA1515.severity = warning
dotnet_diagnostic.CA1711.severity = warning
dotnet_diagnostic.CA1814.severity = warning
dotnet_diagnostic.CA1822.severity = warning
dotnet_diagnostic.CA1852.severity = warning
dotnet_diagnostic.CA5394.severity = warning
dotnet_diagnostic.CS1591.severity = warning
dotnet_diagnostic.IDE0161.severity = warning
dotnet_diagnostic.S2326.severity = warning
dotnet_diagnostic.S2094.severity = warning
dotnet_diagnostic.S1186.severity = warning
dotnet_diagnostic.S4136.severity = warning
dotnet_diagnostic.S4144.severity = warning
dotnet_diagnostic.S4035.severity = warning
dotnet_diagnostic.SKSTYLE001.severity = suggestion
dotnet_diagnostic.SKSTYLE002.severity = suggestion
dotnet_diagnostic.SKSTYLE003.severity = suggestion
dotnet_diagnostic.SKSTYLE004.severity = suggestion
dotnet_diagnostic.SKTEST001.severity = warning
dotnet_diagnostic.SKTEST002.severity = warning
dotnet_diagnostic.SKTEST003.severity = warning
dotnet_diagnostic.SKTEST004.severity = warning
dotnet_diagnostic.SKTEST005.severity = warning
dotnet_diagnostic.SKTEST006.severity = suggestion

# Shell scripts
[*.{sh,bash}]
indent_size = 4
indent_style = space
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# PowerShell scripts
[*.{ps1,psm1,psd1}]
indent_size = 4
indent_style = space
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JSON files
[*.json]
indent_size = 2
indent_style = space
end_of_line = lf
insert_final_newline = true

# YAML files
[*.{yml,yaml}]
indent_size = 2
indent_style = space
end_of_line = lf
insert_final_newline = true

# Markdown files
[*.md]
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# Shell scripts (Unix line endings required)
[*.sh]
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true

# Shell script configuration files
[.shellcheckrc]
end_of_line = lf
insert_final_newline = true

# Git hooks (shell scripts without extension)
[scripts/{pre-commit,post-commit,prepare-commit-msg,commit-msg}]
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true

# EF migrations are generated infrastructure artifacts. Owner: Infrastructure maintainers.
# Keep generated-shape exceptions here instead of editing migration files by hand; remove a rule
# only when EF tooling stops generating that diagnostic for new migrations and snapshots.
# CA1062 is included because EF-generated migration operations do not model caller-facing APIs.
[**/Migrations/*.cs]
dotnet_diagnostic.CA1002.severity = none
dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1711.severity = none
dotnet_diagnostic.CA1814.severity = none
dotnet_diagnostic.CA1852.severity = none
dotnet_diagnostic.IDE0161.severity = none
generated_code = true

# CS0612/CS0618 are emitted by EF-generated migration metadata that calls obsolete
# provider APIs for compatibility. Remove these exceptions when EF/Npgsql tooling
# no longer generates obsolete API usage in migration designer or snapshot files.
[**/Migrations/*.Designer.cs]
dotnet_diagnostic.CS0612.severity = none
dotnet_diagnostic.CS0618.severity = none

[**/Migrations/*ModelSnapshot.cs]
dotnet_diagnostic.CS0612.severity = none
dotnet_diagnostic.CS0618.severity = none

# C# extension block false-positive in .NET 10 analyzers (dotnet/sdk#51681).
# Keep scoped to the single file and remove when upgrading to an SDK with the fix.
[tests/ViajantesTurismo.Admin.Tests.Shared/Integration/Helpers/ApiTestExtensions.cs]
dotnet_diagnostic.CA1034.severity = none

# API and Blazor app entry projects expose framework-discovered surfaces that are not package APIs.
# Owner: API/Web maintainers. Remove when public framework entrypoints are fully documented or internalized.
[src/ViajantesTurismo.Admin.ApiService/**.cs]
dotnet_diagnostic.CS1591.severity = none

[src/ViajantesTurismo.Catalog.ApiService/**.cs]
dotnet_diagnostic.CS1591.severity = none

[src/ViajantesTurismo.Management.Web/**.cs]
dotnet_diagnostic.CS1591.severity = none

# CA2007 is valuable for reusable libraries, but application/host code intentionally keeps
# framework-context awaits readable. Owner: application maintainers. Remove scope entries as
# app layers adopt an explicit ConfigureAwait policy.
[src/ViajantesTurismo.Admin.Application/**.cs]
dotnet_diagnostic.CA2007.severity = none

[src/ViajantesTurismo.Catalog.Application/**.cs]
dotnet_diagnostic.CA2007.severity = none

[src/ViajantesTurismo.Admin.Infrastructure/**.cs]
dotnet_diagnostic.CA2007.severity = none

[src/ViajantesTurismo.Admin.ApiService/**.cs]
dotnet_diagnostic.CA2007.severity = none

[src/ViajantesTurismo.Catalog.ApiService/**.cs]
dotnet_diagnostic.CA2007.severity = none

[src/ViajantesTurismo.Management.Web/**.cs]
dotnet_diagnostic.CA2007.severity = none

[src/ViajantesTurismo.Public.Web/**.cs]
dotnet_diagnostic.CA2007.severity = none

[src/ViajantesTurismo.MigrationService/**.cs]
dotnet_diagnostic.CA2007.severity = none

[src/ViajantesTurismo.AppHost/**.cs]
dotnet_diagnostic.CA2007.severity = none

[samples/**.cs]
dotnet_diagnostic.CA2007.severity = none

# CA1716 flags established C# domain terms and package contracts that are expensive to rename
# across public API consumers. Owner: package/domain maintainers. Revisit on the next major API break.
[src/SharedKernel/SharedKernel.Idempotency/IIdempotencyStore.cs]
dotnet_diagnostic.CA1716.severity = none

[src/SharedKernel/SharedKernel.Mediator.Abstractions/IPipelineBehavior.cs]
dotnet_diagnostic.CA1716.severity = none

[src/SharedKernel/SharedKernel.Mediator.Abstractions/IStreamPipelineBehavior.cs]
dotnet_diagnostic.CA1716.severity = none

[src/SharedKernel/SharedKernel.Results/Option*.cs]
dotnet_diagnostic.CA1716.severity = none

[src/ViajantesTurismo.Admin.Domain/Shared/*.cs]
dotnet_diagnostic.CA1716.severity = none

[src/ViajantesTurismo.Management.Web/Components/Shared/*.cs]
dotnet_diagnostic.CA1716.severity = none

# Blazor component parameters are public and require public model types. Owner: Management.Web.
# Remove when these components no longer expose the models through public [Parameter] surfaces.
[src/ViajantesTurismo.Management.Web/Components/Shared/BookingFormModel.cs]
dotnet_diagnostic.CA1515.severity = none

[src/ViajantesTurismo.Management.Web/Models/PaymentFormModel.cs]
dotnet_diagnostic.CA1515.severity = none

[src/ViajantesTurismo.Management.Web/Services/CountryService.cs]
dotnet_diagnostic.CA1515.severity = none

[src/ViajantesTurismo.Management.Web/Services/CustomerImportHeaderMatcher.cs]
dotnet_diagnostic.CA1515.severity = none

[src/ViajantesTurismo.Management.Web/Components/Pages/Customers/ImportCustomersDuplicateResolutionItem.cs]
dotnet_diagnostic.CA1515.severity = none

# Test projects are not public API, and test names/namespaces intentionally use readable terms.
# Test helpers and test cases also intentionally favor readable builders/overloads.
[tests/**.cs]
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.CA5394.severity = none
dotnet_diagnostic.CA1515.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1716.severity = none
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.S107.severity = none
dotnet_diagnostic.SKSTYLE004.severity = suggestion

# Reqnroll discovers binding and generated test support types by reflection.
# Owner: behavior-test maintainers. Remove when unused binding types can be internalized safely.
[tests/ViajantesTurismo.Admin.BehaviorTests/**.cs]
dotnet_diagnostic.CA1812.severity = none

# Staged rollout for one-top-level-type-per-file. Owner: style analyzer maintainers.
# Keep this allowlist small and remove each entry when the grouped file is split intentionally.
[src/ViajantesTurismo.Admin.Contracts/ImportResultDto.cs]
dotnet_diagnostic.SKSTYLE004.severity = none

[src/ViajantesTurismo.Common/Results/Result.cs]
dotnet_diagnostic.SKSTYLE004.severity = none

[src/ViajantesTurismo.Management.Web/Services/CountryService.cs]
dotnet_diagnostic.SKSTYLE004.severity = none

[src/ViajantesTurismo.Management.Web/Services/CustomerImportHeaderMatcher.cs]
dotnet_diagnostic.SKSTYLE004.severity = none

[src/ViajantesTurismo.MigrationService/SeederWorker.cs]
dotnet_diagnostic.SKSTYLE004.severity = none

# SharedKernel style analyzer defaults
[*]
sharedkernel_style_allow_async_suffix_overrides = true
sharedkernel_style_allow_async_suffix_interface_implementations = true
