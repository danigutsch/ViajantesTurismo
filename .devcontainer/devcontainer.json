{
  "name": "ViajantesTurismo",
  "image": "mcr.microsoft.com/devcontainers/dotnet:dev-10.0-noble",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "nodeGypDependencies": true
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": true
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "dockerDashComposeVersion": "v2"
    }
  },

  "hostRequirements": {
    "cpus": 8,
    "memory": "32gb",
    "storage": "64gb"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.dotnet-aspire",
        "ms-azuretools.vscode-docker",
        "editorconfig.editorconfig"
      ],
      "settings": {
        "dotnet.defaultSolution": "ViajantesTurismo.slnx",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit",
          "source.fixAll": "explicit"
        },
        "files.exclude": {
          "**/bin": true,
          "**/obj": true
        },
        "search.exclude": {
          "**/node_modules": true,
          "**/bin": true,
          "**/obj": true,
          "**/TestResults": true
        }
      }
    }
  },

  "containerEnv": {
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "DOTNET_NOLOGO": "1",
    "ASPNETCORE_ENVIRONMENT": "Development",
    "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "1"
  },

  "onCreateCommand": "dotnet tool restore",

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "postStartCommand": [
    "dotnet dev-certs https --trust",
    "git config --global --add safe.directory ${containerWorkspaceFolder}"
  ],

  "mounts": [
    "source=viajantesTurismo-nuget-packages,target=/home/vscode/.nuget/packages,type=volume",
    "source=viajantesTurismo-aspnet,target=/home/vscode/.aspnet,type=volume"
  ],

  // Comment out to connect as root instead
  "remoteUser": "vscode"
}
