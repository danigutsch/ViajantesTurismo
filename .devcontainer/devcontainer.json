{
  "name": "ViajantesTurismo",
  "image": "mcr.microsoft.com/devcontainers/dotnet:dev-11.0-preview-resolute",

  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "os-provided",
      "installTools": false
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "os-provided",
      "ppa": false
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "29.6.0",
      "moby": false,
      "enableNonRootDocker": true,
      "dockerDashComposeVersion": "v2"
    }
  },

  "hostRequirements": {
    "cpus": 8,
    "memory": "32gb",
    "storage": "64gb"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.dotnet-aspire",
        "ms-azuretools.vscode-docker",
        "editorconfig.editorconfig",
        "timonwong.shellcheck",
        "ms-vscode.powershell",
        "alexkrechik.cucumberautocomplete",
        "davidanson.vscode-markdownlint"
      ],
      "settings": {
        "dotnet.defaultSolution": "ViajantesTurismo.slnx",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit",
          "source.fixAll": "explicit"
        },
        "files.exclude": {
          "**/bin": true,
          "**/obj": true
        },
        "search.exclude": {
          "**/bin": true,
          "**/obj": true,
          "**/TestResults": true
        }
      }
    }
  },

  "containerEnv": {
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "DOTNET_NOLOGO": "1",
    "ASPNETCORE_ENVIRONMENT": "Development",
    "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "1",
    "REMOTE_CONTAINERS": "true"
  },

  "onCreateCommand": "bash .devcontainer/on-create.sh ${containerWorkspaceFolder}",

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "postStartCommand": "bash .devcontainer/post-start.sh",

  "mounts": [
    "source=viajantesTurismo-nuget-packages,target=/home/vscode/.nuget/packages,type=volume",
    "source=viajantesTurismo-aspnet,target=/home/vscode/.aspnet,type=volume",
    "source=viajantesTurismo-build-output,target=${containerWorkspaceFolder}/.build,type=volume"
  ],

  "containerUser": "vscode",

  // Comment out to connect as root instead
  "remoteUser": "vscode"
}
