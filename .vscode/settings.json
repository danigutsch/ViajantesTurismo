{
  // Hide build artifacts and generated files from Explorer
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/TestResults": true,
    "**/*.feature.cs": true,
    "**/.vs": true,
    "**/node_modules": true
  },

  // Search exclusions for better performance
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/TestResults": true,
    "**/node_modules": true,
    "**/.git": true
  },

  // C# formatter - use EditorConfig settings
  "dotnet.preferCSharpExtension": true,
  "dotnet.defaultSolution": "ViajantesTurismo.slnx",
  "omnisharp.enableEditorConfigSupport": true,
  "omnisharp.enableRoslynAnalyzers": true,

  // File settings
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\r\n",

  // Markdown linting
  "markdownlint.config": {
    "extends": "${workspaceFolder}/.markdownlint.json"
  },

  // Code actions on save
  "editor.codeActionsOnSave": {
    "source.fixAll.markdownlint": "explicit",
    "source.organizeImports": "explicit"
  },

  // Task-specific Copilot instructions to keep commit and PR authoring out of always-on context
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Use Conventional Commits in the form `<type>[optional scope]: <description>`. Allowed types: build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test. Keep the header at or under 100 characters. Prefer a header-only message unless extra context materially helps. If a body is included, insert a blank line after the header, wrap every body line to 100 characters or less including bullet items, and use hanging indentation for wrapped bullets."
    }
  ],
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    {
      "text": "Follow `docs/pull_request_template.md` when drafting pull request descriptions. Use the sections `Summary`, `Changes`, `Validation`, and `Checklist`. Preserve the checklist items, record which validation steps actually ran, and mark items that were not run with a brief reason."
    }
  ],

  "sonarlint.connectedMode.project": {
    "connectionId": "danigutsch",
    "projectKey": "danigutsch_ViajantesTurismo"
  }
}
