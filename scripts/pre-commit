#!/bin/sh
# Pre-commit hook to lint and auto-fix markdown, bash, PowerShell, and .NET code

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
LOCAL_NODE_BIN="${REPO_ROOT}/node_modules/.bin"
PATH="${LOCAL_NODE_BIN}:${PATH}"

require_tool() {
    if command -v "$1" > /dev/null 2>&1; then
        return 0
    fi

    printf "%b" "${RED}✗ Required tool '$1' was not found.${NC}\n" >&2
    printf "%b" "${YELLOW}Run 'npm install' in ${REPO_ROOT} and try the commit again.${NC}\n" >&2
    exit 1
}

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Markdown linting and auto-fix
echo "Checking markdown files..."
CHANGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)

if test -n "${CHANGED_MD_FILES}"; then
    require_tool markdownlint
    printf "%b" "${YELLOW}Auto-fixing markdown files...${NC}\n"
    for file in ${CHANGED_MD_FILES}; do
        markdownlint "${file}" --config .markdownlint.json --fix
        git add "${file}"
    done
    printf "%b" "${GREEN}✓ Markdown files auto-fixed and re-staged${NC}\n"
fi

# Gherkin/Feature file linting
echo "Checking feature files..."
CHANGED_FEATURE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.feature$' || true)

if test -n "${CHANGED_FEATURE_FILES}"; then
    require_tool gherkin-lint
    printf "%b" "${YELLOW}Linting Gherkin feature files...${NC}\n"
    for file in ${CHANGED_FEATURE_FILES}; do
        if ! gherkin-lint "${file}"; then
            printf "%b" "${RED}✗ Gherkin lint errors in ${file}${NC}\n"
            printf "%b" "${YELLOW}Fix errors manually and re-stage the file${NC}\n"
            exit 1
        fi
    done
    printf "%b" "${GREEN}✓ Feature files checked${NC}\n"
fi

# JSON file linting and auto-fix
echo "Checking JSON files..."
CHANGED_JSON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.json$' || true)

if test -n "${CHANGED_JSON_FILES}"; then
    require_tool eslint
    printf "%b" "${YELLOW}Auto-fixing JSON files...${NC}\n"
    for file in ${CHANGED_JSON_FILES}; do
        eslint "${file}" --fix
        git add "${file}"
    done
    printf "%b" "${GREEN}✓ JSON files auto-fixed and re-staged${NC}\n"
fi

# Bash/Shell script linting and auto-fix
echo "Checking shell scripts..."
CHANGED_SH_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(sh|bash)$|scripts/(pre-commit|post-commit|prepare-commit-msg)$' || true)

if test -n "${CHANGED_SH_FILES}"; then
    require_tool shellcheck
    printf "%b" "${YELLOW}Linting and formatting shell scripts...${NC}\n"

    # ShellCheck for linting (with .shellcheckrc config)
    for file in ${CHANGED_SH_FILES}; do
        if ! shellcheck "${file}"; then
            printf "%b" "${RED}✗ ShellCheck errors in ${file}${NC}\n"
            exit 1
        fi
    done

    # shfmt for formatting (optional - requires Go installation)
    if command -v shfmt > /dev/null 2>&1; then
        for file in ${CHANGED_SH_FILES}; do
            shfmt -w -i 4 -ci -bn -sr "${file}" && git add "${file}"
        done
        printf "%b" "${GREEN}✓ Shell scripts formatted and re-staged${NC}\n"
    else
        printf "%b" "${YELLOW}⚠️ shfmt not found - skipping auto-format${NC}\n"
        printf "%b" "${GREEN}✓ Shell scripts checked${NC}\n"
    fi
fi

# PowerShell script linting
echo "Checking PowerShell scripts..."
CHANGED_PS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ps1|psm1|psd1)$' || true)

if test -n "${CHANGED_PS_FILES}"; then
    if command -v pwsh > /dev/null 2>&1; then
        printf "%b" "${YELLOW}Linting PowerShell scripts...${NC}\n"
        for file in ${CHANGED_PS_FILES}; do
            if ! pwsh -NoProfile -Command "Invoke-ScriptAnalyzer -Path '${file}' -Settings PSGallery" 2> /dev/null; then
                printf "%b" "${YELLOW}⚠️  PSScriptAnalyzer warnings in ${file} (non-blocking)${NC}\n"
            fi
        done
        printf "%b" "${GREEN}✓ PowerShell scripts checked${NC}\n"
    else
        printf "%b" "${YELLOW}⚠️ PowerShell not available, skipping analysis${NC}\n"
    fi
fi

# .NET code formatting with auto-fix
echo "Checking .NET code formatting..."
CHANGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.cs$' || true)

if test -n "${CHANGED_CS_FILES}"; then
    printf "%b" "${YELLOW}Auto-fixing .NET code formatting...${NC}\n"

    if dotnet format whitespace --verbosity quiet; then
        for file in ${CHANGED_CS_FILES}; do
            git add "${file}"
        done
        printf "%b" "${GREEN}✓ .NET code formatted and re-staged${NC}\n"
    else
        printf "%b" "${RED}✗ .NET formatting failed${NC}\n"
        exit 1
    fi
fi

printf "%b" "${GREEN}✓ Pre-commit checks complete${NC}\n"
exit 0
