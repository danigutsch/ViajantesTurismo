#!/bin/sh
# Pre-commit hook to lint markdown files

changed_md_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [ -n "$changed_md_files" ]; then
    echo "Linting markdown files..."
    
    if ! npx markdownlint-cli $changed_md_files --config .markdownlint.json; then
        echo "Markdown linting failed. Fix the errors above or use 'git commit --no-verify' to bypass."
        exit 1
    fi
    
    echo "Markdown linting passed!"
fi

exit 0