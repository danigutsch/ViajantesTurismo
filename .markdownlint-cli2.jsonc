{
  "config": {
    "extends": ".markdownlint.json"
  },
  "ignores": [
    "**/AnalyzerReleases.*.md",
    "**/BenchmarkDotNet.Artifacts/**/*.md",
    "tmp/**/*.md",
    "node_modules/**",
    "**/bin/**",
    "**/obj/**",
    "**/TestResults/**",
    "logs/**",
    "**/logs/**",
    ".tmp/**",
    ".idea/**",
    ".vs/**",
    "**/playwright/**",
    "**/.local/**"
  ]
}
