{
  "name": "viajantesturismo",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --config .markdownlint.json",
    "lint:md:fix": "markdownlint \"**/*.md\" --ignore node_modules --config .markdownlint.json --fix",
    "lint:sh": "shellcheck **/*.sh",
    "format:sh": "shfmt -w -i 2 **/*.sh",
    "lint:json": "eslint **/*.json",
    "lint:json:fix": "eslint **/*.json --fix",
    "lint:gherkin": "gherkin-lint tests/**/*.feature",
    "lint:gherkin:fix": "gherkin-lint tests/**/*.feature",
    "lint:all": "npm run lint:md && npm run lint:sh && npm run lint:json && npm run lint:gherkin",
    "lint:all:fix": "npm run lint:md:fix && npm run format:sh && npm run lint:json:fix",
    "tools:restore": "npm install ; dotnet tool restore"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "eslint": "^9.39.1",
    "eslint-plugin-jsonc": "^2.21.0",
    "gherkin-lint": "^4.2.4",
    "jsonc-eslint-parser": "^2.4.1",
    "markdownlint-cli": "^0.45.0",
    "shellcheck": "^4.1.0",
    "shfmt": "^0.0.1"
  }
}
