@page "/catalog/tours/{id:guid}/presentation"
@using System.ComponentModel.DataAnnotations
@using ViajantesTurismo.Catalog.Contracts
@using ViajantesTurismo.Management.Web.Exceptions
@using ViajantesTurismo.Management.Web.Helpers
@inject ICatalogToursApiClient CatalogToursApi
@rendermode InteractiveServer

<PageTitle>Edit Catalog Tour Presentation</PageTitle>

<h1>Edit Catalog Tour Presentation</h1>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else if (_notFound)
{
    <div class="alert alert-danger" role="alert">Catalog tour not found.</div>
    <NavLink href="/catalog/tours" class="btn btn-secondary">Back to Catalog Tours</NavLink>
}
else
{
    @if (_success)
    {
        <div class="alert alert-success" role="alert">Catalog presentation updated.</div>
    }

    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    }

    <EditForm Model="@_model" OnValidSubmit="@HandleSubmit" FormName="editCatalogPresentation">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="title" class="form-label">Public title</label>
            <InputText id="title" class="form-control" @bind-Value="_model.Title" />
        </div>

        <div class="mb-3">
            <label for="slug" class="form-label">Public slug</label>
            <InputText id="slug" class="form-control" @bind-Value="_model.Slug" />
        </div>

        <div class="form-check mb-3">
            <InputCheckbox id="isPublished" class="form-check-input" @bind-Value="_model.IsPublished" />
            <label for="isPublished" class="form-check-label">Published</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary" disabled="@_saving">
                @(_saving ? "Saving..." : "Save presentation")
            </button>
            <NavLink href="/catalog/tours" class="btn btn-secondary">Cancel</NavLink>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private CatalogTourPresentationFormModel _model = new();
    private bool _loading = true;
    private bool _saving;
    private bool _notFound;
    private bool _success;
    private string? _errorMessage;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        _errorMessage = null;

        try
        {
            var tour = await CatalogToursApi.GetTour(Id, CancellationToken.None);
            if (tour is null)
            {
                _notFound = true;
                return;
            }

            _model = new CatalogTourPresentationFormModel
            {
                Title = tour.Title,
                Slug = tour.Slug,
                IsPublished = tour.IsPublished
            };
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Catalog tour presentation could not be loaded. Try again later.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSubmit()
    {
        _saving = true;
        _success = false;
        _errorMessage = null;

        try
        {
            var updated = await CatalogToursApi.UpdatePresentation(
                Id,
                new UpsertCatalogTourPresentationRequest
                {
                    Title = _model.Title,
                    Slug = _model.Slug,
                    IsPublished = _model.IsPublished
                },
                CancellationToken.None);

            if (updated is null)
            {
                _notFound = true;
                return;
            }

            _model.Title = updated.Title;
            _model.Slug = updated.Slug;
            _model.IsPublished = updated.IsPublished;
            _success = true;
        }
        catch (ApiValidationException exception)
        {
            _errorMessage = exception.Message;
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Catalog tour presentation could not be saved. Try again later.";
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class CatalogTourPresentationFormModel
    {
        [Required, StringLength(ContractConstants.MaxNameLength, MinimumLength = 1)]
        public string Title { get; set; } = string.Empty;

        [Required, StringLength(ContractConstants.MaxSlugLength, MinimumLength = 1)]
        public string Slug { get; set; } = string.Empty;

        public bool IsPublished { get; set; }
    }
}
