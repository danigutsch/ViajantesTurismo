@using ViajantesTurismo.Admin.Contracts

<div class="card border-danger mt-4">
    <div class="card-header bg-danger text-white">
        <h5 class="card-title mb-0">Manage Booking Actions</h5>
    </div>
    <div class="card-body">
        @if (Status is BookingStatusDto.Completed or BookingStatusDto.Cancelled)
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i> This booking is
                <strong>@Status.ToString().ToLowerInvariant()</strong> and cannot be modified.
            </div>
        }
        <div class="d-flex flex-wrap gap-2">
            @if (Status == BookingStatusDto.Pending)
            {
                <button type="button" class="btn btn-success" @onclick="OnConfirm" disabled="@IsSubmitting">
                    <i class="bi bi-check-circle"></i> Confirm Booking
                </button>
            }
            else if (Status == BookingStatusDto.Confirmed)
            {
                <button type="button" class="btn btn-info" @onclick="OnComplete" disabled="@IsSubmitting">
                    <i class="bi bi-check2-all"></i> Complete Booking
                </button>
            }

            @if (Status != BookingStatusDto.Completed && Status != BookingStatusDto.Cancelled)
            {
                <button type="button" class="btn btn-warning" @onclick="OnCancel" disabled="@IsSubmitting">
                    <i class="bi bi-x-circle"></i> Cancel Booking
                </button>
            }

            <button type="button" class="btn btn-danger" @onclick="OnDelete" disabled="@IsSubmitting">
                <i class="bi bi-trash"></i> Delete Booking
            </button>
        </div>
        <div class="form-text mt-2">These actions will take effect immediately.</div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public BookingStatusDto Status { get; set; }

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter, EditorRequired]
    public EventCallback Confirm { get; set; }

    [Parameter, EditorRequired]
    public EventCallback Complete { get; set; }

    [Parameter, EditorRequired]
    public EventCallback Cancel { get; set; }

    [Parameter, EditorRequired]
    public EventCallback Delete { get; set; }

    private Task OnConfirm() => Confirm.InvokeAsync();

    private Task OnComplete() => Complete.InvokeAsync();

    private Task OnCancel() => Cancel.InvokeAsync();

    private Task OnDelete() => Delete.InvokeAsync();
}
