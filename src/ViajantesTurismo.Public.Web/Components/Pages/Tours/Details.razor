@page "/group-bike-tours/{Slug}"
@inject IPublicCatalogApiClient CatalogApi

@if (_loadFailed)
{
    <PageTitle>Tour unavailable - Viajantes Turismo</PageTitle>
    <h1>Tour unavailable</h1>
    <p>This tour could not be loaded right now. Try again later.</p>
}
else if (_tour is null)
{
    <PageTitle>Tour not found - Viajantes Turismo</PageTitle>
    <h1>Tour not found</h1>
    <p>The requested tour is not published.</p>
}
else
{
    <PageTitle>@_tour.Title - Viajantes Turismo</PageTitle>

    <article>
        <a href="/group-bike-tours">All tours</a>
        <h1>@_tour.Title</h1>
        <p>@_tour.Identifier</p>

        @if (_tour.Images.Count > 0)
        {
            <section aria-labelledby="tour-gallery">
                <h2 id="tour-gallery">Gallery</h2>
                <div class="tour-gallery">
                    <TourGallery Images="_tour.Images" />
                </div>
            </section>
        }
    </article>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private CatalogTourDto? _tour;
    private bool _loadFailed;

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _tour = await CatalogApi.GetPublishedTourBySlug(Slug, CancellationToken.None);
        }
        catch (HttpRequestException)
        {
            _loadFailed = true;
        }
    }
}
