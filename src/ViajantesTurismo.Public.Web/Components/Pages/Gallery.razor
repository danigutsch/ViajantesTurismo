@page "/gallery"
@inject IPublicCatalogApiClient CatalogApi

<PageTitle>Gallery - Viajantes Turismo</PageTitle>

<h1>Gallery</h1>
<p>Moments from Viajantes Turismo cycle tours.</p>

@if (_loadFailed)
{
    <p>The gallery could not be loaded right now. Try again later.</p>
}
else if (_tours is null)
{
    <p><em>Loading gallery...</em></p>
}
else if (!_tours.Any(tour => tour.Images.Count > 0))
{
    <p>New photos will be published soon.</p>
}
else
{
    @foreach (var tour in _tours.Where(tour => tour.Images.Count > 0))
    {
        <section aria-labelledby="@GalleryHeadingId(tour)">
            <h2 id="@GalleryHeadingId(tour)">@tour.Title</h2>
            <div class="tour-gallery">
                <TourGallery Images="tour.Images" />
            </div>
        </section>
    }
}

@code {
    private CatalogTourDto[]? _tours;
    private bool _loadFailed;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tours = await CatalogApi.GetPublishedTours(CancellationToken.None);
        }
        catch (HttpRequestException)
        {
            _loadFailed = true;
            _tours = [];
        }
    }

    private static string GalleryHeadingId(CatalogTourDto tour) => $"gallery-{tour.Id:N}";
}
