@if (CoverImage is not null)
{
    <picture>
        @if (CoverImage.ResponsiveVariants.Count > 0)
        {
            <source srcset="@SrcSet(CoverImage)" sizes="(min-width: 48rem) 33vw, 100vw" />
        }
        <img src="@CoverImage.Uri" alt="@CoverImage.AltText" loading="lazy" />
    </picture>
}

@if (HeadingLevel == 3)
{
    <h3><a href="@TourUrl(Tour)">@Tour.Title</a></h3>
}
else
{
    <h2><a href="@TourUrl(Tour)">@Tour.Title</a></h2>
}

<p>@Tour.Identifier</p>
<a href="@TourUrl(Tour)">Learn more</a>

@code {
    [Parameter, EditorRequired]
    public required CatalogTourDto Tour { get; set; }

    [Parameter]
    public int HeadingLevel { get; set; } = 2;

    private CatalogTourImageDto? CoverImage => Tour.Images
        .OrderByDescending(image => image.IsCover)
        .ThenBy(image => image.SortOrder)
        .FirstOrDefault();

    private static string TourUrl(CatalogTourDto tour) => $"/group-bike-tours/{Uri.EscapeDataString(tour.Slug)}";

    private static string SrcSet(CatalogTourImageDto image)
    {
        return string.Join(", ", image.ResponsiveVariants
            .OrderBy(variant => variant.Width)
            .Select(variant => $"{variant.Uri} {variant.Width}w"));
    }
}
