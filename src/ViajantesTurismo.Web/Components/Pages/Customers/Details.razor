@page "/customers/{id:int}"
@using ViajantesTurismo.AdminApi.Contracts
@attribute [StreamRendering]

@inject CustomersApiClient CustomersApi

<PageTitle>Customer Details</PageTitle>

@if (_customer == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="bi bi-person-circle"></i> Customer Details</h1>
            <div class="btn-group" role="group">
                <NavLink href="/customers" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Customers
                </NavLink>
                <NavLink href="/customers/@Id/edit" class="btn btn-primary">
                    <i class="bi bi-pencil"></i> Edit Customer
                </NavLink>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-person"></i> Personal Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Full Name</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.FirstName @_customer.PersonalInfo.LastName</dd>

                            <dt class="col-sm-4">Date of Birth</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.BirthDate?.ToString("dd/MM/yyyy")</dd>

                            <dt class="col-sm-4">Gender</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.Gender</dd>

                            <dt class="col-sm-4">Nationality</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.Nationality</dd>

                            <dt class="col-sm-4">Profession</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.Profession</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-telephone"></i> Contact Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8"><a
                                        href="mailto:@_customer.ContactInfo.Email">@_customer.ContactInfo.Email</a></dd>

                            <dt class="col-sm-4">Mobile</dt>
                            <dd class="col-sm-8"><a
                                        href="tel:@_customer.ContactInfo.Mobile">@_customer.ContactInfo.Mobile</a></dd>

                            @if (!string.IsNullOrEmpty(_customer.ContactInfo.Instagram))
                            {
                                <dt class="col-sm-4">Instagram</dt>
                                <dd class="col-sm-8"><a href="https://instagram.com/@_customer.ContactInfo.Instagram"
                                                        target="_blank">@_customer.ContactInfo.Instagram</a></dd>
                            }

                            @if (!string.IsNullOrEmpty(_customer.ContactInfo.Facebook))
                            {
                                <dt class="col-sm-4">Facebook</dt>
                                <dd class="col-sm-8"><a href="https://facebook.com/@_customer.ContactInfo.Facebook"
                                                        target="_blank">@_customer.ContactInfo.Facebook</a></dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-card-text"></i> Identification</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">National ID</dt>
                            <dd class="col-sm-8">@_customer.IdentificationInfo.NationalId</dd>

                            <dt class="col-sm-4">ID Nationality</dt>
                            <dd class="col-sm-8">@_customer.IdentificationInfo.IdNationality</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-house"></i> Address</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Street</dt>
                            <dd class="col-sm-8">@_customer.Address.Street</dd>

                            @if (!string.IsNullOrEmpty(_customer.Address.Complement))
                            {
                                <dt class="col-sm-4">Complement</dt>
                                <dd class="col-sm-8">@_customer.Address.Complement</dd>
                            }

                            <dt class="col-sm-4">Neighborhood</dt>
                            <dd class="col-sm-8">@_customer.Address.Neighborhood</dd>

                            <dt class="col-sm-4">Postal Code</dt>
                            <dd class="col-sm-8">@_customer.Address.PostalCode</dd>

                            <dt class="col-sm-4">City</dt>
                            <dd class="col-sm-8">@_customer.Address.City</dd>

                            <dt class="col-sm-4">State</dt>
                            <dd class="col-sm-8">@_customer.Address.State</dd>

                            <dt class="col-sm-4">Country</dt>
                            <dd class="col-sm-8">@_customer.Address.Country</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-activity"></i> Physical Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Weight</dt>
                            <dd class="col-sm-8">@_customer.PhysicalInfo.WeightKg kg</dd>

                            <dt class="col-sm-4">Height</dt>
                            <dd class="col-sm-8">@_customer.PhysicalInfo.HeightCentimeters cm</dd>

                            <dt class="col-sm-4">Bike Type</dt>
                            <dd class="col-sm-8">@_customer.PhysicalInfo.BikeType</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-building"></i> Accommodation Preferences</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Room Type</dt>
                            <dd class="col-sm-8">@_customer.AccommodationPreferences.RoomType</dd>

                            <dt class="col-sm-4">Bed Type</dt>
                            <dd class="col-sm-8">@_customer.AccommodationPreferences.BedType</dd>

                            @if (_customer.AccommodationPreferences.CompanionId.HasValue)
                            {
                                <dt class="col-sm-4">Companion ID</dt>
                                <dd class="col-sm-8">@_customer.AccommodationPreferences.CompanionId</dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-exclamation-triangle"></i> Emergency Contact</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Name</dt>
                            <dd class="col-sm-8">@_customer.EmergencyContact.Name</dd>

                            <dt class="col-sm-4">Mobile</dt>
                            <dd class="col-sm-8"><a
                                        href="tel:@_customer.EmergencyContact.Mobile">@_customer.EmergencyContact.Mobile</a>
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-heart-pulse"></i> Medical Information</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(_customer.MedicalInfo.Allergies))
                        {
                            <dl class="row">
                                <dt class="col-sm-4">Allergies</dt>
                                <dd class="col-sm-8">@_customer.MedicalInfo.Allergies</dd>
                            </dl>
                        }

                        @if (!string.IsNullOrEmpty(_customer.MedicalInfo.AdditionalInfo))
                        {
                            <dl class="row">
                                <dt class="col-sm-4">Additional Info</dt>
                                <dd class="col-sm-8">@_customer.MedicalInfo.AdditionalInfo</dd>
                            </dl>
                        }

                        @if (string.IsNullOrEmpty(_customer.MedicalInfo.Allergies) && string.IsNullOrEmpty(_customer.MedicalInfo.AdditionalInfo))
                        {
                            <p class="text-muted mb-0">No medical information provided.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {

    [Parameter]
    public int Id { get; set; }

    private CustomerDetailsDto? _customer;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        _customer = await CustomersApi.GetCustomerById(Id);
    }

}
