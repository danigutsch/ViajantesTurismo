@page "/customers/create/physical"
@using ViajantesTurismo.AdminApi.Contracts
@using ViajantesTurismo.Web.Components.Shared
@using ViajantesTurismo.Web.Models
@rendermode InteractiveServer

@inject CustomerCreationState State
@inject NavigationManager Navigation

<PageTitle>Create Customer - Physical Information</PageTitle>

<div class="container mt-4">
    <h2>Create New Customer</h2>
    <WizardProgress/>

    <div class="card">
        <div class="card-header">
            <h4>Step 5 of 8: Physical Information</h4>
        </div>
        <div class="card-body">
            <EditForm Model="@_model" OnValidSubmit="@HandleValidSubmit">
                <DataAnnotationsValidator/>
                <ValidationSummary class="alert alert-danger"/>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label for="weightKg" class="form-label">Weight (kg) <span class="text-danger">*</span></label>
                        <InputNumber id="weightKg" @bind-Value="_model.WeightKg" class="form-control" step="0.1"/>
                        <ValidationMessage For="@(() => _model.WeightKg)"/>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label for="heightCm" class="form-label">Height (cm) <span class="text-danger">*</span></label>
                        <InputNumber id="heightCm" @bind-Value="_model.HeightCentimeters" class="form-control"/>
                        <ValidationMessage For="@(() => _model.HeightCentimeters)"/>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label for="bikeType" class="form-label">Bike Type <span class="text-danger">*</span></label>
                        <InputSelect id="bikeType" @bind-Value="_model.BikeType" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="@BikeTypeDto.None">None</option>
                            <option value="@BikeTypeDto.Regular">Regular</option>
                            <option value="@BikeTypeDto.EBike">E-Bike</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => _model.BikeType)"/>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Back
                    </button>
                    <button type="submit" class="btn btn-primary">
                        Next <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private PhysicalInfoFormModel _model = new();

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (State.PhysicalInfo is not null)
        {
            _model = State.PhysicalInfo;
        }

        State.NavigateToStep(5);
    }

    private void HandleValidSubmit()
    {
        State.SetPhysicalInfo(_model);
        Navigation.NavigateTo("/customers/create/accommodation");
    }

    private void GoBack()
    {
        State.NavigateToStep(4);
        Navigation.NavigateTo("/customers/create/address");
    }

}
