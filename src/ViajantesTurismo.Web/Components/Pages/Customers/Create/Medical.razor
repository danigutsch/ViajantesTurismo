@page "/customers/create/medical"
@using ViajantesTurismo.Web.Models
@rendermode InteractiveServer

@inject CustomerCreationState State
@inject NavigationManager Navigation

<PageTitle>Create Customer - Medical Information</PageTitle>

<div class="container mt-4">
    <h2>Create New Customer</h2>
    <WizardProgress/>

    <div class="card">
        <div class="card-header">
            <h4>Step 8 of 8: Medical Information</h4>
        </div>
        <div class="card-body">
            <EditForm Model="@_model" OnValidSubmit="@HandleValidSubmit">
                <DataAnnotationsValidator/>
                <ValidationSummary class="alert alert-danger"/>

                <div class="mb-3">
                    <label for="allergies" class="form-label">Allergies</label>
                    <InputTextArea id="allergies" @bind-Value="_model.Allergies" class="form-control" rows="3"
                                   placeholder="List any known allergies (food, medication, environmental)..."/>
                    <ValidationMessage For="@(() => _model.Allergies)"/>
                </div>

                <div class="mb-3">
                    <label for="additionalInfo" class="form-label">Additional Medical Information</label>
                    <InputTextArea id="additionalInfo" @bind-Value="_model.AdditionalInfo" class="form-control" rows="4"
                                   placeholder="Any relevant medical conditions, medications, mobility limitations, etc..."/>
                    <ValidationMessage For="@(() => _model.AdditionalInfo)"/>
                </div>

                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i> This information is crucial for your safety during the
                    tour. Please be as detailed as possible.
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Back
                    </button>
                    <button type="submit" class="btn btn-success">
                        Review & Submit <i class="bi bi-check-circle"></i>
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private MedicalInfoFormModel _model = new();

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (State.MedicalInfo is not null)
        {
            _model = State.MedicalInfo;
        }

        State.NavigateToStep(8);
    }

    private void HandleValidSubmit()
    {
        State.SetMedicalInfo(_model);
        Navigation.NavigateTo("/customers/create/review");
    }

    private void GoBack()
    {
        State.NavigateToStep(7);
        Navigation.NavigateTo("/customers/create/emergency-contact");
    }

}
