@page "/customers"
@using ViajantesTurismo.AdminApi.Contracts
@attribute [StreamRendering]

@inject CustomersApiClient CustomersApi
@inject NavigationManager NavigationManager

<PageTitle>Customers</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-people-fill"></i> Customers</h1>
    <button @onclick="@(() => NavigationManager.NavigateTo("/customers/create"))" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create New Customer
    </button>
</div>

<p>Manage customer information and profiles.</p>

@if (_customers == null)
{
    <p><em>Loading...</em></p>
}
else if (_customers.Length == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No customers found.
        <button @onclick="@(() => NavigationManager.NavigateTo("/customers/create"))" class="btn btn-link">Create your
            first customer
        </button>
        .
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Mobile</th>
                <th>Nationality</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var customer in _customers)
            {
                <tr>
                    <td>@customer.Id</td>
                    <td>@customer.FirstName @customer.LastName</td>
                    <td>@customer.Email</td>
                    <td>@customer.Mobile</td>
                    <td>@customer.Nationality</td>
                    <td>
                        <div class="btn-group" role="group">
                            <button @onclick="@(() => NavigationManager.NavigateTo($"/customers/{customer.Id}"))"
                                    class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i> View
                            </button>
                            <button @onclick="@(() => NavigationManager.NavigateTo($"/customers/{customer.Id}/edit"))"
                                    class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <p class="text-muted">Total customers: @_customers.Length</p>
    </div>
}

@code {
    private GetCustomerDto[]? _customers;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomersApi.GetCustomers();
    }

}
