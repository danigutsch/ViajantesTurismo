@using ViajantesTurismo.AdminApi.Contracts
@if (Bookings == null || !Bookings.Any())
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i> No bookings found.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
            <tr>
                <th>Booking Date</th>
                @if (ShowTourInfo)
                {
                    <th>Tour</th>
                }
                @if (ShowCustomerInfo)
                {
                    <th>Customer</th>
                }
                <th>Companion</th>
                <th>Total Price</th>
                <th>Status</th>
                <th>Payment</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var booking in Bookings)
            {
                <tr>
                    <td>@booking.BookingDate.ToString("dd/MM/yyyy HH:mm")</td>
                    @if (ShowTourInfo)
                    {
                        <td>
                            <a href="/tours/@booking.TourId">@booking.TourName</a>
                            <br/>
                            <small class="text-muted">@booking.TourIdentifier</small>
                        </td>
                    }
                    @if (ShowCustomerInfo)
                    {
                        <td>
                            <a href="/customers/@booking.CustomerId">@booking.CustomerName</a>
                        </td>
                    }
                    <td>
                        @if (booking.CompanionId.HasValue)
                        {
                            <a href="/customers/@booking.CompanionId">@booking.CompanionName</a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>@booking.TotalPrice.ToString("C")</td>
                    <td>
                        <BookingStatusBadge Status="@booking.Status"/>
                    </td>
                    <td>
                        <PaymentStatusBadge Status="@booking.PaymentStatus"/>
                    </td>
                    <td>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-outline-secondary"
                                    @onclick="() => OnEditClicked(booking.Id)" title="Edit Booking">
                                <i class="bi bi-pencil"></i>
                            </button>
                            @if (booking.Status == BookingStatusDto.Pending)
                            {
                                <button type="button" class="btn btn-outline-success"
                                        @onclick="() => OnConfirmClicked(booking.Id)" title="Confirm Booking">
                                    <i class="bi bi-check-circle"></i> Confirm
                                </button>
                                <button type="button" class="btn btn-outline-warning"
                                        @onclick="() => OnCancelClicked(booking.Id)" title="Cancel Booking">
                                    <i class="bi bi-x-circle"></i> Cancel
                                </button>
                            }
                            else if (booking.Status == BookingStatusDto.Confirmed)
                            {
                                <button type="button" class="btn btn-outline-primary"
                                        @onclick="() => OnCompleteClicked(booking.Id)" title="Complete Booking">
                                    <i class="bi bi-check2-all"></i> Complete
                                </button>
                                <button type="button" class="btn btn-outline-warning"
                                        @onclick="() => OnCancelClicked(booking.Id)" title="Cancel Booking">
                                    <i class="bi bi-x-circle"></i> Cancel
                                </button>
                            }
                            <button type="button" class="btn btn-outline-danger"
                                    @onclick="() => OnDeleteClicked(booking.Id)" title="Delete Booking">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@code {

    [Parameter]
    public IEnumerable<GetBookingDto>? Bookings { get; set; }

    [Parameter]
    public bool ShowTourInfo { get; set; } = true;

    [Parameter]
    public bool ShowCustomerInfo { get; set; } = true;

    [Parameter]
    public EventCallback<long> OnEdit { get; set; }

    [Parameter]
    public EventCallback<long> OnConfirm { get; set; }

    [Parameter]
    public EventCallback<long> OnCancel { get; set; }

    [Parameter]
    public EventCallback<long> OnComplete { get; set; }

    [Parameter]
    public EventCallback<long> OnDelete { get; set; }

    private async Task OnEditClicked(long bookingId)
    {
        await OnEdit.InvokeAsync(bookingId);
    }

    private async Task OnConfirmClicked(long bookingId)
    {
        await OnConfirm.InvokeAsync(bookingId);
    }

    private async Task OnCancelClicked(long bookingId)
    {
        await OnCancel.InvokeAsync(bookingId);
    }

    private async Task OnCompleteClicked(long bookingId)
    {
        await OnComplete.InvokeAsync(bookingId);
    }

    private async Task OnDeleteClicked(long bookingId)
    {
        await OnDelete.InvokeAsync(bookingId);
    }

}
