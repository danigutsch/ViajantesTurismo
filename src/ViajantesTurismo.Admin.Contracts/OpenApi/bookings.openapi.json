            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "discountReason": {
            "maxLength": 500,
            "minLength": 10,
            "type": [
              "null",
              "string"
            ]
          },
          "notes": {
            "maxLength": 2000,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreatePaymentDto": {
