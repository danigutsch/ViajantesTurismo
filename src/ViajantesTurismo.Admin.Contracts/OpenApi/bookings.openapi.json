          "principalBikeType"
        ],
        "type": "object",
        "properties": {
          "roomType": {
            "$ref": "#/components/schemas/RoomTypeDto"
          },
          "principalBikeType": {
            "$ref": "#/components/schemas/BikeTypeDto"
          },
          "companionCustomerId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "companionBikeType": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/BikeTypeDto"
              }
            ]
          }
        }
      },
      "UpdateBookingDiscountDto": {
        "type": "object",
        "properties": {
