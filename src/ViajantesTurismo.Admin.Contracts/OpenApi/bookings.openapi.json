              "string"
            ],
            "format": "double"
          },
          "discountReason": {
            "maxLength": 500,
            "minLength": 10,
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "UpdateBookingNotesDto": {
        "type": "object",
        "properties": {
          "notes": {
            "maxLength": 2000,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
