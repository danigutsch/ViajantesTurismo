<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <PackageId>SharedKernel.Style.CodeFixes</PackageId>
        <Description>Code fixes for repository style conventions.</Description>
        <RootNamespace>SharedKernel.Style.CodeFixes</RootNamespace>
        <IsRoslynComponent>true</IsRoslynComponent>
        <IncludeBuildOutput>false</IncludeBuildOutput>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <Compile Include="..\SharedKernel.Style.Analyzers\StyleDiagnosticIds.cs" Link="StyleDiagnosticIds.cs" />
    </ItemGroup>

    <ItemGroup>
        <AdditionalFiles Include="..\SharedKernel.Style.Analyzers\AnalyzerReleases.Unshipped.md" Link="AnalyzerReleases.Unshipped.md" />
        <None Include="_._" Pack="true" PackagePath="lib/netstandard2.0/" Visible="false" />
        <None Include="$(OutputPath)$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    </ItemGroup>

</Project>
