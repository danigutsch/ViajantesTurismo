<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>SharedKernel.Results</PackageId>
        <Description>Core result primitives for shared-kernel workflows.</Description>
        <RootNamespace>SharedKernel.Results</RootNamespace>
        <IsAotCompatible>true</IsAotCompatible>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <RepositoryUrl>https://github.com/danigutsch/ViajantesTurismo</RepositoryUrl>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <PackageTags>results;shared-kernel;functional;dotnet</PackageTags>
        <ResultsSourceGeneratorPackageFile Condition="'$(REMOTE_CONTAINERS)' != 'true'">..\SharedKernel.Results.SourceGenerator\bin\$(Configuration)\netstandard2.0\SharedKernel.Results.SourceGenerator.dll</ResultsSourceGeneratorPackageFile>
        <ResultsSourceGeneratorPackageFile Condition="'$(REMOTE_CONTAINERS)' == 'true'">$(MSBuildThisFileDirectory)..\..\..\.build\bin\SharedKernel.Results.SourceGenerator\$(Configuration)\netstandard2.0\SharedKernel.Results.SourceGenerator.dll</ResultsSourceGeneratorPackageFile>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\SharedKernel.Results.SourceGenerator\SharedKernel.Results.SourceGenerator.csproj"
            OutputItemType="Analyzer"
            ReferenceOutputAssembly="false"
            PrivateAssets="all"
            IsAspireProjectResource="false" />
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
        <None Include="$(ResultsSourceGeneratorPackageFile)"
            Pack="true"
            PackagePath="analyzers/dotnet/cs"
            Visible="false" />
    </ItemGroup>

</Project>
