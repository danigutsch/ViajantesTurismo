<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>SharedKernel.EventSourcing.PostgreSQL</PackageId>
    <Description>PostgreSQL provider for SharedKernel event-sourcing primitives.</Description>
    <RootNamespace>SharedKernel.EventSourcing.PostgreSQL</RootNamespace>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/danigutsch/ViajantesTurismo</RepositoryUrl>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageTags>event-sourcing;postgresql;shared-kernel;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SharedKernel.EventSourcing\SharedKernel.EventSourcing.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    <PackageReference Include="Npgsql" VersionOverride="10.0.1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
