<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>SharedKernel.IntegrationEvents</PackageId>
        <Description>Typed integration event dispatch abstractions for cross-boundary workflows.</Description>
        <RootNamespace>SharedKernel.IntegrationEvents</RootNamespace>
        <IsAotCompatible>true</IsAotCompatible>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <RepositoryUrl>https://github.com/danigutsch/ViajantesTurismo</RepositoryUrl>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <PackageTags>integration-events;shared-kernel;mediator;dotnet</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\SharedKernel.Mediator.Abstractions\SharedKernel.Mediator.Abstractions.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
    </ItemGroup>

</Project>
