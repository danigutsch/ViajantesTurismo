<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>SharedKernel.DomainEvents</PackageId>
        <Description>Typed domain event dispatch abstractions backed by SharedKernel.Mediator.</Description>
        <RootNamespace>SharedKernel.DomainEvents</RootNamespace>
        <IsAotCompatible>true</IsAotCompatible>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <RepositoryUrl>https://github.com/danigutsch/ViajantesTurismo</RepositoryUrl>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <PackageTags>domain-events;shared-kernel;mediator;dotnet</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\SharedKernel.Domain\SharedKernel.Domain.csproj" />
        <ProjectReference Include="..\SharedKernel.Mediator.Abstractions\SharedKernel.Mediator.Abstractions.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
    </ItemGroup>

</Project>
