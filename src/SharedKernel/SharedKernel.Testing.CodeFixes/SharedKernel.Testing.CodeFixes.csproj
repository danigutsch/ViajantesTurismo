<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <PackageId>SharedKernel.Testing.CodeFixes</PackageId>
        <Description>Code fixes for repository test conventions.</Description>
        <RootNamespace>SharedKernel.Testing.CodeFixes</RootNamespace>
        <IsRoslynComponent>true</IsRoslynComponent>
        <IncludeBuildOutput>false</IncludeBuildOutput>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" VersionOverride="$(MediatorRoslynAnalyzersVersion)" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" VersionOverride="$(MediatorRoslynVersion)" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" VersionOverride="$(MediatorRoslynVersion)" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\SharedKernel.Testing.Analyzers\SharedKernel.Testing.Analyzers.csproj" ReferenceOutputAssembly="false" PrivateAssets="all" OutputItemType="_TestingAnalyzerPackFile" Targets="GetTargetPath" />
        <Compile Include="..\SharedKernel.Testing.Analyzers\TestingDiagnosticIds.cs" Link="TestingDiagnosticIds.cs" />
    </ItemGroup>

    <ItemGroup>
        <AdditionalFiles Include="..\SharedKernel.Testing.Analyzers\AnalyzerReleases.Unshipped.md" Link="AnalyzerReleases.Unshipped.md" />
        <None Include="_._" Pack="true" PackagePath="lib/netstandard2.0/" Visible="false" />
        <None Include="@(_TestingAnalyzerPackFile)" Pack="true" PackagePath="analyzers/dotnet/cs" CopyToOutputDirectory="PreserveNewest" Link="SharedKernel.Testing.Analyzers.dll" Visible="false" />
        <None Include="$(OutputPath)$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    </ItemGroup>

</Project>
