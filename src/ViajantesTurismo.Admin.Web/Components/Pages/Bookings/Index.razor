@page "/bookings"
@using ViajantesTurismo.Admin.Contracts
@rendermode InteractiveServer

@inject IBookingsApiClient BookingsApi

<PageTitle>Bookings</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-calendar-check"></i> All Bookings</h1>
    </div>

    @if (_loading)
    {
        <p><em>Loading bookings...</em></p>
    }
    else
    {
        <div class="card">
            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <h5 class="mb-0">Bookings Overview</h5>
                    </div>
                    <div class="col-md-6 text-end">
                        <span class="badge bg-secondary me-2">Total: @_bookings?.Length</span>
                        <span class="badge bg-warning text-dark me-2">Pending: @_bookings?.Count(b => b.Status == BookingStatusDto.Pending)</span>
                        <span class="badge bg-success">Confirmed: @_bookings?.Count(b => b.Status == BookingStatusDto.Confirmed)</span>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <BookingsList Bookings="_bookings" />
            </div>
        </div>
    }
</div>

@code {
    private GetBookingDto[]? _bookings;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadBookings();
    }

    private async Task LoadBookings()
    {
        _loading = true;
        try
        {
            _bookings = await BookingsApi.GetAllBookings(CancellationToken.None);
        }
        finally
        {
            _loading = false;
        }
    }
}
