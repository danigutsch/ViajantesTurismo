@page "/bookings/{id:guid}"
@using ViajantesTurismo.Admin.Contracts
@using ViajantesTurismo.Admin.Web.Helpers
@inject IBookingsApiClient BookingsApi
@rendermode InteractiveServer

<PageTitle>Booking Details</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-calendar-check"></i> Booking Details</h1>
        <div class="btn-group">
            <NavLink href="/bookings" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </NavLink>
            <NavLink href="@($"/bookings/{Id}/edit")" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Edit Booking
            </NavLink>
        </div>
    </div>

    @if (_loading)
    {
        <p><em>Loading...</em></p>
    }
    else if (_notFound)
    {
        <div class="alert alert-danger" role="alert">
            Booking not found.
        </div>
    }
    else if (_booking != null)
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">General Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Status</dt>
                            <dd class="col-sm-8"><BookingStatusBadge Status="@_booking.Status" /></dd>

                            <dt class="col-sm-4">Payment Status</dt>
                            <dd class="col-sm-8"><PaymentStatusBadge Status="@_booking.PaymentStatus" /></dd>

                            <dt class="col-sm-4">Booking Date</dt>
                            <dd class="col-sm-8">@_booking.BookingDate.ToString("dd/MM/yyyy HH:mm")</dd>

                            <dt class="col-sm-4">Tour</dt>
                            <dd class="col-sm-8">
                                <a href="/tours/@_booking.TourId">@_booking.TourName</a><br />
                                <small class="text-muted">@_booking.TourIdentifier</small>
                            </dd>

                            <dt class="col-sm-4">Customer</dt>
                            <dd class="col-sm-8">
                                <a href="/customers/@_booking.CustomerId">@_booking.CustomerName</a>
                            </dd>

                            @if (_booking.CompanionId.HasValue)
                            {
                                <dt class="col-sm-4">Companion</dt>
                                <dd class="col-sm-8">
                                    <a href="/customers/@_booking.CompanionId">@_booking.CompanionName</a>
                                </dd>
                            }
                        </dl>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Financial Details</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Total Price</dt>
                            <dd class="col-sm-8">@CurrencyFormatter.Format(_booking.TotalPrice, _booking.Currency)</dd>

                            <dt class="col-sm-4">Amount Paid</dt>
                            <dd class="col-sm-8 text-success">@CurrencyFormatter.Format(_booking.AmountPaid, _booking.Currency)</dd>

                            <dt class="col-sm-4">Remaining Balance</dt>
                            <dd class="col-sm-8 text-danger">@CurrencyFormatter.Format(_booking.RemainingBalance, _booking.Currency)</dd>

                            <dt class="col-sm-4">Discount</dt>
                            <dd class="col-sm-8">
                                @if (_booking.DiscountType != DiscountTypeDto.None)
                                {
                                    <span>@_booking.DiscountAmount @(_booking.DiscountType == DiscountTypeDto.Percentage ? "%" : _booking.Currency.ToString())</span>
                                    @if (!string.IsNullOrEmpty(_booking.DiscountReason))
                                    {
                                        <br /><small class="text-muted">Reason: @_booking.DiscountReason</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_booking.Notes))
                {
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Notes</h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-0" style="white-space: pre-wrap;">@_booking.Notes</p>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-4">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Payments</h5>
                    </div>
                    <div class="card-body p-0">
                        <PaymentsList Payments="_booking.Payments" Currency="_booking.Currency" />
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private GetBookingDto? _booking;
    private bool _loading = true;
    private bool _notFound;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _booking = await BookingsApi.GetBookingById(Id, CancellationToken.None);
            if (_booking == null)
            {
                _notFound = true;
            }
        }
        catch (Exception)
        {
            _notFound = true;
        }
        finally
        {
            _loading = false;
        }
    }
}
