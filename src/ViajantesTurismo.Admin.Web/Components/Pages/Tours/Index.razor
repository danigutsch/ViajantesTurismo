@page "/tours"
@using Microsoft.AspNetCore.Components.QuickGrid
@using ViajantesTurismo.Admin.Contracts
@using ViajantesTurismo.Admin.Web.Helpers
@rendermode InteractiveServer

@inject IToursApiClient ToursApi

<PageTitle>Tours</PageTitle>

<h1><i class="bi bi-list-nested"></i> Tours</h1>

@if (_tours == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="table-responsive-wrapper">
    <QuickGrid Items="@_tours.AsQueryable()" Class="table table-hover" Pagination="@(_tours.Length > 10 ? _pagination : null)">
        <PropertyColumn Property="@(t => t.Identifier)" Title="Identifier" Sortable="true" />
        <PropertyColumn Property="@(t => t.Name)" Title="Name" Sortable="true" />
        <PropertyColumn Property="@(t => t.StartDate)" Title="Start Date" Format="@DateFormatter.DateFormat"
                        Sortable="true"/>
        <PropertyColumn Property="@(t => t.EndDate)" Title="End Date" Format="@DateFormatter.DateFormat"
                        Sortable="true"/>

        <TemplateColumn Title="Price" Sortable="true" SortBy="GridSort<GetTourDto>.ByAscending(t => t.Price)">
            @FormatPrice(context.Price, context.Currency)
        </TemplateColumn>

        <TemplateColumn Title="Single Room Supplement">
            @FormatPrice(context.DoubleRoomSupplementPrice, context.Currency)
        </TemplateColumn>

        <TemplateColumn Title="Regular Bike">
            @FormatPrice(context.RegularBikePrice, context.Currency)
        </TemplateColumn>

        <TemplateColumn Title="E-Bike">
            @FormatPrice(context.EBikePrice, context.Currency)
        </TemplateColumn>

        <TemplateColumn Title="Capacity" Sortable="true"
                        SortBy="GridSort<GetTourDto>.ByAscending(t => t.CurrentCustomerCount)">
            <div class="d-flex align-items-center gap-2">
                <span class="text-nowrap">@context.CurrentCustomerCount / @context.MaxCustomers</span>
                @if (IsFullyBooked(context))
                {
                    <span class="badge bg-danger" title="Tour is fully booked">
                        <i class="bi bi-exclamation-circle"></i> Full
                    </span>
                }
                else if (IsBelowMinimum(context))
                {
                    <span class="badge bg-warning text-dark"
                          title="Below minimum capacity (@context.MinCustomers customers)">
                        <i class="bi bi-exclamation-triangle"></i> Below Min
                    </span>
                }
                else
                {
                    <span class="badge bg-success" title="@GetAvailableSpots(context) spots available">
                        <i class="bi bi-check-circle"></i> @GetAvailableSpots(context) spots
                    </span>
                }
            </div>
        </TemplateColumn>

        <TemplateColumn Title="Actions">
            <div class="btn-group" role="group">
                <NavLink href="@($"/tours/{context.Id.ToString()}")" class="btn btn-sm btn-info">
                    <i class="bi bi-eye"></i> View
                </NavLink>
                <NavLink href="@($"/edittour/{context.Id.ToString()}")" class="btn btn-sm btn-primary">
                    <i class="bi bi-pencil"></i> Edit
                </NavLink>
            </div>
        </TemplateColumn>
    </QuickGrid>
    </div>

    @if (_tours.Length > 10)
    {
        <Paginator State="@_pagination" />
    }

    <div class="mt-3">
        <p class="text-muted">Total tours: @_tours.Length</p>
    </div>
}

@code {
    private GetTourDto[]? _tours;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 10 };

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        _tours = await ToursApi.GetTours(CancellationToken.None);
    }

    private static string FormatPrice(decimal price, CurrencyDto currency) => CurrencyFormatter.Format(price, currency);

    private static bool IsFullyBooked(GetTourDto tour) => tour.CurrentCustomerCount >= tour.MaxCustomers;

    private static bool IsBelowMinimum(GetTourDto tour) => tour.CurrentCustomerCount < tour.MinCustomers;

    private static int GetAvailableSpots(GetTourDto tour) => tour.MaxCustomers - tour.CurrentCustomerCount;

}
