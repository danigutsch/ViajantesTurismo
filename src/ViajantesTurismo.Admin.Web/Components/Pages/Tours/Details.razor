@page "/tours/{id:int}"
@using ViajantesTurismo.AdminApi.Contracts
@rendermode InteractiveServer

@inject ToursApiClient ToursApi
@inject BookingsApiClient BookingsApi
@inject CustomersApiClient CustomersApi

<PageTitle>Tour Details</PageTitle>

<ConfirmDialog @ref="_confirmDialog" />
<ToastNotification @ref="_toast" />

<h1>Tour Details</h1>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else if (_notFound)
{
    <div class="alert alert-danger" role="alert">
        Tour not found.
    </div>
    <NavLink href="/tours" class="btn btn-secondary">Back to Tours</NavLink>
}
else if (_tour != null)
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="mb-0">@_tour.Name</h3>
            <div class="d-flex gap-2">
                <a href="@($"/edittour/{_tour.Id}")" class="btn btn-primary">Edit Tour</a>
                <NavLink href="/tours" class="btn btn-secondary">Back to List</NavLink>
            </div>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h5>General Information</h5>
                    <dl class="row">
                        <dt class="col-sm-4">Identifier:</dt>
                        <dd class="col-sm-8">@_tour.Identifier</dd>

                        <dt class="col-sm-4">Tour Name:</dt>
                        <dd class="col-sm-8">@_tour.Name</dd>

                        <dt class="col-sm-4">Start Date:</dt>
                        <dd class="col-sm-8">@_tour.StartDate.ToShortDateString()</dd>

                        <dt class="col-sm-4">End Date:</dt>
                        <dd class="col-sm-8">@_tour.EndDate.ToShortDateString()</dd>

                        <dt class="col-sm-4">Duration:</dt>
                        <dd class="col-sm-8">@((_tour.EndDate - _tour.StartDate).Days) days</dd>

                        <dt class="col-sm-4">Currency:</dt>
                        <dd class="col-sm-8">@_tour.Currency</dd>
                    </dl>
                </div>

                <div class="col-md-6">
                    <h5>Pricing</h5>
                    <dl class="row">
                        <dt class="col-sm-6">Base Price:</dt>
                        <dd class="col-sm-6">@FormatPrice(_tour.Price, _tour.Currency)</dd>

                        <dt class="col-sm-6">Single Room Supplement:</dt>
                        <dd class="col-sm-6">@FormatPrice(_tour.SingleRoomSupplementPrice, _tour.Currency)</dd>

                        <dt class="col-sm-6">Regular Bike Price:</dt>
                        <dd class="col-sm-6">@FormatPrice(_tour.RegularBikePrice, _tour.Currency)</dd>

                        <dt class="col-sm-6">E-Bike Price:</dt>
                        <dd class="col-sm-6">@FormatPrice(_tour.EBikePrice, _tour.Currency)</dd>
                    </dl>
                </div>
            </div>

            @if (_tour.IncludedServices.Any())
            {
                <div class="row">
                    <div class="col-12">
                        <h5>Included Services</h5>
                        <ul class="list-group">
                            @foreach (var service in _tour.IncludedServices)
                            {
                                <li class="list-group-item">@service</li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="bi bi-calendar-check"></i> Bookings</h3>
            <button class="btn btn-success" @onclick="ShowCreateBookingForm">
                <i class="bi bi-plus-circle"></i> Add Booking
            </button>
        </div>
        <div class="card-body">
            @if (_loadingBookings)
            {
                <p><em>Loading bookings...</em></p>
            }
            else if (_showCreateForm)
            {
                <div class="border rounded p-3 mb-3">
                    <h5>@(_editingBookingId.HasValue ? "Edit Booking" : "Create New Booking")</h5>
                    @if (_editingBookingId.HasValue)
                    {
                        <BookingEditForm Model="_bookingFormModel"
                                         Customers="_customers"
                                         OnValidSubmit="@HandleSaveBooking"
                                         OnCancel="@(EventCallback.Factory.Create(this, HideBookingForm))"
                                         IsSubmitting="_isSubmitting"/>
                    }
                    else
                    {
                        <BookingCreateForm Model="_bookingFormModel"
                                           Customers="_customers"
                                           Tours="_tours"
                                           OnValidSubmit="@HandleSaveBooking"
                                           OnCancel="@(EventCallback.Factory.Create(this, HideBookingForm))"
                                           IsSubmitting="_isSubmitting"/>
                    }
                </div>
            }
            else
            {
                <BookingsList Bookings="_bookings"
                              ShowTourInfo="false"
                              OnEdit="HandleEditBooking"
                              OnConfirm="HandleConfirmBooking"
                              OnCancel="HandleCancelBooking"
                              OnComplete="HandleCompleteBooking"
                              OnDelete="HandleDeleteBooking" />
            }
        </div>
    </div>
}

@code {

    /// <summary>
	/// The ID of the tour to display details for.
    /// </summary>
    [Parameter]
    public int Id { get; set; }

    private GetTourDto? _tour;
    private bool _loading = true;
    private bool _notFound;

    private GetBookingDto[]? _bookings;
    private bool _loadingBookings = true;
    private bool _showCreateForm;
    private long? _editingBookingId;

    private GetCustomerDto[] _customers = [];
    private GetTourDto[] _tours = [];
    private BookingFormModel _bookingFormModel = new();
    private bool _isSubmitting;

    private ConfirmDialog _confirmDialog = null!;
    private ToastNotification _toast = null!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tour = await ToursApi.GetTourById(Id);

            if (_tour is null)
            {
                _notFound = true;
            }
            else
            {
                await Task.WhenAll(LoadBookings(), LoadCustomers(), LoadTours());
            }
        }
        catch (Exception)
        {
            _notFound = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadBookings()
    {
        _loadingBookings = true;
        try
        {
            _bookings = await BookingsApi.GetBookingsByTourId(Id);
        }
        finally
        {
            _loadingBookings = false;
        }
    }

    private async Task LoadCustomers()
    {
        try
        {
            _customers = (await CustomersApi.GetCustomers()).ToArray();
        }
        catch (Exception)
        {
            _customers = [];
        }
    }

    private async Task LoadTours()
    {
        try
        {
            _tours = (await ToursApi.GetTours()).ToArray();
        }
        catch (Exception)
        {
            _tours = [];
        }
    }

    private void ShowCreateBookingForm()
    {
        _editingBookingId = null;
        _bookingFormModel = new BookingFormModel();
        _showCreateForm = true;
    }

    private void ShowEditBookingForm(long bookingId)
    {
        var booking = _bookings?.FirstOrDefault(b => b.Id == bookingId);
        if (booking == null) return;

        _editingBookingId = bookingId;
        _bookingFormModel = new BookingFormModel
        {
            CustomerId = booking.CustomerId,
            CompanionId = booking.CompanionId,
            Notes = booking.Notes,
            Status = booking.Status,
            PaymentStatus = booking.PaymentStatus
        };
        _showCreateForm = true;
    }

    private void HideBookingForm()
    {
        _showCreateForm = false;
        _editingBookingId = null;
    }

    private async Task HandleSaveBooking(BookingFormModel model)
    {
        _isSubmitting = true;
        try
        {
            if (_editingBookingId.HasValue)
            {
                var updateDto = new UpdateBookingDto
                {
                    Notes = model.Notes,
                    Status = model.Status,
                    PaymentStatus = model.PaymentStatus
                };

                await BookingsApi.UpdateBooking(_editingBookingId.Value, updateDto);
                _toast.ShowSuccess("Booking updated successfully.");
            }
            else
            {
                var createDto = new CreateBookingDto
                {
                    TourId = Id,
                    PrincipalCustomerId = model.CustomerId!.Value,
                    PrincipalBikeType = BikeTypeDto.Regular,
                    CompanionCustomerId = model.CompanionId,
                    CompanionBikeType = model.CompanionId.HasValue ? BikeTypeDto.Regular : null,
                    RoomType = model.CompanionId.HasValue ? RoomTypeDto.DoubleRoom : RoomTypeDto.SingleRoom,
                    Notes = model.Notes
                };

                await BookingsApi.CreateBooking(createDto);
                _toast.ShowSuccess("Booking created successfully.");
            }

            await LoadBookings();
            HideBookingForm();
        }
        catch (Exception ex)
        {
            _toast.ShowError($"Failed to save booking: {ex.Message}");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task HandleEditBooking(long bookingId)
    {
        ShowEditBookingForm(bookingId);
        await Task.CompletedTask;
    }

    private async Task HandleConfirmBooking(long bookingId)
    {
        try
        {
            await BookingsApi.ConfirmBooking(bookingId);
            await LoadBookings();
            _toast.ShowSuccess("Booking confirmed successfully.");
        }
        catch (Exception ex)
        {
            _toast.ShowError($"Failed to confirm booking: {ex.Message}");
        }
    }

    private async Task HandleCancelBooking(long bookingId)
    {
        if (await _confirmDialog.ShowAsync("Are you sure you want to cancel this booking?", "Cancel Booking", "Yes, Cancel", "No", "btn-warning"))
        {
            try
            {
                await BookingsApi.CancelBooking(bookingId);
                await LoadBookings();
                _toast.ShowSuccess("Booking cancelled successfully.");
            }
            catch (Exception ex)
            {
                _toast.ShowError($"Failed to cancel booking: {ex.Message}");
            }
        }
    }

    private async Task HandleCompleteBooking(long bookingId)
    {
        try
        {
            await BookingsApi.CompleteBooking(bookingId);
            await LoadBookings();
            _toast.ShowSuccess("Booking completed successfully.");
        }
        catch (Exception ex)
        {
            _toast.ShowError($"Failed to complete booking: {ex.Message}");
        }
    }

    private async Task HandleDeleteBooking(long bookingId)
    {
        if (await _confirmDialog.ShowAsync("Are you sure you want to delete this booking? This action cannot be undone.", "Delete Booking", "Yes, Delete", "No", "btn-danger"))
        {
            try
            {
                await BookingsApi.DeleteBooking(bookingId);
                await LoadBookings();
                _toast.ShowSuccess("Booking deleted successfully.");
            }
            catch (Exception ex)
            {
                _toast.ShowError($"Failed to delete booking: {ex.Message}");
            }
        }
    }

    private static string FormatPrice(decimal price, CurrencyDto currency)
    {
        var symbol = currency switch
        {
            CurrencyDto.Real => "R$",
            CurrencyDto.Euro => "€",
            CurrencyDto.UsDollar => "$",
            _ => ""
        };
        return $"{symbol}{price:N2}";
    }

}
