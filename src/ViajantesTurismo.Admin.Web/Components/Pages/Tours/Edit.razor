@page "/edittour/{id:int}"
@using System.ComponentModel.DataAnnotations
@using ViajantesTurismo.AdminApi.Contracts
@inject ToursApiClient ToursApi
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Edit Tour</PageTitle>

<h1>Edit Tour</h1>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else if (_notFound)
{
    <div class="alert alert-danger" role="alert">
        Tour not found.
    </div>
    <NavLink href="/tours" class="btn btn-secondary">Back to Tours</NavLink>
}
else
{
    @if (_success)
    {
        <div class="alert alert-success" role="alert">
            Tour updated successfully!
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @_errorMessage
        </div>
    }

    <EditForm Model="@_model" OnValidSubmit="@HandleSubmit" FormName="editTour">
        <DataAnnotationsValidator/>
        <ValidationSummary/>

        <div class="mb-3">
            <label for="identifier" class="form-label">Tour Identifier</label>
            <InputText id="identifier" class="form-control" @bind-Value="_model.Identifier"
                       placeholder="e.g., CUBA2024"/>
        </div>

        <div class="mb-3">
            <label for="name" class="form-label">Tour Name</label>
            <InputText id="name" class="form-control" @bind-Value="_model.Name" placeholder="e.g., Isla de Cuba"/>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="startDate" class="form-label">Start Date</label>
                <InputDate id="startDate" class="form-control" @bind-Value="_model.StartDate"/>
            </div>
            <div class="col-md-6 mb-3">
                <label for="endDate" class="form-label">End Date</label>
                <InputDate id="endDate" class="form-control" @bind-Value="_model.EndDate"/>
            </div>
        </div>

        <div class="mb-3">
            <label for="currency" class="form-label">Currency</label>
            <InputSelect id="currency" class="form-control" @bind-Value="_model.Currency">
                <option value="@CurrencyDto.Real">Brazilian Real (BRL)</option>
                <option value="@CurrencyDto.Euro">Euro (EUR)</option>
                <option value="@CurrencyDto.UsDollar">US Dollar (USD)</option>
            </InputSelect>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="price" class="form-label">Base Price</label>
                <InputNumber id="price" class="form-control" @bind-Value="_model.Price" @bind-Value:format="F2"/>
            </div>
            <div class="col-md-6 mb-3">
                <label for="singleRoom" class="form-label">Double Room Supplement</label>
                <InputNumber id="singleRoom" class="form-control" @bind-Value="_model.DoubleRoomSupplementPrice"
                             @bind-Value:format="F2"/>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="regularBike" class="form-label">Regular Bike Price</label>
                <InputNumber id="regularBike" class="form-control" @bind-Value="_model.RegularBikePrice"
                             @bind-Value:format="F2"/>
            </div>
            <div class="col-md-6 mb-3">
                <label for="eBike" class="form-label">E-Bike Price</label>
                <InputNumber id="eBike" class="form-control" @bind-Value="_model.EBikePrice" @bind-Value:format="F2"/>
            </div>
        </div>

        <div class="mb-3">
            <label for="services" class="form-label">Included Services (comma-separated)</label>
            <InputText id="services" class="form-control" @bind-Value="_model.ServicesInput"
                       placeholder="e.g., Hotel, Breakfast, City Tour"/>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label for="minCustomers" class="form-label">Minimum Customers</label>
                <InputNumber id="minCustomers" class="form-control" @bind-Value="_model.MinCustomers"/>
                <div class="form-text">Minimum number of customers required (1-20)</div>
            </div>
            <div class="col-md-6 mb-3">
                <label for="maxCustomers" class="form-label">Maximum Customers</label>
                <InputNumber id="maxCustomers" class="form-control" @bind-Value="_model.MaxCustomers"/>
                <div class="form-text">Maximum number of customers allowed (1-20)</div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary" disabled="@(_isSubmitting || _pendingRedirect)">
                @if (_isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <text>Updating...</text>
                }
                else
                {
                    <text>Update Tour</text>
                }
            </button>
            <NavLink href="/tours"
                     class="@($"btn btn-secondary {(_isSubmitting || _pendingRedirect ? "disabled" : "")}")">
                Cancel
            </NavLink>
        </div>
    </EditForm>

    @if (_pendingRedirect)
    {
        <div class="alert alert-info d-flex align-items-center justify-content-between mt-4" role="alert">
            <span>
                Redirecting to details page in 3 seconds...
            </span>
            <button class="btn btn-sm btn-outline-danger ms-3" @onclick="CancelRedirect">Cancel</button>
        </div>
    }
    else if (_redirectCancelled)
    {
        <div class="alert alert-success d-flex align-items-center justify-content-between mt-4" role="alert">
            <span>Tour updated successfully! You can go to the details page now.</span>
            <button class="btn btn-sm btn-primary ms-3" @onclick="GoToDetails">Go to Details</button>
        </div>
    }
}

@code {

    /// <summary>
    /// The ID of the tour to edit.
    /// </summary>
    [Parameter]
    public int Id { get; set; }

    private TourFormModel _model = new();
    private bool _loading = true;
    private bool _notFound;
    private bool _isSubmitting;
    private bool _success;
    private bool _pendingRedirect;
    private bool _redirectCancelled;
    private CancellationTokenSource? _redirectCts;
    private string? _errorMessage;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tour = await ToursApi.GetTourById(Id, CancellationToken.None);

            if (tour is null)
            {
                _notFound = true;
                return;
            }

            _model = new TourFormModel
            {
                Identifier = tour.Identifier,
                Name = tour.Name,
                StartDate = tour.StartDate,
                EndDate = tour.EndDate,
                Currency = tour.Currency,
                Price = tour.Price,
                DoubleRoomSupplementPrice = tour.DoubleRoomSupplementPrice,
                RegularBikePrice = tour.RegularBikePrice,
                EBikePrice = tour.EBikePrice,
                ServicesInput = string.Join(", ", tour.IncludedServices),
                MinCustomers = tour.MinCustomers,
                MaxCustomers = tour.MaxCustomers
            };
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading tour: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _success = false;
        _errorMessage = null;
        _pendingRedirect = false;
        _redirectCancelled = false;

        if (_redirectCts is not null)
        {
            await _redirectCts.CancelAsync();
            _redirectCts = null;
        }

        try
        {
            var tour = new UpdateTourDto
            {
                Identifier = _model.Identifier,
                Name = _model.Name,
                StartDate = _model.StartDate.ToUniversalTime(),
                EndDate = _model.EndDate.ToUniversalTime(),
                Currency = _model.Currency,
                Price = _model.Price,
                DoubleRoomSupplementPrice = _model.DoubleRoomSupplementPrice,
                RegularBikePrice = _model.RegularBikePrice,
                EBikePrice = _model.EBikePrice,
                IncludedServices = _model.ServicesInput
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries),
                MinCustomers = _model.MinCustomers,
                MaxCustomers = _model.MaxCustomers
            };

            await ToursApi.UpdateTour(Id, tour, CancellationToken.None);

            _success = true;
            _pendingRedirect = true;
            _redirectCts = new CancellationTokenSource();
            var token = _redirectCts.Token;
            StateHasChanged();
            try
            {
                await Task.Delay(3000, token);
                if (_pendingRedirect && !token.IsCancellationRequested)
                {
                    Navigation.NavigateTo($"/tours/{Id}");
                }
            }
            catch (TaskCanceledException)
            {
                /* Cancelled by the user */
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void CancelRedirect()
    {
        _pendingRedirect = false;
        _redirectCancelled = true;
        _redirectCts?.Cancel();
        StateHasChanged();
    }

    private void GoToDetails()
    {
        Navigation.NavigateTo($"/tours/{Id}");
    }

    [MinimumDuration(5)]
    private class TourFormModel
    {
        [Required, MaxLength(ContractConstants.MaxNameLength)]
        public string Identifier { get; set; } = string.Empty;

        [Required, MaxLength(ContractConstants.MaxNameLength)]
        public string Name { get; set; } = string.Empty;

        [Required]
        public DateTime StartDate { get; set; }

        [Required]
        public DateTime EndDate { get; set; }

        [Required]
        public CurrencyDto Currency { get; set; }

        [Required, Range(0.01, ContractConstants.MaxPrice)]
        public decimal Price { get; set; }

        [Required, Range(0.01, ContractConstants.MaxPrice)]
        public decimal DoubleRoomSupplementPrice { get; set; }

        [Required, Range(0.01, ContractConstants.MaxPrice)]
        public decimal RegularBikePrice { get; set; }

        [Required, Range(0.01, ContractConstants.MaxPrice)]
        public decimal EBikePrice { get; set; }

        [Required, Range(ContractConstants.MinTourCustomers, ContractConstants.MaxTourCustomers)]
        public int MinCustomers { get; set; }

        [Required, Range(ContractConstants.MinTourCustomers, ContractConstants.MaxTourCustomers)]
        public int MaxCustomers { get; set; }

        [Required]
        public string ServicesInput { get; set; } = string.Empty;
    }

}
