@page "/customers/{id:guid}/edit"
@using ViajantesTurismo.Admin.Contracts
@using ViajantesTurismo.Admin.Web.Models
@inject CustomersApiClient CustomersApi
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Edit Customer</PageTitle>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else if (_notFound)
{
    <div class="alert alert-danger" role="alert">
        Customer not found.
    </div>
    <NavLink href="/customers" class="btn btn-secondary">Back to Customers</NavLink>
}
else
{
    @if (_success)
    {
        <div class="alert alert-success" role="alert">
            Customer updated successfully!
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @_errorMessage
        </div>
    }

    <EditForm Model="@_model" OnValidSubmit="@HandleSubmit" FormName="editCustomer">
        <DataAnnotationsValidator/>
        <ValidationSummary/>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Personal Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="firstName" class="form-label">First Name</label>
                            <InputText id="firstName" class="form-control" @bind-Value="_model.PersonalInfo.FirstName"/>
                        </div>

                        <div class="mb-3">
                            <label for="lastName" class="form-label">Last Name</label>
                            <InputText id="lastName" class="form-control" @bind-Value="_model.PersonalInfo.LastName"/>
                        </div>

                        <div class="mb-3">
                            <label for="birthDate" class="form-label">Date of Birth</label>
                            <InputDate id="birthDate" class="form-control" @bind-Value="_model.PersonalInfo.BirthDate"/>
                        </div>

                        <div class="mb-3">
                            <label for="gender" class="form-label">Gender</label>
                            <InputText id="gender" class="form-control" @bind-Value="_model.PersonalInfo.Gender"/>
                        </div>

                        <div class="mb-3">
                            <label for="nationality" class="form-label">Nationality</label>
                            <InputText id="nationality" class="form-control"
                                       @bind-Value="_model.PersonalInfo.Nationality"/>
                        </div>

                        <div class="mb-3">
                            <label for="profession" class="form-label">Profession</label>
                            <InputText id="profession" class="form-control"
                                       @bind-Value="_model.PersonalInfo.Profession"/>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Contact Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <InputText id="email" class="form-control" @bind-Value="_model.ContactInfo.Email"/>
                        </div>

                        <div class="mb-3">
                            <label for="mobile" class="form-label">Mobile</label>
                            <InputText id="mobile" class="form-control" @bind-Value="_model.ContactInfo.Mobile"/>
                        </div>

                        <div class="mb-3">
                            <label for="instagram" class="form-label">Instagram</label>
                            <InputText id="instagram" class="form-control" @bind-Value="_model.ContactInfo.Instagram"
                                       placeholder="username"/>
                        </div>

                        <div class="mb-3">
                            <label for="facebook" class="form-label">Facebook</label>
                            <InputText id="facebook" class="form-control" @bind-Value="_model.ContactInfo.Facebook"
                                       placeholder="facebook.com/username"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Identification</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="nationalId" class="form-label">National ID</label>
                            <InputText id="nationalId" class="form-control"
                                       @bind-Value="_model.IdentificationInfo.NationalId"/>
                        </div>

                        <div class="mb-3">
                            <label for="idNationality" class="form-label">ID Nationality</label>
                            <InputText id="idNationality" class="form-control"
                                       @bind-Value="_model.IdentificationInfo.IdNationality"/>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Address</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="street" class="form-label">Street</label>
                            <InputText id="street" class="form-control" @bind-Value="_model.Address.Street"/>
                        </div>

                        <div class="mb-3">
                            <label for="complement" class="form-label">Complement</label>
                            <InputText id="complement" class="form-control" @bind-Value="_model.Address.Complement"/>
                        </div>

                        <div class="mb-3">
                            <label for="neighborhood" class="form-label">Neighborhood</label>
                            <InputText id="neighborhood" class="form-control"
                                       @bind-Value="_model.Address.Neighborhood"/>
                        </div>

                        <div class="mb-3">
                            <label for="postalCode" class="form-label">Postal Code</label>
                            <InputText id="postalCode" class="form-control" @bind-Value="_model.Address.PostalCode"/>
                        </div>

                        <div class="mb-3">
                            <label for="city" class="form-label">City</label>
                            <InputText id="city" class="form-control" @bind-Value="_model.Address.City"/>
                        </div>

                        <div class="mb-3">
                            <label for="state" class="form-label">State</label>
                            <InputText id="state" class="form-control" @bind-Value="_model.Address.State"/>
                        </div>

                        <div class="mb-3">
                            <label for="country" class="form-label">Country</label>
                            <InputText id="country" class="form-control" @bind-Value="_model.Address.Country"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Physical Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="weight" class="form-label">Weight (kg)</label>
                            <InputNumber id="weight" class="form-control" @bind-Value="_model.PhysicalInfo.WeightKg"/>
                        </div>

                        <div class="mb-3">
                            <label for="height" class="form-label">Height (cm)</label>
                            <InputNumber id="height" class="form-control"
                                         @bind-Value="_model.PhysicalInfo.HeightCentimeters"/>
                        </div>

                        <div class="mb-3">
                            <label for="bikeType" class="form-label">Bike Type</label>
                            <InputSelect id="bikeType" class="form-control" @bind-Value="_model.PhysicalInfo.BikeType">
                                <option value="@BikeTypeDto.None">None</option>
                                <option value="@BikeTypeDto.Regular">Regular</option>
                                <option value="@BikeTypeDto.EBike">E-Bike</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Accommodation Preferences</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="roomType" class="form-label">Room Type</label>
                            <InputSelect id="roomType" class="form-control"
                                         @bind-Value="_model.AccommodationPreferences.RoomType">
                                <option value="@RoomTypeDto.SingleRoom">Single Room</option>
                                <option value="@RoomTypeDto.DoubleRoom">Double Room</option>
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label for="bedType" class="form-label">Bed Type</label>
                            <InputSelect id="bedType" class="form-control"
                                         @bind-Value="_model.AccommodationPreferences.BedType">
                                <option value="@BedTypeDto.SingleBed">Single Bed</option>
                                <option value="@BedTypeDto.DoubleBed">Double Bed</option>
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label for="companionId" class="form-label">Companion ID</label>
                            <InputNumber id="companionId" class="form-control"
                                         @bind-Value="_model.AccommodationPreferences.CompanionId"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Emergency Contact</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="emergencyName" class="form-label">Name</label>
                            <InputText id="emergencyName" class="form-control"
                                       @bind-Value="_model.EmergencyContact.Name"/>
                        </div>

                        <div class="mb-3">
                            <label for="emergencyMobile" class="form-label">Mobile</label>
                            <InputText id="emergencyMobile" class="form-control"
                                       @bind-Value="_model.EmergencyContact.Mobile"/>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Medical Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="allergies" class="form-label">Allergies</label>
                            <InputTextArea id="allergies" class="form-control"
                                           @bind-Value="_model.MedicalInfo.Allergies" rows="3"/>
                        </div>

                        <div class="mb-3">
                            <label for="additionalInfo" class="form-label">Additional Information</label>
                            <InputTextArea id="additionalInfo" class="form-control"
                                           @bind-Value="_model.MedicalInfo.AdditionalInfo" rows="3"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary" disabled="@(_isSubmitting || _pendingRedirect)">
                @if (_isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <text>Updating...</text>
                }
                else
                {
                    <text>Update Customer</text>
                }
            </button>
            <NavLink href="/customers"
                     class="@($"btn btn-secondary {(_isSubmitting || _pendingRedirect ? "disabled" : "")}")">
                Cancel
            </NavLink>
        </div>
    </EditForm>

    @if (_pendingRedirect)
    {
        <div class="alert alert-info d-flex align-items-center justify-content-between mt-4" role="alert">
            <span>
                Redirecting to details page in 3 seconds...
            </span>
            <button class="btn btn-sm btn-outline-danger ms-3" @onclick="CancelRedirect">Cancel</button>
        </div>
    }
    else if (_redirectCancelled)
    {
        <div class="alert alert-success d-flex align-items-center justify-content-between mt-4" role="alert">
            <span>Customer updated successfully! You can go to the details page now.</span>
            <button class="btn btn-sm btn-primary ms-3" @onclick="GoToDetails">Go to Details</button>
        </div>
    }
}

@code {

    /// <summary>
    /// The ID of the customer to edit.
    /// </summary>
    [Parameter]
    public Guid Id { get; set; }

    private CustomerFormModel _model = new();
    private bool _loading = true;
    private bool _notFound;
    private bool _isSubmitting;
    private bool _success;
    private bool _pendingRedirect;
    private bool _redirectCancelled;
    private CancellationTokenSource? _redirectCts;
    private string? _errorMessage;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var customer = await CustomersApi.GetCustomerById(Id, CancellationToken.None);

            if (customer is null)
            {
                _notFound = true;
                return;
            }

            _model = new CustomerFormModel
            {
                PersonalInfo = PersonalInfoFormModel.FromDto(customer.PersonalInfo),
                IdentificationInfo = IdentificationInfoFormModel.FromDto(customer.IdentificationInfo),
                ContactInfo = ContactInfoFormModel.FromDto(customer.ContactInfo),
                Address = AddressFormModel.FromDto(customer.Address),
                PhysicalInfo = PhysicalInfoFormModel.FromDto(customer.PhysicalInfo),
                AccommodationPreferences = AccommodationPreferencesFormModel.FromDto(customer.AccommodationPreferences),
                EmergencyContact = EmergencyContactFormModel.FromDto(customer.EmergencyContact),
                MedicalInfo = MedicalInfoFormModel.FromDto(customer.MedicalInfo)
            };
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading customer: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _success = false;
        _errorMessage = null;
        _pendingRedirect = false;
        _redirectCancelled = false;

        if (_redirectCts is not null)
        {
            await _redirectCts.CancelAsync();
            _redirectCts = null;
        }

        try
        {
            var customer = new UpdateCustomerDto
            {
                PersonalInfo = _model.PersonalInfo.ToDto(),
                IdentificationInfo = _model.IdentificationInfo.ToDto(),
                ContactInfo = _model.ContactInfo.ToDto(),
                Address = _model.Address.ToDto(),
                PhysicalInfo = _model.PhysicalInfo.ToDto(),
                AccommodationPreferences = _model.AccommodationPreferences.ToDto(),
                EmergencyContact = _model.EmergencyContact.ToDto(),
                MedicalInfo = _model.MedicalInfo.ToDto()
            };

            await CustomersApi.UpdateCustomer(Id, customer, CancellationToken.None);

            _success = true;
            _pendingRedirect = true;
            _redirectCts = new CancellationTokenSource();
            var token = _redirectCts.Token;
            StateHasChanged();
            try
            {
                await Task.Delay(3000, token);
                if (_pendingRedirect && !token.IsCancellationRequested)
                {
                    Navigation.NavigateTo($"/customers/{Id}");
                }
            }
            catch (TaskCanceledException)
            {
                /* Cancelled by the user */
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void CancelRedirect()
    {
        _pendingRedirect = false;
        _redirectCancelled = true;
        _redirectCts?.Cancel();
        StateHasChanged();
    }

    private void GoToDetails()
    {
        Navigation.NavigateTo($"/customers/{Id}");
    }

    private class CustomerFormModel
    {
        public PersonalInfoFormModel PersonalInfo { get; set; } = new();
        public IdentificationInfoFormModel IdentificationInfo { get; set; } = new();
        public ContactInfoFormModel ContactInfo { get; set; } = new();
        public AddressFormModel Address { get; set; } = new();
        public PhysicalInfoFormModel PhysicalInfo { get; set; } = new();
        public AccommodationPreferencesFormModel AccommodationPreferences { get; set; } = new();
        public EmergencyContactFormModel EmergencyContact { get; set; } = new();
        public MedicalInfoFormModel MedicalInfo { get; set; } = new();
    }

}
