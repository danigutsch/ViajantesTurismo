@page "/customers"
@using Microsoft.AspNetCore.Components.QuickGrid
@using ViajantesTurismo.Admin.Contracts
@rendermode InteractiveServer

@inject ICustomersApiClient CustomersApi

<PageTitle>Customers</PageTitle>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h1 class="mb-0"><i class="bi bi-people-fill"></i> Customers</h1>
    <div class="d-flex gap-2">
        <NavLink href="/customers/import" class="btn btn-outline-secondary">
            <i class="bi bi-upload"></i> Import from CSV
        </NavLink>
        <NavLink href="/customers/create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Customer
        </NavLink>
    </div>
</div>

<p>Manage customer information and profiles.</p>

@if (_customers == null)
{
    <p><em>Loading...</em></p>
}
else if (_customers.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No customers found.
        <NavLink href="/customers/create" class="btn btn-link">Create your first customer</NavLink>
        .
    </div>
}
else
{
    <div class="table-responsive-wrapper">
    <QuickGrid Items="@_customers.AsQueryable()" Class="table table-hover" Pagination="@(_customers.Count > 10 ? _pagination : null)">
        <TemplateColumn Title="Name" Sortable="true" SortBy="GridSort<GetCustomerDto>.ByAscending(c => c.FirstName).ThenAscending(c => c.LastName)">
            @context.FirstName @context.LastName
        </TemplateColumn>

        <PropertyColumn Property="@(c => c.Email)" Title="Email" Sortable="true" />
        <PropertyColumn Property="@(c => c.Mobile)" Title="Mobile" />
        <PropertyColumn Property="@(c => c.Nationality)" Title="Nationality" Sortable="true" />

        <TemplateColumn Title="Actions">
            <div class="btn-group" role="group">
                <NavLink href="@($"/customers/{context.Id.ToString()}" as string)" class="btn btn-sm btn-info">
                    <i class="bi bi-eye"></i> View
                </NavLink>
                <NavLink href="@($"/customers/{context.Id.ToString()}/edit" as string)" class="btn btn-sm btn-primary">
                    <i class="bi bi-pencil"></i> Edit
                </NavLink>
            </div>
        </TemplateColumn>
    </QuickGrid>
    </div>

    @if (_customers.Count > 10)
    {
        <Paginator State="@_pagination" />
    }

    <div class="mt-3">
        <p class="text-muted">Total customers: @_customers.Count</p>
    </div>
}

@code {
    private IReadOnlyList<GetCustomerDto>? _customers;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 10 };

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomersApi.GetCustomers(CancellationToken.None);
    }

}
