@page "/customers"
@using Microsoft.AspNetCore.Components.QuickGrid
@using ViajantesTurismo.AdminApi.Contracts
@rendermode InteractiveServer

@inject CustomersApiClient CustomersApi

<PageTitle>Customers</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-people-fill"></i> Customers</h1>
    <NavLink href="/customers/create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create New Customer
    </NavLink>
</div>

<p>Manage customer information and profiles.</p>

@if (_customers == null)
{
    <p><em>Loading...</em></p>
}
else if (_customers.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No customers found.
        <NavLink href="/customers/create" class="btn btn-link">Create your first customer</NavLink>
        .
    </div>
}
else
{
    <QuickGrid Items="@_customers.AsQueryable()" Class="table table-hover" Pagination="@(_customers.Count > 10 ? _pagination : null)">
        <PropertyColumn Property="@(c => c.Id)" Title="ID" Sortable="true" />
        
        <TemplateColumn Title="Name" Sortable="true" SortBy="GridSort<GetCustomerDto>.ByAscending(c => c.FirstName).ThenAscending(c => c.LastName)">
            @context.FirstName @context.LastName
        </TemplateColumn>
        
        <PropertyColumn Property="@(c => c.Email)" Title="Email" Sortable="true" />
        <PropertyColumn Property="@(c => c.Mobile)" Title="Mobile" />
        <PropertyColumn Property="@(c => c.Nationality)" Title="Nationality" Sortable="true" />
        
        <TemplateColumn Title="Actions">
            <div class="btn-group" role="group">
                <NavLink href="@($"/customers/{context.Id}")" class="btn btn-sm btn-info">
                    <i class="bi bi-eye"></i> View
                </NavLink>
                <NavLink href="@($"/customers/{context.Id}/edit")" class="btn btn-sm btn-primary">
                    <i class="bi bi-pencil"></i> Edit
                </NavLink>
            </div>
        </TemplateColumn>
    </QuickGrid>
    
    @if (_customers.Count > 10)
    {
        <Paginator State="@_pagination" />
    }

    <div class="mt-3">
        <p class="text-muted">Total customers: @_customers.Count</p>
    </div>
}

@code {
    private IReadOnlyList<GetCustomerDto>? _customers;
    private PaginationState _pagination = new() { ItemsPerPage = 10 };

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomersApi.GetCustomers();
    }

}
