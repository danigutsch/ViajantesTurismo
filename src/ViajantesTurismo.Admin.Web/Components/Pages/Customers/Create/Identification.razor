@page "/customers/create/identification"
@using ViajantesTurismo.Admin.Web.Models
@using ViajantesTurismo.Admin.Web.Services
@rendermode InteractiveServer

@inject CustomerCreationState State
@inject NavigationManager Navigation
@inject ICountryService CountryService

<PageTitle>Create Customer - Identification</PageTitle>

<div class="container mt-4">
    <h2>Create New Customer</h2>
    <WizardProgress/>

    <div class="card">
        <div class="card-header">
            <h4>Step 2 of 8: Identification Information</h4>
        </div>
        <div class="card-body">
            <EditForm Model="@_model" OnValidSubmit="@HandleValidSubmit">
                <DataAnnotationsValidator/>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="nationalId" class="form-label">National ID <span
                                class="text-danger">*</span></label>
                        <InputText id="nationalId" @bind-Value="_model.NationalId" class="form-control"
                                   placeholder="e.g., 123.456.789-00"/>
                        <ValidationMessage For="@(() => _model.NationalId)"/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">ID Nationality <span class="text-danger">*</span></label>
                        @if (_countries == null)
                        {
                            <div class="form-control">
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                Loading countries...
                            </div>
                        }
                        else
                        {
                            <CountrySelector @bind-Value="_model.IdNationality" Countries="_countries"/>
                        }
                        <ValidationMessage For="@(() => _model.IdNationality)"/>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Back
                    </button>
                    <button type="submit" class="btn btn-primary">
                        Next <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private IdentificationInfoFormModel _model = new();
    private CountryInfo[]? _countries;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        if (State.IdentificationInfo is not null)
        {
            _model = State.IdentificationInfo;
        }

        State.NavigateToStep(2);

        _countries = await CountryService.GetCountries(CancellationToken.None);
    }

    private void HandleValidSubmit()
    {
        State.SetIdentificationInfo(_model);
        Navigation.NavigateTo("/customers/create/contact");
    }

    private void GoBack()
    {
        State.NavigateToStep(1);
        Navigation.NavigateTo("/customers/create/personal-info");
    }

}
