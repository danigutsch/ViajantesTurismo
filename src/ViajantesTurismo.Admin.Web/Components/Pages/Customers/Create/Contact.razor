@page "/customers/create/contact"
@using ViajantesTurismo.Admin.Web.Models
@rendermode InteractiveServer

@inject CustomerCreationState State
@inject NavigationManager Navigation

<PageTitle>Create Customer - Contact Information</PageTitle>

<div class="container mt-4">
    <h2>Create New Customer</h2>
    <WizardProgress/>

    <div class="card">
        <div class="card-header">
            <h4>Step 3 of 8: Contact Information</h4>
        </div>
        <div class="card-body">
            <EditForm Model="@_model" OnValidSubmit="@HandleValidSubmit">
                <DataAnnotationsValidator/>
                <ValidationSummary class="alert alert-danger"/>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
                        <InputText id="email" type="email" @bind-Value="_model.Email" class="form-control"/>
                        <ValidationMessage For="@(() => _model.Email)"/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="mobile" class="form-label">Mobile <span class="text-danger">*</span></label>
                        <InputText id="mobile" @bind-Value="_model.Mobile" class="form-control"
                                   placeholder="+55 11 98765-4321"/>
                        <ValidationMessage For="@(() => _model.Mobile)"/>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="instagram" class="form-label">Instagram</label>
                        <InputText id="instagram" @bind-Value="_model.Instagram" class="form-control"
                                   placeholder="username"/>
                        <ValidationMessage For="@(() => _model.Instagram)"/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="facebook" class="form-label">Facebook</label>
                        <InputText id="facebook" @bind-Value="_model.Facebook" class="form-control"/>
                        <ValidationMessage For="@(() => _model.Facebook)"/>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Back
                    </button>
                    <button type="submit" class="btn btn-primary">
                        Next <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private ContactInfoFormModel _model = new();

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (State.ContactInfo is not null)
        {
            _model = State.ContactInfo;
        }

        State.NavigateToStep(3);
    }

    private void HandleValidSubmit()
    {
        State.SetContactInfo(_model);
        Navigation.NavigateTo("/customers/create/address");
    }

    private void GoBack()
    {
        State.NavigateToStep(2);
        Navigation.NavigateTo("/customers/create/identification");
    }

}
