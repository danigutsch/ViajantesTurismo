@page "/customers/create/accommodation"
@using ViajantesTurismo.Admin.Contracts
@using ViajantesTurismo.Admin.Web.Models
@rendermode InteractiveServer

@inject CustomerCreationState State
@inject NavigationManager Navigation
@inject CustomersApiClient CustomersApi

<PageTitle>Create Customer - Accommodation Preferences</PageTitle>

<div class="container mt-4">
    <h2>Create New Customer</h2>
    <WizardProgress/>

    <div class="card">
        <div class="card-header">
            <h4>Step 6 of 8: Accommodation Preferences</h4>
        </div>
        <div class="card-body">
            <EditForm Model="@_model" OnValidSubmit="@HandleValidSubmit">
                <DataAnnotationsValidator/>
                <ValidationSummary class="alert alert-danger"/>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="roomType" class="form-label">Room Type <span class="text-danger">*</span></label>
                        <InputSelect id="roomType" @bind-Value="_model.RoomType" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="@RoomTypeDto.SingleRoom">Single Room</option>
                            <option value="@RoomTypeDto.DoubleRoom">Double Room</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => _model.RoomType)"/>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="bedType" class="form-label">Bed Type <span class="text-danger">*</span></label>
                        <InputSelect id="bedType" @bind-Value="_model.BedType" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="@BedTypeDto.SingleBed">Single Bed</option>
                            <option value="@BedTypeDto.DoubleBed">Double Bed</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => _model.BedType)"/>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Companion (Optional)</label>
                        @if (_customers == null)
                        {
                            <div class="form-control">
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                Loading customers...
                            </div>
                        }
                        else
                        {
                            <CustomerSelector @bind-Value="_model.CompanionId" Customers="_customers"/>
                        }
                        <ValidationMessage For="@(() => _model.CompanionId)"/>
                        <small class="form-text text-muted">Select another customer traveling with this person</small>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Back
                    </button>
                    <button type="submit" class="btn btn-primary">
                        Next <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private AccommodationPreferencesFormModel _model = new();
    private IReadOnlyList<GetCustomerDto>? _customers;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        if (State.AccommodationPreferences is not null)
        {
            _model = State.AccommodationPreferences;
        }

        State.NavigateToStep(6);

        _customers = await CustomersApi.GetCustomers(CancellationToken.None);
    }

    private void HandleValidSubmit()
    {
        State.SetAccommodationPreferences(_model);
        Navigation.NavigateTo("/customers/create/emergency-contact");
    }

    private void GoBack()
    {
        State.NavigateToStep(5);
        Navigation.NavigateTo("/customers/create/physical");
    }

}
