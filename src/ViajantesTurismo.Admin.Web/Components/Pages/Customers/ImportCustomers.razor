@page "/customers/import"
@using System.Globalization
@using System.Text
@using ViajantesTurismo.Admin.Contracts
@using ViajantesTurismo.Admin.Web.Helpers
@using ViajantesTurismo.Admin.Web.Services
@rendermode InteractiveServer

@inject ICustomersApiClient CustomersApi

<PageTitle>Import Customers</PageTitle>

<div class="container mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <h1 class="mb-0"><i class="bi bi-upload"></i> Import Customers</h1>
        <NavLink href="/customers" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Customers
        </NavLink>
    </div>

    <p class="text-muted">Upload a CSV file to bulk-import customers. The file must include the required columns.</p>

    @if (_result is not null)
    {
        var summary = BuildImportSummary();
        var successRows = _result.SuccessRows ?? [];
        var errorRows = _result.ErrorRows ?? [];
        var errorReportDataUri = BuildErrorReportDataUri(errorRows);

        <div class="alert @(_result.ErrorCount == 0 ? "alert-success" : "alert-warning") d-flex align-items-start gap-3">
            <i class="bi @(_result.ErrorCount == 0 ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") fs-4"></i>
            <div>
                <strong>Import complete.</strong>
                <ul class="mb-0 mt-1">
                    <li>@_result.SuccessCount customer(s) imported successfully.</li>
                    @if (_result.ErrorCount > 0)
                    {
                        <li>@_result.ErrorCount row(s) could not be imported due to errors.</li>
                    }
                </ul>
                <ul class="mb-0 mt-2" data-testid="import-summary-counts">
                    <li>Created: @summary.CreatedCount</li>
                    <li>Updated: @summary.UpdatedCount</li>
                    <li>Skipped: @summary.SkippedCount</li>
                    <li>Failed: @summary.FailedCount</li>
                </ul>

                @if (successRows.Count > 0)
                {
                    <div class="mt-3" data-testid="summary-success-rows">
                        <div class="fw-semibold mb-2">Successful rows</div>
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Outcome</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in successRows)
                                {
                                    <tr>
                                        <td>@row.Email</td>
                                        <td>@row.Outcome</td>
                                        <td>
                                            @if (row.CustomerId.HasValue)
                                            {
                                                <NavLink href="@($"/customers/{row.CustomerId.Value}")"
                                                         data-action="view-customer"
                                                         class="btn btn-sm btn-outline-primary">
                                                    View customer
                                                </NavLink>
                                            }
                                            else
                                            {
                                                <span class="text-muted" data-action="customer-id-unavailable">ID unavailable</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (errorRows.Count > 0)
                {
                    <div class="mt-3" data-testid="summary-error-rows">
                        <div class="fw-semibold mb-2">Failed rows</div>
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Line</th>
                                    <th>Field</th>
                                    <th>Message</th>
                                    <th>Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in errorRows)
                                {
                                    <tr>
                                        <td>@row.LineNumber</td>
                                        <td>@(row.Field ?? "-")</td>
                                        <td>@row.Message</td>
                                        <td>@(row.Email ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (errorReportDataUri is not null)
                        {
                            <a href="@errorReportDataUri"
                               download="import-errors.csv"
                               class="btn btn-sm btn-outline-danger mt-2"
                               data-action="download-error-report">
                                Download error report
                            </a>
                        }
                    </div>
                }

                <div class="mt-2 d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="Reset">Import another file</button>
                    @if (_pendingFileBytes.Length > 0)
                    {
                        <button class="btn btn-sm btn-outline-secondary"
                                data-action="retry-current-file"
                                @onclick="RetryWithCurrentFile">
                            Retry with current file
                        </button>
                    }
                    <NavLink href="/customers" class="btn btn-sm btn-primary">View customers</NavLink>
                </div>
            </div>
        </div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger d-flex align-items-start gap-3">
            <i class="bi bi-x-circle-fill fs-4"></i>
            <div>
                <strong>Import failed.</strong> @_error
                <div class="mt-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="Reset">Try again</button>
                </div>
            </div>
        </div>
    }
    else if (_step == PageStep.HeaderMapping)
    {
        var unmatchedRequired = _fieldMappings
            .Where(m => m.Field.IsRequired && !AllRequiredFieldsMapped(m.Field.Name))
            .ToArray();
        var allRequiredMatched = unmatchedRequired.Length == 0;

        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-text"></i>
                <strong>@_pendingFileName</strong>
                <span class="badge bg-secondary">@_csvHeaders.Count column(s) detected</span>
            </div>
            <div class="card-body">
                @if (allRequiredMatched)
                {
                    <div class="alert alert-success d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-check-circle-fill fs-5"></i>
                        <span>All required columns were automatically matched.</span>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                        <span>@unmatchedRequired.Length required column(s) could not be matched. Please assign them below.</span>
                    </div>
                }

                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Field</th>
                            <th></th>
                            <th>Source Column (CSV)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mapping in _fieldMappings)
                        {
                            var fieldName = mapping.Field.Name;
                            var effective = GetEffectiveMappingValue(fieldName, mapping.MatchedCsvHeader);
                            <tr>
                                <td>@mapping.Field.DisplayName</td>
                                <td>
                                    @if (mapping.Field.IsRequired)
                                    {
                                        <span class="badge bg-danger">Required</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Optional</span>
                                    }
                                </td>
                                <td>
                                    <select class="form-select form-select-sm"
                                            data-field="@fieldName"
                                            @onchange="@(e => OnFieldMapped(fieldName, e.Value?.ToString()))">
                                        <option value="">(none)</option>
                                        @foreach (var header in _csvHeaders)
                                        {
                                            <option value="@header" selected="@(header == effective)">@header</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (_validationError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="bi bi-exclamation-circle"></i> @_validationError
                    </div>
                }

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary"
                            @onclick="ShowPreview"
                            disabled="@(!AllRequiredFieldsMapped() || _uploading)">
                        <i class="bi bi-eye"></i> Preview
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="Reset" disabled="@_uploading">
                        <i class="bi bi-arrow-left"></i> Choose different file
                    </button>
                </div>
            </div>
        </div>
    }
    else if (_step == PageStep.Preview)
    {
        var mappedFields = _fieldMappings
            .Where(mapping => GetEffectiveMappingValue(mapping.Field.Name, mapping.MatchedCsvHeader) is not null)
            .Select(mapping => mapping.Field)
            .ToList();

        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-table"></i>
                <strong>@_pendingFileName</strong>
                <span class="badge bg-secondary">@_previewRows.Count of max @MaxPreviewRows row(s) shown</span>
            </div>
            <div class="card-body">
                <p class="text-muted small">Review the extracted data below. Rows with missing required values are highlighted.</p>

                <div class="table-responsive">
                    <table class="table table-sm preview-table">
                        <thead>
                            <tr>
                                @foreach (var mapping in mappedFields)
                                {
                                    <th>
                                        @mapping.DisplayName
                                        @if (mapping.IsRequired)
                                        {
                                            <span class="text-danger ms-1">*</span>
                                        }
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _previewRows)
                            {
                                var hasWarning = mappedFields
                                    .Where(field => field.IsRequired)
                                    .Any(field => !row.TryGetValue(field.Name, out var value) || string.IsNullOrEmpty(value));
                                <tr class="@(hasWarning ? "table-warning" : "")">
                                    @foreach (var mapping in mappedFields)
                                    {
                                        <td>@row.GetValueOrDefault(mapping.Name, "")</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (_validationError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="bi bi-exclamation-circle"></i> @_validationError
                    </div>
                }

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary"
                            @onclick="HandleImport"
                            disabled="@_uploading">
                        @if (_uploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-check-lg"></i> Confirm Import
                    </button>
                    <button class="btn btn-outline-secondary"
                            @onclick="@(() => _step = PageStep.HeaderMapping)"
                            disabled="@_uploading">
                        <i class="bi bi-arrow-left"></i> Back to Mapping
                    </button>
                </div>
            </div>
        </div>
    }
    else if (_step == PageStep.DuplicateResolution)
    {
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-exclamation-circle"></i> Resolve Duplicates</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">The following @_conflicts.Count email(s) already exist in the database. Choose how to handle each conflict before completing the import.</p>
                <table class="table table-sm duplicate-resolution-table">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Decision</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var conflictEmail in _conflicts.Select(conflict => conflict.Email))
                        {
                            var decision = _conflictDecisions.GetValueOrDefault(conflictEmail);
                            <tr>
                                <td>@conflictEmail.ToLowerInvariant()</td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button"
                                                class="btn @(decision == "keep" ? "btn-success" : "btn-outline-secondary")"
                                                data-action="keep"
                                                @onclick="@(() => SetConflictDecision(conflictEmail, "keep"))">
                                            Keep existing
                                        </button>
                                        <button type="button"
                                                class="btn @(decision == "overwrite" ? "btn-warning" : "btn-outline-secondary")"
                                                data-action="overwrite"
                                                @onclick="@(() => SetConflictDecision(conflictEmail, "overwrite"))">
                                            Overwrite
                                        </button>
                                        <button type="button"
                                                class="btn @(decision == "mixed" ? "btn-info" : "btn-outline-secondary")"
                                                data-action="mixed"
                                                @onclick="@(() => SetConflictDecision(conflictEmail, "mixed"))">
                                            Mixed merge
                                        </button>
                                    </div>

                                    @if (decision == "mixed")
                                    {
                                        var sourceSelections = GetOrInitializeMixedSelections(conflictEmail);
                                        var incomingValues = GetIncomingConflictValues(conflictEmail);
                                        var existingValues = GetExistingConflictValues(conflictEmail);

                                        <div class="mt-3 border rounded p-2">
                                            <div class="small fw-semibold mb-2">Field-level merge (existing vs incoming)</div>
                                            <table class="table table-sm mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Field</th>
                                                        <th>Existing</th>
                                                        <th>Incoming</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var mapping in _fieldMappings)
                                                    {
                                                        if (mapping.MatchedCsvHeader is null && GetEffectiveMappingValue(mapping.Field.Name, mapping.MatchedCsvHeader) is null)
                                                        {
                                                            continue;
                                                        }

                                                        var fieldName = mapping.Field.Name;
                                                        var source = sourceSelections.GetValueOrDefault(fieldName, ConflictFieldSource.Existing);
                                                        var existingValue = existingValues.GetValueOrDefault(fieldName, "");
                                                        var incomingValue = incomingValues.GetValueOrDefault(fieldName, "");

                                                        <tr>
                                                            <td>@mapping.Field.DisplayName</td>
                                                            <td>
                                                                <button type="button"
                                                                        class="btn btn-sm @(source == ConflictFieldSource.Existing ? "btn-success" : "btn-outline-secondary")"
                                                                        data-action="field-existing"
                                                                        @onclick="@(() => SetFieldSource(conflictEmail, fieldName, ConflictFieldSource.Existing))">
                                                                    Existing: @existingValue
                                                                </button>
                                                            </td>
                                                            <td>
                                                                <button type="button"
                                                                        class="btn btn-sm @(source == ConflictFieldSource.Incoming ? "btn-primary" : "btn-outline-secondary")"
                                                                        data-action="field-incoming"
                                                                        @onclick="@(() => SetFieldSource(conflictEmail, fieldName, ConflictFieldSource.Incoming))">
                                                                    Incoming: @incomingValue
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary"
                            data-action="confirm-import"
                            @onclick="HandleCommitWithResolutions"
                            disabled="@(_conflictDecisions.Count < _conflicts.Count || _uploading)">
                        @if (_uploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-check-lg"></i> Confirm Import
                    </button>
                    <button class="btn btn-outline-secondary"
                            @onclick="@(() => _step = PageStep.Preview)"
                            disabled="@_uploading">
                        <i class="bi bi-arrow-left"></i> Back to Preview
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="border border-2 rounded-3 p-5 text-center position-relative @(_dragging > 0 ? "border-primary bg-primary bg-opacity-10" : "border-secondary")"
                     style="border-style: dashed !important;"
                     @ondragenter="@(() => _dragging++)"
                     @ondragleave="@(() => _dragging--)">
                    <i class="bi bi-file-earmark-arrow-up fs-1 text-muted d-block mb-2"></i>
                    <p class="mb-1 fw-semibold">Drop a CSV file here</p>
                    <p class="text-muted small mb-0">or click to browse &mdash; max 5 MB</p>
                    <InputFile OnChange="OnFileSelected"
                               accept=".csv"
                               class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                               style="cursor: pointer;" />
                </div>

                @if (_validationError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="bi bi-exclamation-circle"></i> @_validationError
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private enum PageStep { FileSelection, HeaderMapping, Preview, DuplicateResolution }
    private enum ConflictFieldSource { Existing, Incoming }
    private sealed record ImportSummaryCounts(int CreatedCount, int UpdatedCount, int SkippedCount, int FailedCount);
    private sealed record MixedConflictRow(
        string[] Values,
        Dictionary<string, ConflictFieldSource> FieldSelections,
        Dictionary<string, string> ExistingValues);

    private const long MaxFileSizeBytes = 5 * 1024 * 1024;
    private const int MaxPreviewRows = 5;

    // File selection
    private int _dragging;
    private string? _validationError;
    private PageStep _step = PageStep.FileSelection;

    // Header mapping
    private string _pendingFileName = "";
    private byte[] _pendingFileBytes = [];
    private IReadOnlyList<string> _csvHeaders = [];
    private IReadOnlyList<CustomerImportFieldMapping> _fieldMappings = [];
    private Dictionary<string, string?> _userMappings = new();
    private bool _uploading;
    private IReadOnlyList<IReadOnlyDictionary<string, string>> _previewRows = [];

    // Result
    private string? _error;
    private ImportResultDto? _result;
    private IReadOnlyList<ImportConflictDto> _conflicts = [];
    private Dictionary<string, string> _conflictDecisions = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, Dictionary<string, string>> _incomingConflictValuesByEmail = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, Dictionary<string, string>> _existingConflictValuesByEmail = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, Dictionary<string, ConflictFieldSource>> _mixedFieldSelectionsByEmail = new(StringComparer.OrdinalIgnoreCase);

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _dragging = 0;
        _validationError = null;

        var file = e.File;

        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            _validationError = "Only CSV files are supported (.csv).";
            return;
        }

        if (file.Size > MaxFileSizeBytes)
        {
            _validationError = $"File is too large ({file.Size / 1024 / 1024} MB). Maximum allowed size is 5 MB.";
            return;
        }

        using var ms = new MemoryStream();
        await using var stream = file.OpenReadStream(MaxFileSizeBytes);
        await stream.CopyToAsync(ms);
        _pendingFileBytes = ms.ToArray();
        _pendingFileName = file.Name;

        var text = Encoding.UTF8.GetString(_pendingFileBytes, 0, Math.Min(4096, _pendingFileBytes.Length));
        var firstLine = text
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
            .FirstOrDefault() ?? "";
        _csvHeaders = firstLine.Split(',')
            .Select(h => h.Trim().Trim('"'))
            .ToList()
            .AsReadOnly();

        _fieldMappings = CustomerImportHeaderMatcher.AutoMatch(_csvHeaders);
        _userMappings = new Dictionary<string, string?>();
        _step = PageStep.HeaderMapping;
    }

    private void OnFieldMapped(string fieldName, string? csvHeader) =>
        _userMappings[fieldName] = string.IsNullOrEmpty(csvHeader) ? null : csvHeader;

    private string? GetEffectiveMappingValue(string fieldName, string? autoMatchedHeader)
    {
        return _userMappings.GetValueOrDefault(fieldName, autoMatchedHeader);
    }

    private bool AllRequiredFieldsMapped(string fieldName) =>
        _fieldMappings.First(m => m.Field.Name == fieldName) is var mapping
        && (GetEffectiveMappingValue(fieldName, mapping.MatchedCsvHeader) is not null);

    private bool AllRequiredFieldsMapped() =>
        _fieldMappings
            .Where(m => m.Field.IsRequired)
            .All(m => GetEffectiveMappingValue(m.Field.Name, m.MatchedCsvHeader) is not null);

    private void ShowPreview()
    {
        _previewRows = BuildPreviewRows();
        _step = PageStep.Preview;
    }

    private IReadOnlyList<IReadOnlyDictionary<string, string>> BuildPreviewRows()
    {
        var text = Encoding.UTF8.GetString(_pendingFileBytes);
        var lines = text.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries);
        if (lines.Length < 2) return [];

        var fieldToColIndex = new Dictionary<string, int>(StringComparer.Ordinal);
        foreach (var mapping in _fieldMappings)
        {
            var csvCol = GetEffectiveMappingValue(mapping.Field.Name, mapping.MatchedCsvHeader);
            if (csvCol is null) continue;
            for (var i = 0; i < _csvHeaders.Count; i++)
            {
                if (string.Equals(_csvHeaders[i], csvCol, StringComparison.OrdinalIgnoreCase))
                {
                    fieldToColIndex[mapping.Field.Name] = i;
                    break;
                }
            }
        }

        var result = new List<IReadOnlyDictionary<string, string>>();
        foreach (var line in lines.Skip(1).Take(MaxPreviewRows))
        {
            var values = line.Split(',');
            var row = new Dictionary<string, string>(StringComparer.Ordinal);
            foreach (var (fieldName, colIdx) in fieldToColIndex)
                row[fieldName] = colIdx < values.Length ? values[colIdx].Trim().Trim('"') : "";
            result.Add(row);
        }
        return result.AsReadOnly();
    }

    private async Task HandleImport()
    {
        if (!AllRequiredFieldsMapped())
        {
            _validationError = "All required fields must be mapped before importing.";
            return;
        }

        _uploading = true;
        _validationError = null;

        try
        {
            var fileBytes = CustomerImportHeaderMatcher.ApplyMapping(
                _pendingFileBytes,
                _fieldMappings,
                _userMappings);
            var result = await CustomersApi.ImportCustomers(fileBytes, _pendingFileName, CancellationToken.None);
            if (result.Conflicts is { Count: > 0 } conflicts)
            {
                _conflicts = conflicts;
                await InitializeConflictResolutionData(conflicts, fileBytes);
                _step = PageStep.DuplicateResolution;
            }
            else
            {
                _result = result;
            }
        }
        catch (Exception)
        {
            _error = UserFacingErrorMessage.ForOperation("import the customers");
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task HandleCommitWithResolutions()
    {
        _uploading = true;
        _validationError = null;

        try
        {
            var fileBytes = CustomerImportHeaderMatcher.ApplyMapping(
                _pendingFileBytes,
                _fieldMappings,
                _userMappings);

            var hasMixedDecision = _conflictDecisions.Values.Any(v => v.Equals("mixed", StringComparison.OrdinalIgnoreCase));
            if (hasMixedDecision)
            {
                fileBytes = ApplyMixedFieldSelections(fileBytes);
            }

            _result = await CustomersApi.CommitImportWithResolutions(
                fileBytes, _pendingFileName, _conflictDecisions, CancellationToken.None);
        }
        catch (Exception)
        {
            _error = UserFacingErrorMessage.ForOperation("complete the customer import");
        }
        finally
        {
            _uploading = false;
        }
    }

    private void Reset()
    {
        _result = null;
        _error = null;
        _validationError = null;
        _conflicts = [];
        _conflictDecisions = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        _incomingConflictValuesByEmail = new Dictionary<string, Dictionary<string, string>>(StringComparer.OrdinalIgnoreCase);
        _existingConflictValuesByEmail = new Dictionary<string, Dictionary<string, string>>(StringComparer.OrdinalIgnoreCase);
        _mixedFieldSelectionsByEmail = new Dictionary<string, Dictionary<string, ConflictFieldSource>>(StringComparer.OrdinalIgnoreCase);
        _pendingFileName = "";
        _pendingFileBytes = [];
        _csvHeaders = [];
        _fieldMappings = [];
        _userMappings = new Dictionary<string, string?>();
        _previewRows = [];
        _uploading = false;
        _step = PageStep.FileSelection;
    }

    private void RetryWithCurrentFile()
    {
        _result = null;
        _error = null;
        _validationError = null;
        _conflicts = [];
        _conflictDecisions = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        _incomingConflictValuesByEmail = new Dictionary<string, Dictionary<string, string>>(StringComparer.OrdinalIgnoreCase);
        _existingConflictValuesByEmail = new Dictionary<string, Dictionary<string, string>>(StringComparer.OrdinalIgnoreCase);
        _mixedFieldSelectionsByEmail = new Dictionary<string, Dictionary<string, ConflictFieldSource>>(StringComparer.OrdinalIgnoreCase);
        _uploading = false;

        _step = _pendingFileBytes.Length > 0
            ? PageStep.HeaderMapping
            : PageStep.FileSelection;
    }

    private void SetConflictDecision(string email, string decision)
    {
        _conflictDecisions[email] = decision;
        if (decision.Equals("mixed", StringComparison.OrdinalIgnoreCase))
        {
            _ = GetOrInitializeMixedSelections(email);
        }
    }

    private Dictionary<string, ConflictFieldSource> GetOrInitializeMixedSelections(string email)
    {
        if (_mixedFieldSelectionsByEmail.TryGetValue(email, out var existing))
        {
            return existing;
        }

        var selections = new Dictionary<string, ConflictFieldSource>(StringComparer.OrdinalIgnoreCase);
        foreach (var mapping in _fieldMappings)
        {
            var fieldName = mapping.Field.Name;
            var hasExisting = GetExistingConflictValues(email).ContainsKey(fieldName);
            selections[fieldName] = hasExisting ? ConflictFieldSource.Existing : ConflictFieldSource.Incoming;
        }

        _mixedFieldSelectionsByEmail[email] = selections;
        return selections;
    }

    private void SetFieldSource(string email, string fieldName, ConflictFieldSource source)
    {
        var selections = GetOrInitializeMixedSelections(email);
        selections[fieldName] = source;
    }

    private Dictionary<string, string> GetIncomingConflictValues(string email) =>
        _incomingConflictValuesByEmail.GetValueOrDefault(email) ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    private Dictionary<string, string> GetExistingConflictValues(string email) =>
        _existingConflictValuesByEmail.GetValueOrDefault(email) ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    private async Task InitializeConflictResolutionData(IReadOnlyList<ImportConflictDto> conflicts, byte[] mappedFileBytes)
    {
        _incomingConflictValuesByEmail = ParseMappedRowsByEmail(mappedFileBytes);
        _existingConflictValuesByEmail = await LoadExistingConflictValuesByEmail(conflicts);
        _mixedFieldSelectionsByEmail = new Dictionary<string, Dictionary<string, ConflictFieldSource>>(StringComparer.OrdinalIgnoreCase);
    }

    private async Task<Dictionary<string, Dictionary<string, string>>> LoadExistingConflictValuesByEmail(IReadOnlyList<ImportConflictDto> conflicts)
    {
        var result = new Dictionary<string, Dictionary<string, string>>(StringComparer.OrdinalIgnoreCase);
        var customers = await CustomersApi.GetCustomers(CancellationToken.None);

        foreach (var conflictEmail in conflicts.Select(conflict => conflict.Email))
        {
            var existingSummary = customers.FirstOrDefault(customer => customer.Email.Equals(conflictEmail, StringComparison.OrdinalIgnoreCase));
            if (existingSummary is null)
            {
                continue;
            }

            var details = await CustomersApi.GetCustomerById(existingSummary.Id, CancellationToken.None);
            if (details is null)
            {
                continue;
            }

            result[conflictEmail] = MapCustomerDetailsToFieldValues(details);
        }

        return result;
    }

    private static Dictionary<string, string> MapCustomerDetailsToFieldValues(CustomerDetailsDto details)
    {
        return new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["FirstName"] = details.PersonalInfo.FirstName,
            ["LastName"] = details.PersonalInfo.LastName,
            ["Gender"] = details.PersonalInfo.Gender,
            ["BirthDate"] = details.PersonalInfo.BirthDate.ToString("yyyy-MM-dd"),
            ["Nationality"] = details.PersonalInfo.Nationality,
            ["Occupation"] = details.PersonalInfo.Occupation,
            ["NationalId"] = details.IdentificationInfo.NationalId,
            ["IdNationality"] = details.IdentificationInfo.IdNationality,
            ["Email"] = details.ContactInfo.Email,
            ["Mobile"] = details.ContactInfo.Mobile,
            ["Instagram"] = details.ContactInfo.Instagram ?? string.Empty,
            ["Facebook"] = details.ContactInfo.Facebook ?? string.Empty,
            ["Street"] = details.Address.Street,
            ["Complement"] = details.Address.Complement ?? string.Empty,
            ["Neighborhood"] = details.Address.Neighborhood ?? string.Empty,
            ["PostalCode"] = details.Address.PostalCode,
            ["City"] = details.Address.City,
            ["State"] = details.Address.State,
            ["Country"] = details.Address.Country,
            ["WeightKg"] = details.PhysicalInfo.WeightKg.ToString(CultureInfo.InvariantCulture),
            ["HeightCentimeters"] = details.PhysicalInfo.HeightCentimeters.ToString(CultureInfo.InvariantCulture),
            ["BikeType"] = details.PhysicalInfo.BikeType.ToString(),
            ["RoomType"] = details.AccommodationPreferences.RoomType.ToString(),
            ["BedType"] = details.AccommodationPreferences.BedType.ToString(),
            ["CompanionId"] = details.AccommodationPreferences.CompanionId?.ToString() ?? string.Empty,
            ["EmergencyContactName"] = details.EmergencyContact.Name,
            ["EmergencyContactMobile"] = details.EmergencyContact.Mobile,
            ["Allergies"] = details.MedicalInfo.Allergies ?? string.Empty,
            ["AdditionalInfo"] = details.MedicalInfo.AdditionalInfo ?? string.Empty,
        };
    }

    private static Dictionary<string, Dictionary<string, string>> ParseMappedRowsByEmail(byte[] mappedFileBytes)
    {
        var text = Encoding.UTF8.GetString(mappedFileBytes);
        var lines = text.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries);
        if (lines.Length < 2)
        {
            return new Dictionary<string, Dictionary<string, string>>(StringComparer.OrdinalIgnoreCase);
        }

        var headers = lines[0].Split(',').Select(h => h.Trim().Trim('"')).ToArray();
        var emailIndex = Array.FindIndex(headers, h => h.Equals("Email", StringComparison.OrdinalIgnoreCase));
        if (emailIndex < 0)
        {
            return new Dictionary<string, Dictionary<string, string>>(StringComparer.OrdinalIgnoreCase);
        }

        var result = new Dictionary<string, Dictionary<string, string>>(StringComparer.OrdinalIgnoreCase);
        foreach (var line in lines.Skip(1))
        {
            var values = line.Split(',').Select(v => v.Trim().Trim('"')).ToArray();
            if (emailIndex >= values.Length)
            {
                continue;
            }

            var email = values[emailIndex];
            if (string.IsNullOrWhiteSpace(email))
            {
                continue;
            }

            var rowValues = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            for (var i = 0; i < headers.Length; i++)
            {
                rowValues[headers[i]] = i < values.Length ? values[i] : string.Empty;
            }

            result[email] = rowValues;
        }

        return result;
    }

    private byte[] ApplyMixedFieldSelections(byte[] mappedFileBytes)
    {
        var text = Encoding.UTF8.GetString(mappedFileBytes);
        var lines = text.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries);
        if (lines.Length < 2)
        {
            return mappedFileBytes;
        }

        var headers = lines[0].Split(',').Select(h => h.Trim().Trim('"')).ToArray();
        var headerIndexes = headers
            .Select((name, index) => new { name, index })
            .ToDictionary(x => x.name, x => x.index, StringComparer.OrdinalIgnoreCase);

        if (!headerIndexes.TryGetValue("Email", out var emailIndex))
        {
            return mappedFileBytes;
        }

        var outputLines = new List<string>(lines.Length) { lines[0] };
        foreach (var line in lines.Skip(1))
        {
            var values = line.Split(',').Select(v => v.Trim().Trim('"')).ToArray();
            if (!TryGetMixedConflictRow(values, emailIndex, out var conflictRow))
            {
                outputLines.Add(line);
                continue;
            }

            var mergedValues = BuildMergedValues(headers, headerIndexes, conflictRow);

            outputLines.Add(string.Join(",", mergedValues.Select(EscapeCsvValue)));
        }

        return Encoding.UTF8.GetBytes(string.Join("\n", outputLines));
    }

    private bool TryGetMixedConflictRow(string[] values, int emailIndex, out MixedConflictRow conflictRow)
    {
        conflictRow = null!;

        if (emailIndex >= values.Length)
        {
            return false;
        }

        var email = values[emailIndex];
        if (!_conflictDecisions.TryGetValue(email, out var decision)
            || !decision.Equals("mixed", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!_mixedFieldSelectionsByEmail.TryGetValue(email, out var fieldSelections)
            || !_existingConflictValuesByEmail.TryGetValue(email, out var existingValues))
        {
            return false;
        }

        conflictRow = new MixedConflictRow(values, fieldSelections, existingValues);
        return true;
    }

    private static string[] BuildMergedValues(
        IReadOnlyList<string> headers,
        IReadOnlyDictionary<string, int> headerIndexes,
        MixedConflictRow conflictRow)
    {
        var mergedValues = headers.Select((_, i) => i < conflictRow.Values.Length ? conflictRow.Values[i] : string.Empty).ToArray();

        foreach (var (fieldName, source) in conflictRow.FieldSelections)
        {
            if (source != ConflictFieldSource.Existing)
            {
                continue;
            }

            if (!headerIndexes.TryGetValue(fieldName, out var fieldIndex))
            {
                continue;
            }

            if (!conflictRow.ExistingValues.TryGetValue(fieldName, out var existingValue))
            {
                continue;
            }

            mergedValues[fieldIndex] = existingValue;
        }

        return mergedValues;
    }

    private static string EscapeCsvValue(string value)
    {
        var normalized = value;
        if (!normalized.Contains(',') && !normalized.Contains('"') && !normalized.Contains('\n') && !normalized.Contains('\r'))
        {
            return normalized;
        }

        return $"\"{normalized.Replace("\"", "\"\"")}";
    }

    private ImportSummaryCounts BuildImportSummary()
    {
        if (_result is null)
        {
            return new ImportSummaryCounts(0, 0, 0, 0);
        }

        var skippedCount = _conflictDecisions.Values.Count(v =>
            v.Equals("keep", StringComparison.OrdinalIgnoreCase));
        var updatedCount = _conflictDecisions.Values.Count(v =>
            v.Equals("overwrite", StringComparison.OrdinalIgnoreCase)
            || v.Equals("mixed", StringComparison.OrdinalIgnoreCase));
        var createdCount = Math.Max(0, _result.SuccessCount - updatedCount);

        return new ImportSummaryCounts(
            createdCount,
            updatedCount,
            skippedCount,
            _result.ErrorCount);
    }

    private static string? BuildErrorReportDataUri(IReadOnlyList<ImportErrorRowDto> errorRows)
    {
        if (errorRows.Count == 0)
        {
            return null;
        }

        var sb = new StringBuilder();
        sb.AppendLine("LineNumber,Field,Message,Email");
        foreach (var row in errorRows)
        {
            sb.Append(row.LineNumber)
                .Append(',')
                .Append(EscapeCsvValue(row.Field ?? string.Empty))
                .Append(',')
                .Append(EscapeCsvValue(row.Message))
                .Append(',')
                .Append(EscapeCsvValue(row.Email ?? string.Empty))
                .AppendLine();
        }

        return "data:text/csv;charset=utf-8," + Uri.EscapeDataString(sb.ToString());
    }
}
