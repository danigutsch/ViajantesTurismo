@page "/customers/import"
@using System.Text
@using ViajantesTurismo.Admin.Contracts
@using ViajantesTurismo.Admin.Web.Helpers
@using ViajantesTurismo.Admin.Web.Services
@rendermode InteractiveServer

@inject ICustomersApiClient CustomersApi

<PageTitle>Import Customers</PageTitle>

<div class="container mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <h1 class="mb-0"><i class="bi bi-upload"></i> Import Customers</h1>
        <NavLink href="/customers" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Customers
        </NavLink>
    </div>

    <p class="text-muted">Upload a CSV file to bulk-import customers. The file must include the required columns.</p>

    @if (_state.Result is not null)
    {
        var summary = ImportCustomersCsvProcessor.BuildImportSummary(_state.Result, _state.ConflictStates);
        var successRows = _state.Result.SuccessRows ?? [];
        var errorRows = _state.Result.ErrorRows ?? [];
        var errorReportDataUri = ImportCustomersCsvProcessor.BuildErrorReportDataUri(errorRows);

        <div class="alert @(_state.Result.ErrorCount == 0 ? "alert-success" : "alert-warning") d-flex align-items-start gap-3">
            <i class="bi @(_state.Result.ErrorCount == 0 ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") fs-4"></i>
            <div>
                <strong>Import complete.</strong>
                <ul class="mb-0 mt-1">
                    <li>@_state.Result.SuccessCount customer(s) imported successfully.</li>
                    @if (_state.Result.ErrorCount > 0)
                    {
                        <li>@_state.Result.ErrorCount row(s) could not be imported due to errors.</li>
                    }
                </ul>
                <ul class="mb-0 mt-2" data-testid="import-summary-counts">
                    <li>Created: @summary.CreatedCount</li>
                    <li>Updated: @summary.UpdatedCount</li>
                    <li>Skipped: @summary.SkippedCount</li>
                    <li>Failed: @summary.FailedCount</li>
                </ul>

                @if (successRows.Count > 0)
                {
                    <div class="mt-3" data-testid="summary-success-rows">
                        <div class="fw-semibold mb-2">Successful rows</div>
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Outcome</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in successRows)
                                {
                                    <tr>
                                        <td>@row.Email</td>
                                        <td>@row.Outcome</td>
                                        <td>
                                            @if (row.CustomerId.HasValue)
                                            {
                                                <NavLink href="@($"/customers/{row.CustomerId.Value}")"
                                                         data-action="view-customer"
                                                         class="btn btn-sm btn-outline-primary">
                                                    View customer
                                                </NavLink>
                                            }
                                            else
                                            {
                                                <span class="text-muted" data-action="customer-id-unavailable">ID unavailable</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (errorRows.Count > 0)
                {
                    <div class="mt-3" data-testid="summary-error-rows">
                        <div class="fw-semibold mb-2">Failed rows</div>
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Line</th>
                                    <th>Field</th>
                                    <th>Message</th>
                                    <th>Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in errorRows)
                                {
                                    <tr>
                                        <td>@row.LineNumber</td>
                                        <td>@(row.Field ?? "-")</td>
                                        <td>@row.Message</td>
                                        <td>@(row.Email ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (errorReportDataUri is not null)
                        {
                            <a href="@errorReportDataUri"
                               download="import-errors.csv"
                               class="btn btn-sm btn-outline-danger mt-2"
                               data-action="download-error-report">
                                Download error report
                            </a>
                        }
                    </div>
                }

                <div class="mt-2 d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="Reset">Import another file</button>
                    @if (_state.PendingFileBytes.Length > 0)
                    {
                        <button class="btn btn-sm btn-outline-secondary"
                                data-action="retry-current-file"
                                @onclick="RetryWithCurrentFile">
                            Retry with current file
                        </button>
                    }
                    <NavLink href="/customers" class="btn btn-sm btn-primary">View customers</NavLink>
                </div>
            </div>
        </div>
    }
    else if (_state.Error is not null)
    {
        <div class="alert alert-danger d-flex align-items-start gap-3">
            <i class="bi bi-x-circle-fill fs-4"></i>
            <div>
                <strong>Import failed.</strong> @_state.Error
                <div class="mt-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="Reset">Try again</button>
                </div>
            </div>
        </div>
    }
    else if (_state.Step == ImportCustomersWorkflowStep.HeaderMapping)
    {
        var unmatchedRequired = _state.FieldMappings
            .Where(m => m.Field.IsRequired && !AllRequiredFieldsMapped(m.Field.Name))
            .ToArray();
        var allRequiredMatched = unmatchedRequired.Length == 0;

        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-text"></i>
                <strong>@_state.PendingFileName</strong>
                <span class="badge bg-secondary">@_state.CsvHeaders.Count column(s) detected</span>
            </div>
            <div class="card-body">
                @if (allRequiredMatched)
                {
                    <div class="alert alert-success d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-check-circle-fill fs-5"></i>
                        <span>All required columns were automatically matched.</span>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                        <span>@unmatchedRequired.Length required column(s) could not be matched. Please assign them below.</span>
                    </div>
                }

                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Field</th>
                            <th></th>
                            <th>Source Column (CSV)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mapping in _state.FieldMappings)
                        {
                            var fieldName = mapping.Field.Name;
                            var effective = GetEffectiveMappingValue(fieldName, mapping.MatchedCsvHeader);
                            <tr>
                                <td>@mapping.Field.DisplayName</td>
                                <td>
                                    @if (mapping.Field.IsRequired)
                                    {
                                        <span class="badge bg-danger">Required</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Optional</span>
                                    }
                                </td>
                                <td>
                                    <select class="form-select form-select-sm"
                                            data-field="@fieldName"
                                            @onchange="@(e => OnFieldMapped(fieldName, e.Value?.ToString()))">
                                        <option value="">(none)</option>
                                        @foreach (var header in _state.CsvHeaders)
                                        {
                                            <option value="@header" selected="@(header == effective)">@header</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (_state.ValidationError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="bi bi-exclamation-circle"></i> @_state.ValidationError
                    </div>
                }

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary"
                            @onclick="ShowPreview"
                            disabled="@(!AllRequiredFieldsMapped() || _state.Uploading)">
                        <i class="bi bi-eye"></i> Preview
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="Reset" disabled="@_state.Uploading">
                        <i class="bi bi-arrow-left"></i> Choose different file
                    </button>
                </div>
            </div>
        </div>
    }
    else if (_state.Step == ImportCustomersWorkflowStep.Preview)
    {
        var mappedFields = _state.FieldMappings
            .Where(mapping => GetEffectiveMappingValue(mapping.Field.Name, mapping.MatchedCsvHeader) is not null)
            .Select(mapping => mapping.Field)
            .ToList();

        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-table"></i>
                <strong>@_state.PendingFileName</strong>
                <span class="badge bg-secondary">@_state.PreviewRows.Count of max @MaxPreviewRows row(s) shown</span>
            </div>
            <div class="card-body">
                <p class="text-muted small">Review the extracted data below. Rows with missing required values are highlighted.</p>

                <div class="table-responsive">
                    <table class="table table-sm preview-table">
                        <thead>
                            <tr>
                                @foreach (var field in mappedFields)
                                {
                                    <th>
                                        @field.DisplayName
                                        @if (field.IsRequired)
                                        {
                                            <span class="text-danger ms-1">*</span>
                                        }
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _state.PreviewRows)
                            {
                                var hasWarning = mappedFields
                                    .Where(field => field.IsRequired)
                                    .Any(field => !row.TryGetValue(field.Name, out var value) || string.IsNullOrEmpty(value));
                                <tr class="@(hasWarning ? "table-warning" : "")">
                                    @foreach (var mapping in mappedFields)
                                    {
                                        <td>@row.GetValueOrDefault(mapping.Name, "")</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (_state.ValidationError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="bi bi-exclamation-circle"></i> @_state.ValidationError
                    </div>
                }

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary"
                            @onclick="HandleImport"
                            disabled="@_state.Uploading">
                        @if (_state.Uploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-check-lg"></i> Confirm Import
                    </button>
                    <button class="btn btn-outline-secondary"
                            @onclick="@(() => _state.Step = ImportCustomersWorkflowStep.HeaderMapping)"
                            disabled="@_state.Uploading">
                        <i class="bi bi-arrow-left"></i> Back to Mapping
                    </button>
                </div>
            </div>
        </div>
    }
    else if (_state.Step == ImportCustomersWorkflowStep.DuplicateResolution)
    {
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-exclamation-circle"></i> Resolve Duplicates</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">The following @_state.ConflictStates.Count email(s) already exist in the database. Choose how to handle each conflict before completing the import.</p>
                <table class="table table-sm duplicate-resolution-table">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Decision</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var conflictState in _state.ConflictStates)
                        {
                            var conflictEmail = conflictState.Email;
                            var decision = conflictState.Decision;
                            <tr>
                                <td>@conflictEmail.ToLowerInvariant()</td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button"
                                                class="btn @(decision == "keep" ? "btn-success" : "btn-outline-secondary")"
                                                data-action="keep"
                                                @onclick="@(() => SetConflictDecision(conflictState, "keep"))">
                                            Keep existing
                                        </button>
                                        <button type="button"
                                                class="btn @(decision == "overwrite" ? "btn-warning" : "btn-outline-secondary")"
                                                data-action="overwrite"
                                                @onclick="@(() => SetConflictDecision(conflictState, "overwrite"))">
                                            Overwrite
                                        </button>
                                        <button type="button"
                                                class="btn @(decision == "mixed" ? "btn-info" : "btn-outline-secondary")"
                                                data-action="mixed"
                                                @onclick="@(() => SetConflictDecision(conflictState, "mixed"))">
                                            Mixed merge
                                        </button>
                                    </div>

                                    @if (decision == "mixed")
                                    {
                                        conflictState.EnsureMixedSelections(_state.FieldMappings);
                                        var sourceSelections = conflictState.FieldSelections;

                                        <div class="mt-3 border rounded p-2">
                                            <div class="small fw-semibold mb-2">Field-level merge (existing vs incoming)</div>
                                            <table class="table table-sm mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Field</th>
                                                        <th>Existing</th>
                                                        <th>Incoming</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var mapping in _state.FieldMappings)
                                                    {
                                                        if (mapping.MatchedCsvHeader is null && GetEffectiveMappingValue(mapping.Field.Name, mapping.MatchedCsvHeader) is null)
                                                        {
                                                            continue;
                                                        }

                                                        var fieldName = mapping.Field.Name;
                                                        var source = sourceSelections.GetValueOrDefault(fieldName, ImportConflictFieldSource.Existing);
                                                        var existingValue = conflictState.GetExistingValue(fieldName);
                                                        var incomingValue = conflictState.GetIncomingValue(fieldName);

                                                        <tr>
                                                            <td>@mapping.Field.DisplayName</td>
                                                            <td>
                                                                <button type="button"
                                                                        class="btn btn-sm @(source == ImportConflictFieldSource.Existing ? "btn-success" : "btn-outline-secondary")"
                                                                        data-action="field-existing"
                                                                        @onclick="@(() => SetFieldSource(conflictState, fieldName, ImportConflictFieldSource.Existing))">
                                                                    Existing: @existingValue
                                                                </button>
                                                            </td>
                                                            <td>
                                                                <button type="button"
                                                                        class="btn btn-sm @(source == ImportConflictFieldSource.Incoming ? "btn-primary" : "btn-outline-secondary")"
                                                                        data-action="field-incoming"
                                                                        @onclick="@(() => SetFieldSource(conflictState, fieldName, ImportConflictFieldSource.Incoming))">
                                                                    Incoming: @incomingValue
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary"
                            data-action="confirm-import"
                            @onclick="HandleCommitWithResolutions"
                            disabled="@(_state.ConflictStates.Count == 0 || _state.ConflictStates.Any(state => !state.IsResolved) || _state.Uploading)">
                        @if (_state.Uploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-check-lg"></i> Confirm Import
                    </button>
                    <button class="btn btn-outline-secondary"
                            @onclick="@(() => _state.Step = ImportCustomersWorkflowStep.Preview)"
                            disabled="@_state.Uploading">
                        <i class="bi bi-arrow-left"></i> Back to Preview
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                 <div class="border border-2 rounded-3 p-5 text-center position-relative @(_state.Dragging > 0 ? "border-primary bg-primary bg-opacity-10" : "border-secondary")"
                     style="border-style: dashed !important;"
                     @ondragenter="@(() => _state.Dragging++)"
                     @ondragleave="@(() => _state.Dragging--)">
                    <i class="bi bi-file-earmark-arrow-up fs-1 text-muted d-block mb-2"></i>
                    <p class="mb-1 fw-semibold">Drop a CSV file here</p>
                    <p class="text-muted small mb-0">or click to browse &mdash; max 5 MB</p>
                    <InputFile OnChange="OnFileSelected"
                               accept=".csv"
                               class="position-absolute top-0 start-0 w-100 h-100 opacity-0"
                               style="cursor: pointer;" />
                </div>

                @if (_state.ValidationError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="bi bi-exclamation-circle"></i> @_state.ValidationError
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private const long MaxFileSizeBytes = 5 * 1024 * 1024;
    private const int MaxPreviewRows = 5;
    private readonly ImportCustomersWorkflowState _state = new();

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _state.Dragging = 0;
        _state.ValidationError = null;

        var file = e.File;
        if (!ValidateSelectedFile(file))
        {
            return;
        }

        var fileBytes = await ReadFileBytes(file);
        SetPendingFile(file.Name, fileBytes);
    }

    private void OnFieldMapped(string fieldName, string? csvHeader) =>
        _state.UserMappings[fieldName] = string.IsNullOrEmpty(csvHeader) ? null : csvHeader;

    private string? GetEffectiveMappingValue(string fieldName, string? autoMatchedHeader)
    {
        return _state.UserMappings.GetValueOrDefault(fieldName, autoMatchedHeader);
    }

    private bool AllRequiredFieldsMapped(string fieldName) =>
        _state.FieldMappings.First(m => m.Field.Name == fieldName) is var mapping
        && (GetEffectiveMappingValue(fieldName, mapping.MatchedCsvHeader) is not null);

    private bool AllRequiredFieldsMapped() =>
        _state.FieldMappings
            .Where(m => m.Field.IsRequired)
            .All(m => GetEffectiveMappingValue(m.Field.Name, m.MatchedCsvHeader) is not null);

    private void ShowPreview()
    {
        _state.PreviewRows = ImportCustomersCsvProcessor.BuildPreviewRows(
            _state.PendingFileBytes,
            _state.CsvHeaders,
            _state.FieldMappings,
            _state.UserMappings,
            MaxPreviewRows);
        _state.Step = ImportCustomersWorkflowStep.Preview;
    }

    private async Task HandleImport()
    {
        if (!AllRequiredFieldsMapped())
        {
            _state.ValidationError = "All required fields must be mapped before importing.";
            return;
        }

        BeginUpload();

        try
        {
            var fileBytes = ApplyCurrentMapping();
            var result = await CustomersApi.ImportCustomers(fileBytes, _state.PendingFileName, CancellationToken.None);
            if (result.Conflicts is { Count: > 0 } conflicts)
            {
                await InitializeConflictResolutionData(conflicts, fileBytes);
                _state.Step = ImportCustomersWorkflowStep.DuplicateResolution;
            }
            else
            {
                _state.Result = result;
            }
        }
        catch (Exception)
        {
            _state.Error = UserFacingErrorMessage.ForOperation("import the customers");
        }
        finally
        {
            EndUpload();
        }
    }

    private async Task HandleCommitWithResolutions()
    {
        BeginUpload();

        try
        {
            var fileBytes = ApplyCurrentMapping();

            var hasMixedDecision = _state.ConflictStates.Any(state => state.HasMixedDecision);
            if (hasMixedDecision)
            {
                fileBytes = ImportCustomersCsvProcessor.ApplyMixedFieldSelections(
                    fileBytes,
                    _state.ConflictStates);
            }

            var conflictDecisions = BuildConflictDecisions();
            _state.Result = await CustomersApi.CommitImportWithResolutions(
                fileBytes, _state.PendingFileName, conflictDecisions, CancellationToken.None);
        }
        catch (Exception)
        {
            _state.Error = UserFacingErrorMessage.ForOperation("complete the customer import");
        }
        finally
        {
            EndUpload();
        }
    }

    private void Reset()
    {
        _state.ResetToFileSelection();
    }

    private void RetryWithCurrentFile()
    {
        _state.RetryCurrentFile();
    }

    private bool ValidateSelectedFile(IBrowserFile file)
    {
        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            _state.ValidationError = "Only CSV files are supported (.csv).";
            return false;
        }

        if (file.Size > MaxFileSizeBytes)
        {
            _state.ValidationError = $"File is too large ({file.Size / 1024 / 1024} MB). Maximum allowed size is 5 MB.";
            return false;
        }

        return true;
    }

    private static async Task<byte[]> ReadFileBytes(IBrowserFile file)
    {
        using var ms = new MemoryStream();
        await using var stream = file.OpenReadStream(MaxFileSizeBytes);
        await stream.CopyToAsync(ms);
        return ms.ToArray();
    }

    private void SetPendingFile(string fileName, byte[] fileBytes)
    {
        var csvHeaders = ParseCsvHeaders(fileBytes);
        var fieldMappings = CustomerImportHeaderMatcher.AutoMatch(csvHeaders);
        _state.SetPendingFile(fileName, fileBytes, csvHeaders, fieldMappings);
    }

    private static IReadOnlyList<string> ParseCsvHeaders(byte[] fileBytes)
    {
        var text = Encoding.UTF8.GetString(fileBytes, 0, Math.Min(4096, fileBytes.Length));
        var firstLine = text
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
            .FirstOrDefault() ?? string.Empty;

        return firstLine.Split(',')
            .Select(header => header.Trim().Trim('"'))
            .ToList()
            .AsReadOnly();
    }

    private byte[] ApplyCurrentMapping() =>
        CustomerImportHeaderMatcher.ApplyMapping(
            _state.PendingFileBytes,
            _state.FieldMappings,
            _state.UserMappings);

    private Dictionary<string, string> BuildConflictDecisions() => _state.BuildConflictDecisions();

    private void BeginUpload()
    {
        _state.Uploading = true;
        _state.ValidationError = null;
    }

    private void EndUpload()
    {
        _state.Uploading = false;
    }

    private void SetConflictDecision(ImportCustomerConflictState conflictState, string decision)
    {
        conflictState.SetDecision(decision, _state.FieldMappings);
    }

    private static void SetFieldSource(ImportCustomerConflictState conflictState, string fieldName, ImportConflictFieldSource source)
    {
        conflictState.SetFieldSource(fieldName, source);
    }

    private async Task InitializeConflictResolutionData(IReadOnlyList<ImportConflictDto> conflicts, byte[] mappedFileBytes)
    {
        _state.ConflictStates = await ImportCustomersConflictLoader.LoadConflictStates(
            CustomersApi,
            conflicts,
            mappedFileBytes);
    }
}
