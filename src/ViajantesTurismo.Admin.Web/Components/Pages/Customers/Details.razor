@page "/customers/{id:int}"
@using ViajantesTurismo.AdminApi.Contracts
@rendermode InteractiveServer

@inject CustomersApiClient CustomersApi
@inject BookingsApiClient BookingsApi
@inject ToursApiClient ToursApi

<PageTitle>Customer Details</PageTitle>

<ConfirmDialog @ref="_confirmDialog" />
<ToastNotification @ref="_toast" />

@if (_customer == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="bi bi-person-circle"></i> Customer Details</h1>
            <div class="btn-group" role="group">
                <NavLink href="/customers" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Customers
                </NavLink>
                <NavLink href="@($"/customers/{Id}/edit")" class="btn btn-primary">
                    <i class="bi bi-pencil"></i> Edit Customer
                </NavLink>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-person"></i> Personal Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Full Name</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.FirstName @_customer.PersonalInfo.LastName</dd>

                            <dt class="col-sm-4">Date of Birth</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.BirthDate.ToString("dd/MM/yyyy")</dd>

                            <dt class="col-sm-4">Gender</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.Gender</dd>

                            <dt class="col-sm-4">Nationality</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.Nationality</dd>

                            <dt class="col-sm-4">Profession</dt>
                            <dd class="col-sm-8">@_customer.PersonalInfo.Profession</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-telephone"></i> Contact Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8"><a
                                        href="mailto:@_customer.ContactInfo.Email">@_customer.ContactInfo.Email</a></dd>

                            <dt class="col-sm-4">Mobile</dt>
                            <dd class="col-sm-8"><a
                                        href="tel:@_customer.ContactInfo.Mobile">@_customer.ContactInfo.Mobile</a></dd>

                            @if (!string.IsNullOrEmpty(_customer.ContactInfo.Instagram))
                            {
                                <dt class="col-sm-4">Instagram</dt>
                                <dd class="col-sm-8"><a href="https://instagram.com/@_customer.ContactInfo.Instagram"
                                                        target="_blank">@_customer.ContactInfo.Instagram</a></dd>
                            }

                            @if (!string.IsNullOrEmpty(_customer.ContactInfo.Facebook))
                            {
                                <dt class="col-sm-4">Facebook</dt>
                                <dd class="col-sm-8"><a href="https://facebook.com/@_customer.ContactInfo.Facebook"
                                                        target="_blank">@_customer.ContactInfo.Facebook</a></dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-card-text"></i> Identification</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">National ID</dt>
                            <dd class="col-sm-8">@_customer.IdentificationInfo.NationalId</dd>

                            <dt class="col-sm-4">ID Nationality</dt>
                            <dd class="col-sm-8">@_customer.IdentificationInfo.IdNationality</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-house"></i> Address</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Street</dt>
                            <dd class="col-sm-8">@_customer.Address.Street</dd>

                            @if (!string.IsNullOrEmpty(_customer.Address.Complement))
                            {
                                <dt class="col-sm-4">Complement</dt>
                                <dd class="col-sm-8">@_customer.Address.Complement</dd>
                            }

                            <dt class="col-sm-4">Neighborhood</dt>
                            <dd class="col-sm-8">@_customer.Address.Neighborhood</dd>

                            <dt class="col-sm-4">Postal Code</dt>
                            <dd class="col-sm-8">@_customer.Address.PostalCode</dd>

                            <dt class="col-sm-4">City</dt>
                            <dd class="col-sm-8">@_customer.Address.City</dd>

                            <dt class="col-sm-4">State</dt>
                            <dd class="col-sm-8">@_customer.Address.State</dd>

                            <dt class="col-sm-4">Country</dt>
                            <dd class="col-sm-8">@_customer.Address.Country</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-activity"></i> Physical Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Weight</dt>
                            <dd class="col-sm-8">@_customer.PhysicalInfo.WeightKg kg</dd>

                            <dt class="col-sm-4">Height</dt>
                            <dd class="col-sm-8">@_customer.PhysicalInfo.HeightCentimeters cm</dd>

                            <dt class="col-sm-4">Bike Type</dt>
                            <dd class="col-sm-8">@_customer.PhysicalInfo.BikeType</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-building"></i> Accommodation Preferences</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Room Type</dt>
                            <dd class="col-sm-8">@_customer.AccommodationPreferences.RoomType</dd>

                            <dt class="col-sm-4">Bed Type</dt>
                            <dd class="col-sm-8">@_customer.AccommodationPreferences.BedType</dd>

                            @if (_customer.AccommodationPreferences.CompanionId.HasValue)
                            {
                                <dt class="col-sm-4">Companion ID</dt>
                                <dd class="col-sm-8">@_customer.AccommodationPreferences.CompanionId</dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-exclamation-triangle"></i> Emergency Contact</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Name</dt>
                            <dd class="col-sm-8">@_customer.EmergencyContact.Name</dd>

                            <dt class="col-sm-4">Mobile</dt>
                            <dd class="col-sm-8"><a
                                        href="tel:@_customer.EmergencyContact.Mobile">@_customer.EmergencyContact.Mobile</a>
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-heart-pulse"></i> Medical Information</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(_customer.MedicalInfo.Allergies))
                        {
                            <dl class="row">
                                <dt class="col-sm-4">Allergies</dt>
                                <dd class="col-sm-8">@_customer.MedicalInfo.Allergies</dd>
                            </dl>
                        }

                        @if (!string.IsNullOrEmpty(_customer.MedicalInfo.AdditionalInfo))
                        {
                            <dl class="row">
                                <dt class="col-sm-4">Additional Info</dt>
                                <dd class="col-sm-8">@_customer.MedicalInfo.AdditionalInfo</dd>
                            </dl>
                        }

                        @if (string.IsNullOrEmpty(_customer.MedicalInfo.Allergies) && string.IsNullOrEmpty(_customer.MedicalInfo.AdditionalInfo))
                        {
                            <p class="text-muted mb-0">No medical information provided.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0"><i class="bi bi-calendar-check"></i> Bookings</h5>
                        <button class="btn btn-success" @onclick="ShowCreateBookingForm">
                            <i class="bi bi-plus-circle"></i> Add Booking
                        </button>
                    </div>
                    <div class="card-body">
                        @if (_loadingBookings)
                        {
                            <p><em>Loading bookings...</em></p>
                        }
                        else if (_showBookingForm)
                        {
                            <div class="border rounded p-3 mb-3">
                                <h5>@(_editingBookingId.HasValue ? "Edit Booking" : "Create New Booking")</h5>
                                <CustomerBookingForm TourId="@_bookingFormModel.TourId"
                                                     CompanionId="@_bookingFormModel.CompanionId"
                                                     Notes="@_bookingFormModel.Notes"
                                                     Status="@_bookingFormModel.Status"
                                                     PaymentStatus="@_bookingFormModel.PaymentStatus"
                                                     Tours="@_tours"
                                                     Customers="@_customers"
                                                     CurrentCustomerId="@Id"
                                                     OnValidSubmit="@HandleSaveBooking"
                                                     OnCancel="@(EventCallback.Factory.Create(this, HideBookingForm))"
                                                     SubmitButtonText="@(_editingBookingId.HasValue ? "Update Booking" : "Create Booking")"
                                                     IsSubmitting="@_isSubmitting"
                                                     IsEditMode="@_editingBookingId.HasValue" />
                            </div>
                        }
                        else
                        {
                            <BookingsList Bookings="_bookings"
                                          ShowCustomerInfo="false"
                                          OnEdit="HandleEditBooking"
                                          OnConfirm="HandleConfirmBooking"
                                          OnCancel="HandleCancelBooking"
                                          OnComplete="HandleCompleteBooking"
                                          OnDelete="HandleDeleteBooking" />
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {

    /// <summary>
    /// The ID of the customer to display details for.
    /// </summary>
    [Parameter]
    public int Id { get; set; }

    private CustomerDetailsDto? _customer;
    private GetBookingDto[]? _bookings;
    private bool _loadingBookings = true;
    private bool _showBookingForm;
    private long? _editingBookingId;

    private GetTourDto[] _tours = [];
    private GetCustomerDto[] _customers = [];
    private BookingFormModel _bookingFormModel = new();
    private bool _isSubmitting;

    private ConfirmDialog _confirmDialog = null!;
    private ToastNotification _toast = null!;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        _customer = await CustomersApi.GetCustomerById(Id);
        await Task.WhenAll(LoadBookings(), LoadTours(), LoadCustomers());
    }

    private async Task LoadBookings()
    {
        _loadingBookings = true;
        try
        {
            _bookings = await BookingsApi.GetBookingsByCustomerId(Id);
        }
        finally
        {
            _loadingBookings = false;
        }
    }

    private async Task LoadTours()
    {
        try
        {
            _tours = await ToursApi.GetTours(maxItems: 100);
        }
        catch (Exception)
        {
            _tours = [];
        }
    }

    private async Task LoadCustomers()
    {
        try
        {
            _customers = (await CustomersApi.GetCustomers(maxItems: 100)).ToArray();
        }
        catch (Exception)
        {
            _customers = [];
        }
    }

    private void ShowCreateBookingForm()
    {
        _editingBookingId = null;
        _bookingFormModel = new BookingFormModel();
        _showBookingForm = true;
    }

    private void ShowEditBookingForm(long bookingId)
    {
        var booking = _bookings?.FirstOrDefault(b => b.Id == bookingId);
        if (booking == null) return;

        _editingBookingId = bookingId;
        _bookingFormModel = new BookingFormModel
        {
            TourId = booking.TourId,
            CustomerId = booking.CustomerId,
            CompanionId = booking.CompanionId,
            Notes = booking.Notes,
            Status = booking.Status,
            PaymentStatus = booking.PaymentStatus
        };
        _showBookingForm = true;
    }

    private void HideBookingForm()
    {
        _showBookingForm = false;
        _editingBookingId = null;
    }

    private async Task HandleSaveBooking(BookingFormModel model)
    {
        _isSubmitting = true;
        try
        {
            if (_editingBookingId.HasValue)
            {
                var updateDto = new UpdateBookingDto
                {
                    Notes = model.Notes,
                    Status = model.Status,
                    PaymentStatus = model.PaymentStatus
                };

                await BookingsApi.UpdateBooking(_editingBookingId.Value, updateDto);
            }
            else
            {
                var createDto = new CreateBookingDto
                {
                    TourId = model.TourId!.Value,
                    CustomerId = Id,
                    CompanionId = model.CompanionId,
                    Notes = model.Notes
                };

                await BookingsApi.CreateBooking(createDto);
            }

            await LoadBookings();
            HideBookingForm();
            _toast.ShowSuccess(_editingBookingId.HasValue ? "Booking updated successfully." : "Booking created successfully.");
        }
        catch (Exception ex)
        {
            _toast.ShowError($"Failed to save booking: {ex.Message}");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task HandleEditBooking(long bookingId)
    {
        ShowEditBookingForm(bookingId);
        await Task.CompletedTask;
    }

    private async Task HandleConfirmBooking(long bookingId)
    {
        try
        {
            await BookingsApi.ConfirmBooking(bookingId);
            await LoadBookings();
            _toast.ShowSuccess("Booking confirmed successfully.");
        }
        catch (Exception ex)
        {
            _toast.ShowError($"Failed to confirm booking: {ex.Message}");
        }
    }

    private async Task HandleCancelBooking(long bookingId)
    {
        if (await _confirmDialog.ShowAsync("Are you sure you want to cancel this booking?", "Cancel Booking", "Yes, Cancel", "No", "btn-warning"))
        {
            try
            {
                await BookingsApi.CancelBooking(bookingId);
                await LoadBookings();
                _toast.ShowSuccess("Booking cancelled successfully.");
            }
            catch (Exception ex)
            {
                _toast.ShowError($"Failed to cancel booking: {ex.Message}");
            }
        }
    }

    private async Task HandleCompleteBooking(long bookingId)
    {
        try
        {
            await BookingsApi.CompleteBooking(bookingId);
            await LoadBookings();
            _toast.ShowSuccess("Booking completed successfully.");
        }
        catch (Exception ex)
        {
            _toast.ShowError($"Failed to complete booking: {ex.Message}");
        }
    }

    private async Task HandleDeleteBooking(long bookingId)
    {
        if (await _confirmDialog.ShowAsync("Are you sure you want to delete this booking? This action cannot be undone.", "Delete Booking", "Yes, Delete", "No", "btn-danger"))
        {
            try
            {
                await BookingsApi.DeleteBooking(bookingId);
                await LoadBookings();
                _toast.ShowSuccess("Booking deleted successfully.");
            }
            catch (Exception ex)
            {
                _toast.ShowError($"Failed to delete booking: {ex.Message}");
            }
        }
    }

}
