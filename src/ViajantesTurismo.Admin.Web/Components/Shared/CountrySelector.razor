@using ViajantesTurismo.Admin.Web.Services
@inherits InputBase<string>

<div class="position-relative">
    <button type="button" class="form-select text-start d-flex align-items-center" @onclick="ToggleDropdown">
        @if (!string.IsNullOrEmpty(Value) && _selectedCountry != null)
        {
            <span class="fi fi-@_selectedCountry.Code me-2"></span>
            <span>@_selectedCountry.Name</span>
        }
        else
        {
            <span class="text-muted">-- Select Country --</span>
        }
    </button>

    @if (_isOpen)
    {
        <div class="country-dropdown-menu">
            <input type="text"
                   class="form-control form-control-sm mb-2"
                   placeholder="Search countries..."
                   @bind="_searchText"
                   @bind:event="oninput"
                   @onclick:stopPropagation="true"/>

            <div class="country-dropdown-list">
                @foreach (var country in FilteredCountries)
                {
                    <div class="country-dropdown-item" @onclick="() => SelectCountry(country)">
                        <span class="fi fi-@country.Code me-2"></span>
                        <span>@country.Name</span>
                    </div>
                }

                @if (!FilteredCountries.Any())
                {
                    <div class="text-muted p-2">No countries found</div>
                }
            </div>
        </div>
    }
</div>

@code {

    [Parameter]
    public IReadOnlyList<CountryInfo>? Countries { get; set; }

    private bool _isOpen;
    private string _searchText = string.Empty;
    private CountryInfo? _selectedCountry;

    private IEnumerable<CountryInfo> FilteredCountries =>
        (Countries ?? [])
        .Where(country => string.IsNullOrEmpty(_searchText) ||
                          country.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        UpdateSelectedCountry();
    }

    private void UpdateSelectedCountry()
    {
        if (!string.IsNullOrEmpty(Value) && Countries != null)
        {
            _selectedCountry = Countries.FirstOrDefault(c => c.Name == Value);
        }
        else
        {
            _selectedCountry = null;
        }
    }

    private void ToggleDropdown()
    {
        _isOpen = !_isOpen;
        if (!_isOpen)
        {
            _searchText = string.Empty;
        }
    }

    private void SelectCountry(CountryInfo country)
    {
        CurrentValue = country.Name;
        _selectedCountry = country;
        _isOpen = false;
        _searchText = string.Empty;
    }

    protected override bool TryParseValueFromString(string? value, out string result, out string validationErrorMessage)
    {
        result = value ?? string.Empty;
        validationErrorMessage = string.Empty;
        return true;
    }

}

<style>
    .country-dropdown-menu {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1050;
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        margin-top: 0.25rem;
        padding: 0.5rem;
    }

    .country-dropdown-list {
        max-height: 300px;
        overflow-y: auto;
    }

    .country-dropdown-item {
        padding: 0.5rem;
        cursor: pointer;
        border-radius: 0.25rem;
        display: flex;
        align-items: center;
    }

    .country-dropdown-item:hover {
        background-color: #f8f9fa;
    }

    .fi {
        width: 20px;
        height: 15px;
        background-size: contain;
        background-position: center;
        background-repeat: no-repeat;
        display: inline-block;
        flex-shrink: 0;
    }
</style>
