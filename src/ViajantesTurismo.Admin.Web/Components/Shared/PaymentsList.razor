@using Microsoft.AspNetCore.Components.QuickGrid
@using ViajantesTurismo.Admin.Contracts
@using ViajantesTurismo.Admin.Web.Helpers
@if (!Payments.Any())
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i> No payments recorded yet.
    </div>
}
else
{
    <QuickGrid Items="@PaymentsByDateDescending" Class="table table-hover"
               Pagination="@(Payments.Count > 10 ? _pagination : null)">
        <PropertyColumn Property="@(p => p.PaymentDate)" Title="Payment Date" Format="dd/MM/yyyy" Sortable="true"/>

        <TemplateColumn Title="Amount" Sortable="true" SortBy="GridSort<GetPaymentDto>.ByAscending(p => p.Amount)">
            <strong>@CurrencyFormatter.Format(context.Amount, Currency)</strong>
        </TemplateColumn>

        <TemplateColumn Title="Method" Sortable="true" SortBy="GridSort<GetPaymentDto>.ByAscending(p => p.Method)">
            <span class="badge @GetMethodBadgeClass(context.Method)">
                @FormatPaymentMethod(context.Method)
            </span>
        </TemplateColumn>

        <TemplateColumn Title="Reference">
            @if (!string.IsNullOrWhiteSpace(context.ReferenceNumber))
            {
                <code class="small">@context.ReferenceNumber</code>
            }
            else
            {
                <span class="text-muted">-</span>
            }
        </TemplateColumn>

        <TemplateColumn Title="Notes">
            @if (!string.IsNullOrWhiteSpace(context.Notes))
            {
                <span title="@context.Notes">
                    @TruncateNotes(context.Notes, 30)
                </span>
            }
            else
            {
                <span class="text-muted">-</span>
            }
        </TemplateColumn>

        <TemplateColumn Title="Recorded At" Sortable="true"
                        SortBy="GridSort<GetPaymentDto>.ByAscending(p => p.RecordedAt)">
            <small class="text-muted" title="@context.RecordedAt.ToLocalTime().ToString("g")">
                @FormatRecordedAt(context.RecordedAt)
            </small>
        </TemplateColumn>
    </QuickGrid>

    <div class="mt-3 p-3 bg-light rounded">
        <strong>Total Paid:</strong> <strong class="ms-2">@CurrencyFormatter.Format(TotalPaid, Currency)</strong>
    </div>
}

@code {
    private readonly PaginationState _pagination = new() { ItemsPerPage = 10 };

    [Parameter, EditorRequired]
    public required IReadOnlyCollection<GetPaymentDto> Payments { get; set; }

    [Parameter, EditorRequired] public required CurrencyDto Currency { get; set; }

    private IQueryable<GetPaymentDto> PaymentsByDateDescending =>
        Payments.OrderByDescending(p => p.PaymentDate).AsQueryable();

    private decimal TotalPaid => Payments.Sum(p => p.Amount);

    private static string FormatPaymentMethod(PaymentMethodDto method) => method switch
    {
        PaymentMethodDto.CreditCard => "Credit Card",
        PaymentMethodDto.BankTransfer => "Bank Transfer",
        PaymentMethodDto.Cash => "Cash",
        PaymentMethodDto.Check => "Check",
        PaymentMethodDto.PayPal => "PayPal",
        PaymentMethodDto.Other => "Other",
        _ => method.ToString()
    };

    private static string GetMethodBadgeClass(PaymentMethodDto method) => method switch
    {
        PaymentMethodDto.CreditCard => "bg-primary",
        PaymentMethodDto.BankTransfer => "bg-info",
        PaymentMethodDto.Cash => "bg-success",
        PaymentMethodDto.Check => "bg-warning text-dark",
        PaymentMethodDto.PayPal => "bg-secondary",
        PaymentMethodDto.Other => "bg-light text-dark",
        _ => "bg-secondary"
    };

    private static string TruncateNotes(string notes, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(notes) || notes.Length <= maxLength)
        {
            return notes;
        }

        return notes[..maxLength] + "...";
    }

    private static string FormatRecordedAt(DateTime recordedAt)
    {
        var localTime = recordedAt.ToLocalTime();
        var now = DateTime.Now;
        var diff = now - localTime;

        if (diff.TotalMinutes < 1)
        {
            return "Just now";
        }

        if (diff.TotalMinutes < 60)
        {
            return $"{(int)diff.TotalMinutes}m ago";
        }

        if (diff.TotalHours < 24)
        {
            return $"{(int)diff.TotalHours}h ago";
        }

        if (diff.TotalDays < 7)
        {
            return $"{(int)diff.TotalDays}d ago";
        }

        return localTime.ToShortDateString();
    }
}
