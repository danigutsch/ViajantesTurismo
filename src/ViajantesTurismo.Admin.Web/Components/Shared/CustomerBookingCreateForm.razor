@using ViajantesTurismo.Admin.Contracts
@using ViajantesTurismo.Admin.Web.Helpers
<EditForm Model="@Model" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator/>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Tour <span class="text-danger">*</span></label>
            <InputSelect @bind-Value="Model.TourId" class="form-select" @bind-Value:after="OnTourChanged">
                <option value="">-- Select Tour --</option>
                @foreach (var tour in Tours)
                {
                    <option value="@tour.Id">@tour.Name (@DateFormatter.FormatDate(tour.StartDate))</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => Model.TourId)"/>
            @if (Model.TourId.HasValue && SelectedTour is not null)
            {
                var availableSpots = SelectedTour.MaxCustomers - SelectedTour.CurrentCustomerCount;
                <div class="form-text">
                    @if (availableSpots > 0)
                    {
                        <span class="text-success"><i class="bi bi-check-circle"></i> @availableSpots spot@(availableSpots == 1 ? "" : "s") available (@SelectedTour.CurrentCustomerCount / @SelectedTour.MaxCustomers booked)</span>
                    }
                    else
                    {
                        <span class="text-danger"><i class="bi bi-x-circle"></i> Tour is fully booked (@SelectedTour.CurrentCustomerCount / @SelectedTour.MaxCustomers)</span>
                    }
                </div>
            }
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">Companion (Optional)</label>
            <InputSelect @bind-Value="Model.CompanionId" class="form-select">
                <option value="">-- No Companion --</option>
                @foreach (var customer in Customers.Where(c => c.Id != CurrentCustomerId))
                {
                    <option value="@customer.Id">@customer.FirstName @customer.LastName (@customer.Email)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => Model.CompanionId)"/>
        </div>
    </div>

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea @bind-Value="Model.Notes" class="form-control" id="notes" rows="3"/>
        <ValidationMessage For="@(() => Model.Notes)"/>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            <h5 class="card-title mb-0"><i class="bi bi-percent"></i> Discount (Optional)</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label for="discountType" class="form-label">Discount Type</label>
                <InputSelect id="discountType" class="form-select" @bind-Value="Model.DiscountType">
                    <option value="@DiscountTypeDto.None">No Discount</option>
                    <option value="@DiscountTypeDto.Percentage">Percentage (0-100%)</option>
                    <option value="@DiscountTypeDto.Absolute">Absolute Amount (in tour currency)</option>
                </InputSelect>
                <ValidationMessage For="@(() => Model.DiscountType)"/>
            </div>

            @if (Model.DiscountType != DiscountTypeDto.None)
            {
                <div class="mb-3">
                    <label for="discountAmount" class="form-label">
                        @if (Model.DiscountType == DiscountTypeDto.Percentage)
                        {
                            <text>Discount Percentage <span class="text-danger">*</span></text>
                        }
                        else
                        {
                            <text>Discount Amount <span class="text-danger">*</span></text>
                        }
                    </label>
                    <InputNumber id="discountAmount" class="form-control" @bind-Value="Model.DiscountAmount"
                                 @bind-Value:format="F2" step="0.01"/>
                    <ValidationMessage For="@(() => Model.DiscountAmount)"/>
                    @if (Model.DiscountType == DiscountTypeDto.Percentage)
                    {
                        <div class="form-text">Enter a value between 0 and 100</div>
                    }
                    else
                    {
                        <div class="form-text">Enter the discount amount in the tour currency</div>
                    }
                </div>

                <div class="mb-3">
                    <label for="discountReason" class="form-label">Discount Reason <span
                            class="text-danger">*</span></label>
                    <InputTextArea id="discountReason" class="form-control" @bind-Value="Model.DiscountReason"
                                   rows="2" placeholder="e.g., Early bird discount, Loyalty customer, Group discount"/>
                    <ValidationMessage For="@(() => Model.DiscountReason)"/>
                    <div class="form-text">Required for audit purposes (10-500 characters)</div>
                </div>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" disabled="@IsSubmitting">
            @if (IsSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            }
            Create Booking
        </button>
        <button type="button" class="btn btn-secondary" @onclick="OnCancel" disabled="@IsSubmitting">
            Cancel
        </button>
    </div>
</EditForm>

@code {

    [Parameter]
    public BookingFormModel Model { get; set; } = new();

    [Parameter]
    public IReadOnlyList<GetTourDto> Tours { get; set; } = [];

    [Parameter]
    public IReadOnlyList<GetCustomerDto> Customers { get; set; } = [];

    [Parameter] public Guid CurrentCustomerId { get; set; }

    [Parameter]
    public EventCallback<BookingFormModel> OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsSubmitting { get; set; }

    private GetTourDto? SelectedTour => Model.TourId.HasValue
        ? Tours.FirstOrDefault(t => t.Id == Model.TourId.Value)
        : null;

    private void OnTourChanged()
    {
        // Trigger UI update when tour selection changes
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        await OnValidSubmit.InvokeAsync(Model);
    }

}
