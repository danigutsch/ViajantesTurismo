@using ViajantesTurismo.Admin.Contracts
@using ViajantesTurismo.Admin.Web.Helpers
<EditForm Model="@Model" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator/>

    <div class="mb-3">
        <label class="form-label">Tour <span class="text-danger">*</span></label>
        <InputSelect @bind-Value="Model.TourId" class="form-select" @bind-Value:after="OnTourChanged">
            <option value="">-- Select Tour --</option>
            @foreach (var tour in Tours)
            {
                <option value="@tour.Id">@tour.Name (@DateFormatter.FormatDate(tour.StartDate))</option>
            }
        </InputSelect>
        <ValidationMessage For="@(() => Model.TourId)"/>
        @if (Model.TourId.HasValue && SelectedTour is not null)
        {
            var availableSpots = SelectedTour.MaxCustomers - SelectedTour.CurrentCustomerCount;
            <div class="form-text">
                @if (availableSpots > 0)
                {
                    <span class="text-success"><i class="bi bi-check-circle"></i> @availableSpots spot@(availableSpots == 1 ? "" : "s") available (@SelectedTour.CurrentCustomerCount / @SelectedTour.MaxCustomers booked)</span>
                }
                else
                {
                    <span class="text-danger"><i class="bi bi-x-circle"></i> Tour is fully booked (@SelectedTour.CurrentCustomerCount / @SelectedTour.MaxCustomers)</span>
                }
            </div>
        }
    </div>

    <div class="mb-3">
        <label class="form-label">Room Type <span class="text-danger">*</span></label>
        <InputSelect @bind-Value="Model.RoomType" class="form-select" @bind-Value:after="OnRoomTypeChanged">
            <option value="@RoomTypeDto.DoubleOccupancy">Double Room (Base Price)</option>
            <option value="@RoomTypeDto.SingleOccupancy">Single Room (Base Price + Supplement)</option>
        </InputSelect>
        <ValidationMessage For="@(() => Model.RoomType)"/>
        <div class="form-text">
            Double Room: Tour base price (shared room, standard).<br/>
            Single Room: Tour base price + single room supplement (solo occupancy surcharge).
            @if (Model is { RoomType: RoomTypeDto.SingleOccupancy, CompanionId: null })
            {
                <br/>
                <span class="badge bg-info mt-1"><i class="bi bi-info-circle"></i> Single Occupancy - No companion selected</span>
            }
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Bike Type <span class="text-danger">*</span></label>
        <InputSelect @bind-Value="Model.PrincipalBikeType" class="form-select">
            <option value="">-- Select Bike Type --</option>
            <option value="@BikeTypeDto.Regular">Regular Bike</option>
            <option value="@BikeTypeDto.EBike">E-Bike</option>
        </InputSelect>
        <ValidationMessage For="@(() => Model.PrincipalBikeType)"/>
    </div>

    @if (Model.RoomType == RoomTypeDto.DoubleOccupancy)
    {
        <div class="mb-3">
            <label class="form-label">Companion (Optional)</label>
            <InputSelect @bind-Value="Model.CompanionId" class="form-select"
                         @bind-Value:after="OnCompanionChanged">
                <option value="">-- No Companion --</option>
                @foreach (var customer in Customers.Where(c => c.Id != CurrentCustomerId))
                {
                    <option value="@customer.Id">@customer.FirstName @customer.LastName (@customer.Email)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => Model.CompanionId)"/>
            <div class="form-text">
                Companion is optional for double rooms (allows single occupancy of double room).
            </div>
        </div>

        @if (Model.CompanionId.HasValue)
        {
            <div class="mb-3">
                <label class="form-label">Companion Bike <span class="text-danger">*</span></label>
                <InputSelect @bind-Value="Model.CompanionBikeType" class="form-select">
                    <option value="">-- Select Bike Type --</option>
                    <option value="@BikeTypeDto.Regular">Regular Bike</option>
                    <option value="@BikeTypeDto.EBike">E-Bike</option>
                </InputSelect>
                <ValidationMessage For="@(() => Model.CompanionBikeType)"/>
            </div>
        }
    }

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea @bind-Value="Model.Notes" class="form-control" id="notes" rows="3"/>
        <ValidationMessage For="@(() => Model.Notes)"/>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            <h5 class="card-title mb-0"><i class="bi bi-percent"></i> Discount (Optional)</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label for="discountType" class="form-label">Discount Type</label>
                <InputSelect id="discountType" class="form-select" @bind-Value="Model.DiscountType">
                    <option value="@DiscountTypeDto.None">No Discount</option>
                    <option value="@DiscountTypeDto.Percentage">Percentage (0-100%)</option>
                    <option value="@DiscountTypeDto.Absolute">Absolute Amount (in tour currency)</option>
                </InputSelect>
                <ValidationMessage For="@(() => Model.DiscountType)"/>
            </div>

            @if (Model.DiscountType != DiscountTypeDto.None)
            {
                <div class="mb-3">
                    <label for="discountAmount" class="form-label">
                        @if (Model.DiscountType == DiscountTypeDto.Percentage)
                        {
                            <text>Discount Percentage <span class="text-danger">*</span></text>
                        }
                        else
                        {
                            <text>Discount Amount <span class="text-danger">*</span></text>
                        }
                    </label>
                    <InputNumber id="discountAmount" class="form-control" @bind-Value="Model.DiscountAmount"
                                 @bind-Value:format="F2" step="0.01"/>
                    <ValidationMessage For="@(() => Model.DiscountAmount)"/>
                    @if (Model.DiscountType == DiscountTypeDto.Percentage)
                    {
                        <div class="form-text">Enter a value between 0 and 100</div>
                    }
                    else
                    {
                        <div class="form-text">Enter the discount amount in the tour currency</div>
                    }
                </div>

                <div class="mb-3">
                    <label for="discountReason" class="form-label">Discount Reason <span
                            class="text-danger">*</span></label>
                    <InputTextArea id="discountReason" class="form-control" @bind-Value="Model.DiscountReason"
                                   rows="2" placeholder="e.g., Early bird discount, Loyalty customer, Group discount"/>
                    <ValidationMessage For="@(() => Model.DiscountReason)"/>
                    <div class="form-text">Required for audit purposes (10-500 characters)</div>
                </div>
            }
        </div>
    </div>

    @if (SelectedTour is not null)
    {
        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5 class="card-title mb-0"><i class="bi bi-calculator"></i> Price Breakdown</h5>
            </div>
            <div class="card-body">
                @{
                    var subtotal = BookingPriceCalculator.CalculateSubtotal(
                        Model.RoomType,
                        Model.PrincipalBikeType,
                        Model.CompanionBikeType,
                        SelectedTour.Price,
                        SelectedTour.SingleRoomSupplementPrice,
                        SelectedTour.RegularBikePrice,
                        SelectedTour.EBikePrice);
                    var discountAmount = BookingPriceCalculator.CalculateDiscountAmount(Model.DiscountType, Model.DiscountAmount, subtotal);
                    var finalTotal = BookingPriceCalculator.CalculateFinalTotal(subtotal, discountAmount);
                }

                <dl class="row mb-0">
                    <dt class="col-sm-8">Subtotal (before discount):</dt>
                    <dd class="col-sm-4 text-end">@FormatPrice(subtotal, SelectedTour.Currency)</dd>

                    @if (Model.DiscountType != DiscountTypeDto.None && discountAmount > 0)
                    {
                        <dt class="col-sm-8 text-danger">
                            Discount
                            @if (Model.DiscountType == DiscountTypeDto.Percentage)
                            {
                                <text>(@Model.DiscountAmount.ToString("F2")%)</text>
                            }
                            :
                        </dt>
                        <dd class="col-sm-4 text-end text-danger">
                            -@FormatPrice(discountAmount, SelectedTour.Currency)</dd>
                    }

                    <dt class="col-sm-8 fw-bold border-top pt-2">Final Total:</dt>
                    <dd class="col-sm-4 text-end fw-bold border-top pt-2">@FormatPrice(finalTotal, SelectedTour.Currency)</dd>
                </dl>

                @if (finalTotal <= 0 && Model.DiscountType != DiscountTypeDto.None)
                {
                    <div class="alert alert-warning mb-0 mt-2">
                        <i class="bi bi-exclamation-triangle"></i> Warning: Final price cannot be zero or negative.
                    </div>
                }
            </div>
        </div>
    }

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" disabled="@IsSubmitting">
            @if (IsSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            }
            Create Booking
        </button>
        <button type="button" class="btn btn-secondary" @onclick="OnCancel" disabled="@IsSubmitting">
            Cancel
        </button>
    </div>
</EditForm>

@code {

    [Parameter]
    public BookingFormModel Model { get; set; } = new();

    [Parameter]
    public IReadOnlyList<GetTourDto> Tours { get; set; } = [];

    [Parameter]
    public IReadOnlyList<GetCustomerDto> Customers { get; set; } = [];

    [Parameter] public Guid CurrentCustomerId { get; set; }

    [Parameter]
    public EventCallback<BookingFormModel> OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsSubmitting { get; set; }

    private GetTourDto? SelectedTour => Model.TourId.HasValue
        ? Tours.FirstOrDefault(t => t.Id == Model.TourId.Value)
        : null;

    private void OnTourChanged()
    {
        StateHasChanged();
    }

    private void OnRoomTypeChanged()
    {
        if (Model.RoomType == RoomTypeDto.SingleOccupancy)
        {
            Model.CompanionId = null;
            Model.CompanionBikeType = null;
        }
    }

    private void OnCompanionChanged()
    {
        if (!Model.CompanionId.HasValue)
        {
            Model.CompanionBikeType = null;
        }
        else
        {
            var companion = Customers.FirstOrDefault(c => c.Id == Model.CompanionId.Value);
            if (companion is not null)
            {
                Model.CompanionBikeType = companion.BikeType;
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        await OnValidSubmit.InvokeAsync(Model);
    }

    private static string FormatPrice(decimal amount, CurrencyDto currency) => CurrencyFormatter.Format(amount, currency);

}
