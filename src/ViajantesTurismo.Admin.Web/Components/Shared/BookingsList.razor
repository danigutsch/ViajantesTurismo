@using Microsoft.AspNetCore.Components.QuickGrid
@using ViajantesTurismo.Admin.Contracts
@if (Bookings == null || !Bookings.Any())
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i> No bookings found.
    </div>
}
else
{
    <QuickGrid Items="@Bookings.AsQueryable()" Class="table table-hover" Pagination="@(Bookings.Count() > 10 ? _pagination : null)">
        <PropertyColumn Property="@(b => b.BookingDate)" Title="Booking Date" Format="dd/MM/yyyy HH:mm" Sortable="true" />

        @if (ShowTourInfo)
        {
            <TemplateColumn Title="Tour" Sortable="true" SortBy="GridSort<GetBookingDto>.ByAscending(b => b.TourName)">
                <a href="/tours/@context.TourId">@context.TourName</a>
                <br/>
                <small class="text-muted">@context.TourIdentifier</small>
            </TemplateColumn>
        }

        @if (ShowCustomerInfo)
        {
            <TemplateColumn Title="Customer" Sortable="true" SortBy="GridSort<GetBookingDto>.ByAscending(b => b.CustomerName)">
                <a href="/customers/@context.CustomerId">@context.CustomerName</a>
            </TemplateColumn>
        }

        <TemplateColumn Title="Companion">
            @if (context.CompanionId.HasValue)
            {
                <a href="/customers/@context.CompanionId">@context.CompanionName</a>
            }
            else
            {
                <span class="text-muted">-</span>
            }
        </TemplateColumn>

        <PropertyColumn Property="@(b => b.TotalPrice)" Title="Total Price" Format="C" Sortable="true" />

        <TemplateColumn Title="Discount">
            @if (context.DiscountType != DiscountTypeDto.None)
            {
                <span class="badge @GetDiscountBadgeClass(context.DiscountType)"
                      title="@GetDiscountTooltip(context)">
                    <i class="bi bi-percent"></i> @GetDiscountDisplayText(context)
                </span>
            }
            else
            {
                <span class="text-muted">-</span>
            }
        </TemplateColumn>

        <TemplateColumn Title="Status">
            <BookingStatusBadge Status="@context.Status"/>
        </TemplateColumn>

        <TemplateColumn Title="Payment">
            <PaymentStatusBadge Status="@context.PaymentStatus"/>
        </TemplateColumn>

        <TemplateColumn Title="Actions">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm btn-primary"
                        @onclick="() => OnEditClicked(context.Id)" title="Edit Booking">
                    <i class="bi bi-pencil"></i> Edit
                </button>
                @if (context.Status == BookingStatusDto.Pending)
                {
                    <button type="button" class="btn btn-sm btn-success"
                            @onclick="() => OnConfirmClicked(context.Id)" title="Confirm Booking">
                        <i class="bi bi-check-circle"></i> Confirm
                    </button>
                }
                else if (context.Status == BookingStatusDto.Confirmed)
                {
                    <button type="button" class="btn btn-sm btn-info"
                            @onclick="() => OnCompleteClicked(context.Id)" title="Complete Booking">
                        <i class="bi bi-check2-all"></i> Complete
                    </button>
                }
                @if (context.Status != BookingStatusDto.Completed && context.Status != BookingStatusDto.Cancelled)
                {
                    <button type="button" class="btn btn-sm btn-warning"
                            @onclick="() => OnCancelClicked(context.Id)" title="Cancel Booking">
                        <i class="bi bi-x-circle"></i> Cancel
                    </button>
                }
                <button type="button" class="btn btn-sm btn-danger"
                        @onclick="() => OnDeleteClicked(context.Id)" title="Delete Booking">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </TemplateColumn>
    </QuickGrid>

    @if (Bookings.Count() > 10)
    {
        <Paginator State="@_pagination" />
    }
}

@code {
    private readonly PaginationState _pagination = new() { ItemsPerPage = 10 };

    [Parameter]
    public IEnumerable<GetBookingDto>? Bookings { get; set; }

    [Parameter]
    public bool ShowTourInfo { get; set; } = true;

    [Parameter]
    public bool ShowCustomerInfo { get; set; } = true;

    [Parameter] public EventCallback<Guid> OnEdit { get; set; }

    [Parameter] public EventCallback<Guid> OnConfirm { get; set; }

    [Parameter] public EventCallback<Guid> OnCancel { get; set; }

    [Parameter] public EventCallback<Guid> OnComplete { get; set; }

    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    private async Task OnEditClicked(Guid bookingId)
    {
        await OnEdit.InvokeAsync(bookingId);
    }

    private async Task OnConfirmClicked(Guid bookingId)
    {
        await OnConfirm.InvokeAsync(bookingId);
    }

    private async Task OnCancelClicked(Guid bookingId)
    {
        await OnCancel.InvokeAsync(bookingId);
    }

    private async Task OnCompleteClicked(Guid bookingId)
    {
        await OnComplete.InvokeAsync(bookingId);
    }

    private async Task OnDeleteClicked(Guid bookingId)
    {
        await OnDelete.InvokeAsync(bookingId);
    }

    private string GetDiscountBadgeClass(DiscountTypeDto discountType)
    {
        return discountType switch
        {
            DiscountTypeDto.None => "bg-secondary",
            DiscountTypeDto.Percentage => "bg-primary",
            DiscountTypeDto.Absolute => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }

    private string GetDiscountDisplayText(GetBookingDto booking)
    {
        return booking.DiscountType switch
        {
            DiscountTypeDto.Percentage => $"{booking.DiscountAmount:F2}%",
            DiscountTypeDto.Absolute => $"{booking.DiscountAmount:C}",
            _ => "-"
        };
    }

    private string GetDiscountTooltip(GetBookingDto booking)
    {
        if (booking.DiscountType == DiscountTypeDto.None)
        {
            return "No discount applied";
        }

        var discountTypeText = booking.DiscountType == DiscountTypeDto.Percentage
            ? "Percentage Discount"
            : "Absolute Discount";

        return string.IsNullOrWhiteSpace(booking.DiscountReason)
            ? discountTypeText
            : $"{discountTypeText}: {booking.DiscountReason}";
    }

}
