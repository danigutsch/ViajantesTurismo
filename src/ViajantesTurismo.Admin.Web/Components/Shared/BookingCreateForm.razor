@using ViajantesTurismo.AdminApi.Contracts
<EditForm Model="@Model" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator/>

    @if (Tours.Any())
    {
        <div class="mb-3">
            <label class="form-label">Tour <span class="text-danger">*</span></label>
            <InputSelect @bind-Value="Model.TourId" class="form-select">
                <option value="">-- Select Tour --</option>
                @foreach (var tour in Tours)
                {
                    <option value="@tour.Id">@tour.Name (@tour.StartDate.ToShortDateString())</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => Model.TourId)"/>
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Customer <span class="text-danger">*</span></label>
        <InputSelect @bind-Value="Model.CustomerId" class="form-select" @bind-Value:after="OnPrincipalCustomerChanged">
            <option value="">-- Select Customer --</option>
            @foreach (var customer in Customers)
            {
                <option value="@customer.Id">@customer.FirstName @customer.LastName (@customer.Email)</option>
            }
        </InputSelect>
        <ValidationMessage For="@(() => Model.CustomerId)"/>
    </div>

    <div class="mb-3">
        <label class="form-label">Room Type <span class="text-danger">*</span></label>
        <InputSelect @bind-Value="Model.RoomType" class="form-select" @bind-Value:after="OnRoomTypeChanged">
            <option value="@RoomTypeDto.SingleRoom">Single Room (Base Price)</option>
            <option value="@RoomTypeDto.DoubleRoom">Double Room (Base Price + Supplement)</option>
        </InputSelect>
        <ValidationMessage For="@(() => Model.RoomType)"/>
        <div class="form-text">
            Single Room: Tour base price (standard room).<br/>
            Double Room: Tour base price + double room supplement (larger space, more expensive).
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Principal Customer Bike <span class="text-danger">*</span></label>
        <InputSelect @bind-Value="Model.PrincipalBikeType" class="form-select">
            <option value="@BikeTypeDto.None">No Bike</option>
            <option value="@BikeTypeDto.Regular">Regular Bike</option>
            <option value="@BikeTypeDto.EBike">E-Bike</option>
        </InputSelect>
        <ValidationMessage For="@(() => Model.PrincipalBikeType)"/>
    </div>

    @if (Model.RoomType == RoomTypeDto.DoubleRoom)
    {
        <div class="mb-3">
            <label class="form-label">Companion (Optional)</label>
            <InputSelect @bind-Value="Model.CompanionId" class="form-select"
                         @bind-Value:after="OnCompanionCustomerChanged">
                <option value="">-- No Companion --</option>
                @foreach (var customer in Customers.Where(c => !Model.CustomerId.HasValue || c.Id != Model.CustomerId.Value))
                {
                    <option value="@customer.Id">@customer.FirstName @customer.LastName (@customer.Email)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => Model.CompanionId)"/>
            <div class="form-text">
                Companion is optional for double rooms (allows single occupancy of double room).
            </div>
        </div>

        @if (Model.CompanionId.HasValue)
        {
            <div class="mb-3">
                <label class="form-label">Companion Bike <span class="text-danger">*</span></label>
                <InputSelect @bind-Value="Model.CompanionBikeType" class="form-select">
                    <option value="@BikeTypeDto.None">No Bike</option>
                    <option value="@BikeTypeDto.Regular">Regular Bike</option>
                    <option value="@BikeTypeDto.EBike">E-Bike</option>
                </InputSelect>
                <ValidationMessage For="@(() => Model.CompanionBikeType)"/>
            </div>
        }
    }

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea @bind-Value="Model.Notes" class="form-control" id="notes" rows="3"/>
        <ValidationMessage For="@(() => Model.Notes)"/>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" disabled="@IsSubmitting">
            @if (IsSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            }
            Create Booking
        </button>
        <button type="button" class="btn btn-secondary" @onclick="OnCancel" disabled="@IsSubmitting">
            Cancel
        </button>
    </div>
</EditForm>

@code {

    [Parameter]
    public BookingFormModel Model { get; set; } = new();

    [Parameter]
    public IReadOnlyList<GetCustomerDto> Customers { get; set; } = [];

    [Parameter]
    public IReadOnlyList<GetTourDto> Tours { get; set; } = [];

    [Parameter]
    public EventCallback<BookingFormModel> OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsSubmitting { get; set; }

    private void OnPrincipalCustomerChanged()
    {
        if (!Model.CustomerId.HasValue)
        {
            return;
        }

        var customer = Customers.FirstOrDefault(c => c.Id == Model.CustomerId.Value);
        if (customer is not null)
        {
            Model.PrincipalBikeType = customer.BikeType;
        }
    }

    private void OnRoomTypeChanged()
    {
        if (Model.RoomType != RoomTypeDto.SingleRoom)
        {
            return;
        }

        Model.CompanionId = null;
        Model.CompanionBikeType = null;
    }

    private void OnCompanionCustomerChanged()
    {
        if (!Model.CompanionId.HasValue)
        {
            Model.CompanionBikeType = null;
        }
        else
        {
            var companion = Customers.FirstOrDefault(c => c.Id == Model.CompanionId.Value);
            if (companion is not null)
            {
                Model.CompanionBikeType = companion.BikeType;
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        await OnValidSubmit.InvokeAsync(Model);
    }

}
