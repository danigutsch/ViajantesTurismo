# Behavior-test analyzer hardening exceptions.
#
# These files produce test-run reports and console diagnostics intended for
# developer feedback, not localizable product UI. Remove these entries when the
# reporting hook is replaced with structured test output that avoids literals.

[Hooks/InvariantCoverageHooks.cs]
dotnet_diagnostic.CA1303.severity = none

# Behavior step definitions intentionally use repeated binding shapes and framework-owned
# binding entrypoints that would otherwise force low-value null-guard boilerplate or
# empty placeholder steps. Owner: behavior-test maintainers. Remove when Reqnroll step
# bindings no longer require these framework-shaped methods.
[Steps/**/*.cs]
dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.S1186.severity = none
dotnet_diagnostic.S4136.severity = none
dotnet_diagnostic.S4144.severity = none
