<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <RootNamespace>ViajantesTurismo.Admin.BehaviorTests</RootNamespace>
        <ReqnrollDeleteObsoleteCodeBehindFilesOnClean>true</ReqnrollDeleteObsoleteCodeBehindFilesOnClean>
    </PropertyGroup>

    <ItemGroup>
        <Using Include="System.Globalization"/>
        <Using Include="Reqnroll"/>
        <Using Include="ViajantesTurismo.Admin.BehaviorTests.Context"/>
        <Using Include="ViajantesTurismo.Admin.Domain.Customers"/>
        <Using Include="ViajantesTurismo.Admin.Domain.Tours"/>
        <Using Include="ViajantesTurismo.Admin.Testing.Behavior"/>
        <Using Include="SharedKernel.Results"/>
        <Using Include="SharedKernel.Testing.Assertions"/>
        <Using Include="Xunit" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage">
            <PrivateAssets>all</PrivateAssets>
        </PackageReference>
        <PackageReference Include="Reqnroll.xunit.v3" />
        <PackageReference Include="xunit.v3.mtp-v2" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\ViajantesTurismo.Admin.Application\ViajantesTurismo.Admin.Application.csproj"/>
        <ProjectReference Include="..\SharedKernel.Testing.Assertions\SharedKernel.Testing.Assertions.csproj" />
        <ProjectReference Include="..\ViajantesTurismo.Admin.Testing\ViajantesTurismo.Admin.Testing.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <None Update="specs\**\*.feature">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup>
        <Content Include="**/*.feature" />
    </ItemGroup>

</Project>
