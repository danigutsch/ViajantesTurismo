<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <NoWarn>$(NoWarn);CA1812</NoWarn>
    </PropertyGroup>

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <RootNamespace>ViajantesTurismo.Admin.BehaviorTests</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <Content Include="xunit.runner.json" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="System.Globalization"/>
        <Using Include="Reqnroll"/>
        <Using Include="ViajantesTurismo.Admin.BehaviorTests.Context"/>
        <Using Include="ViajantesTurismo.Admin.Domain.Customers"/>
        <Using Include="ViajantesTurismo.Admin.Domain.Tours"/>
        <Using Include="ViajantesTurismo.Admin.Tests.Shared.Behavior"/>
        <Using Include="ViajantesTurismo.Common.Results"/>
        <Using Include="Xunit" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage">
            <PrivateAssets>all</PrivateAssets>
        </PackageReference>
        <PackageReference Include="Reqnroll.xunit.v3" />
        <PackageReference Include="xunit.v3.mtp-v2" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\ViajantesTurismo.Admin.Application\ViajantesTurismo.Admin.Application.csproj"/>
        <ProjectReference Include="..\ViajantesTurismo.Admin.Tests.Shared\ViajantesTurismo.Admin.Tests.Shared.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <None Update="specs\**\*.feature">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup>
        <Content Include="**/*.feature" />
    </ItemGroup>

</Project>
