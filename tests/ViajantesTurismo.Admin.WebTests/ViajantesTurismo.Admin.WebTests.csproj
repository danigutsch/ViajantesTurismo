        <Using Include="ViajantesTurismo.Admin.Web.Components.Shared"/>
        <Using Include="ViajantesTurismo.Admin.Web.Services"/>
        <Using Include="Xunit"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="bunit"/>
        <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage">
            <PrivateAssets>all</PrivateAssets>
        </PackageReference>
        <PackageReference Include="xunit.v3.mtp-v2"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\ViajantesTurismo.Admin.Web\ViajantesTurismo.Admin.Web.csproj"/>
