{
  "default": true,
  "MD003": { "style": "atx" },
  "MD004": { "style": "dash" },
  "MD007": { "indent": 4 },
  "MD013": {
    "line_length": 160,
    "tables": false,
    "code_blocks": false,
    "headings": false,
    "stern": true
  },
  "MD024": { "siblings_only": true },
  "MD025": true,
  "MD026": { "punctuation": ".,;:!" },
  "MD029": { "style": "ordered" },
  "MD030": {
    "ul_single": 1,
    "ul_multi": 1,
    "ol_single": 1,
    "ol_multi": 1
  },
  "MD033": {
    "allowed_elements": ["details", "summary", "br", "img", "kbd", "sub", "sup"]
  },
  "MD035": { "style": "---" },
  "MD041": false,
  "MD046": { "style": "fenced" },
  "MD048": { "style": "backtick" }
}
