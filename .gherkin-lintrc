{
  "no-files-without-scenarios": "on",
  "no-unnamed-features": "on",
  "no-unnamed-scenarios": "on",
  "no-dupe-scenario-names": ["on", "in-feature"],
  "no-dupe-feature-names": "on",
  "no-partially-commented-tag-lines": "on",
  "indentation": [
    "on",
    {
      "Feature": 0,
      "Background": 4,
      "Rule": 4,
      "Scenario": 4,
      "Step": 8,
      "Examples": 8,
      "example": 10,
      "given": 8,
      "when": 8,
      "then": 8,
      "and": 8,
      "but": 8
    }
  ],
  "no-trailing-spaces": "on",
  "new-line-at-eof": ["on", "yes"],
  "no-multiple-empty-lines": "on",
  "no-empty-file": "on",
  "allowed-tags": [
    "on",
    {
      "patterns": [
        "^@BC:.+",
        "^@Agg:.+",
        "^@Entity:.+",
        "^@VO:.+",
        "^@ADR:\\d+",
        "^@WI:.+",
        "^@US:\\d+",
        "^@Invariant:INV-.+",
        "^@smoke$",
        "^@regression$",
        "^@integration$",
        "^@unit$",
        "^@critical$",
        "^@high$",
        "^@medium$",
        "^@low$",
        "^@happy_path$",
        "^@edge_case$",
        "^@error_case$",
        "^@security$",
        "^@performance$",
        "^@architectural$",
        "^@wip$",
        "^@manual$",
        "^@automated$",
        "^@flaky$",
        "^@ignore$",
        "^@summary$",
        "^@duplicate_resolution$"
      ],
      "tags": [
        "@BC:Admin",
        "@Agg:Tour",
        "@Agg:Booking",
        "@Agg:Customer",
        "@Entity:Payment",
        "@Entity:BookingCustomer",
        "@Entity:Booking",
        "@Entity:PersonalInfo",
        "@Entity:ContactInfo",
        "@Entity:IdentificationInfo",
        "@VO:DateRange",
        "@VO:Discount",
        "@VO:PersonalInfo",
        "@VO:PhysicalInfo",
        "@VO:MedicalInfo",
        "@VO:EmergencyContact",
        "@VO:Address",
        "@smoke",
        "@regression",
        "@integration",
        "@unit",
        "@critical",
        "@high",
        "@medium",
        "@low",
        "@happy_path",
        "@edge_case",
        "@error_case",
        "@security",
        "@performance",
        "@architectural",
        "@wip",
        "@manual",
        "@automated",
        "@flaky",
        "@ignore",
        "@summary",
        "@duplicate_resolution"
      ]
    }
  ],
  "name-length": [
    "on",
    {
      "Feature": 250,
      "Rule": 150,
      "Scenario": 150,
      "Step": 200
    }
  ],
  "no-restricted-tags": [
    "on",
    {
      "tags": ["@skip"]
    }
  ],
  "no-scenario-outlines-without-examples": "on",
  "use-and": "on",
  "no-homogenous-tags": "off",
  "no-superfluous-tags": "off"
}
